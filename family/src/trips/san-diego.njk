  .detail-card:hover { transform: translateY(-2px); }
  .detail-card .icon { font-size: 2rem; margin-bottom: 6px; }
  .detail-card h4 { font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; color: var(--wedding-dark); }
  .detail-card p { font-size: 0.82rem; color: var(--text-mid); }

  footer {
    text-align: center;
    padding: 24px;
    font-size: 0.82rem;
    color: var(--text-light);
  }

  @media (max-width: 600px) {
