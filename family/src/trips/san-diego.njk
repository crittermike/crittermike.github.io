  .todo-item input[type="checkbox"] { width: 16px; height: 16px; accent-color: #3fb950; }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
  }
  .detail-card {
    background: #21262d;
    border: 1px solid #30363d;
    border-radius: 12px;
    padding: 18px;
    text-align: center;
    transition: transform 0.15s;
