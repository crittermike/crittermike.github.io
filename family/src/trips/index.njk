  <!-- Overview -->
  <section class="ed-section">
    <div class="ed-section-head"><h2>The trip</h2></div>
    <div class="ed-prose">
      <p>A lakefront house on Lake Hartwell, about 1.5 hours from Greenville via I-85. The private dock is covered, has deep water for swimming, and fish bite right off it. A pontoon rental for the middle of the week rounds it out.</p>
    </div>
    <dl class="ed-kv" style="margin-top:18px;">
