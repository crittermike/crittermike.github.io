  <!-- Pontoon -->
  <section class="ed-section">
    <div class="ed-section-head"><h2>Pontoon rental<span class="ed-status">Booked</span></h2><div class="aside">Boatsetter · Greg (5.0 / 146)</div></div>
    <div class="ed-grid">

      <div class="ed-cell">
        <div class="ttl">Schedule</div>
        <div class="body">
          <strong>Tritoon 150hp · 22 ft</strong>
          <div class="leg">
            <strong>Pickup</strong> · Tue Jul 7, 8:30 AM<br>
            <strong>Return</strong> · Thu Jul 9, 6:00 PM<br>
            3 days &middot; no captain (we drive)
          </div>
        </div>
      </div>

      <div class="ed-cell">
        <div class="ttl">Boat</div>
        <div class="body">
          <strong>2014 Premier Marine 220 SunSation RE</strong>
          <div class="leg">
            Triple tube · 150hp · capacity 12<br>
            Stereo + Bluetooth, swim ladder, anchor, kids' life jackets. Tritoon pulls tubes easy, wakeboarding is doable but not ripping.
          </div>
        </div>
      </div>

      <div class="ed-cell">
        <div class="ttl">Details</div>
        <div class="body">
          <strong>$1,798.38</strong> <span style="color:var(--text-mid);">(fuel not included)</span>
          <div class="leg">
            Booking <strong>SMGJBNK</strong><br>
            Passengers: 10<br>
            Pickup: <a class="ed-link" href="https://www.google.com/maps/search/117+Chestnut+Lane+Anderson+SC+29625" target="_blank">117 Chestnut Lane, Anderson, SC</a>
          </div>
        </div>
      </div>

      <div class="ed-cell">
        <div class="ttl">Add-ons</div>
        <div class="body">
          Available: paddleboards ($50), floating mat ($75), floating island ($100/hr), fishing gear ($25/passenger), cooler ($25), tubes, wakeboards.
        </div>
      </div>

    </div>
    <div class="ed-callout">
      <strong>Don't get burned</strong>
      <ul>
        <li>Refuel before return or $75 service fee + fuel cost.</li>
        <li>Late = hourly rate. 30+ min late = additional $100 fee.</li>
        <li>No refunds within 30 days of rental (past that as of 6/7).</li>
        <li>Security deposit due Jul 5.</li>
      </ul>
    </div>
  </section>

