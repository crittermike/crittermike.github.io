---
layout: base.njk
pagination:
  data: recipes
  size: 1
  alias: recipe
permalink: "/recipes/{{ recipe.slug }}/index.html"
eleventyComputed:
  title: "{{ recipe.name }}"
---

<style>
  :root {
    --accent: #d29922;
    --accent-dim: rgba(210, 153, 34, 0.14);
  }
</style>

<div class="ed-wrap">

  <header class="ed-header">
    <div class="ed-eyebrow">
      Recipe
      {%- if recipe.effort %} · {{ recipe.effort }}{% endif -%}
      {%- if recipe.tags.includes("crockpot") %} · crockpot{% endif -%}
    </div>
    <h1 class="ed-title">{{ recipe.name }}</h1>
    {% if recipe.notes and not recipe.hasFullRecipe %}
    <p class="ed-deck">{{ recipe.notes }}</p>
    {% endif %}
  </header>

  {% if recipe.servings or recipe.protein_g or recipe.cal or recipe.prep_min or recipe.cook_min %}
  <div class="ed-meta">
    {% if recipe.servings %}<div class="ed-meta-item"><div class="label">Serves</div><div class="value">{{ recipe.servings }}</div></div>{% endif %}
    {% if recipe.prep_min %}<div class="ed-meta-item"><div class="label">Prep</div><div class="value">{{ recipe.prep_min }} min</div></div>{% endif %}
    {% if recipe.cook_min %}<div class="ed-meta-item"><div class="label">Cook</div><div class="value">{{ recipe.cook_min }} min</div></div>{% endif %}
    {% if recipe.protein_g %}<div class="ed-meta-item"><div class="label">Protein</div><div class="value">{{ recipe.protein_g }}g</div></div>{% endif %}
    {% if recipe.cal %}<div class="ed-meta-item"><div class="label">Calories</div><div class="value">{{ recipe.cal }}</div></div>{% endif %}
    {% if recipe.kid_friendly %}<div class="ed-meta-item"><div class="label">Kids</div><div class="value">Yes</div></div>{% endif %}
  </div>
  {% endif %}

  {% if recipe.all_ingredients.length %}
  <section class="ed-section">
    <div class="ed-section-head">
      <h2>Ingredients</h2>
      <div class="aside">Tap to check off as you go</div>
    </div>
    <ul class="rx-ingredients" id="rx-ing">
      {% for group in recipe.ingredient_groups %}
        {% if group.heading %}
        <li class="group-heading">{{ group.heading }}</li>
        {% endif %}
        {% for item in group.items %}
        <li class="ing">
          <input type="checkbox" data-ing="{{ (group.heading or 'main') | lower }}-{{ loop.index0 }}-{{ item | lower }}">
          <span class="ing-text">{{ item }}</span>
        </li>
        {% endfor %}
      {% endfor %}
    </ul>
    <button class="rx-reset" id="rx-reset" type="button">Reset all</button>
  </section>
  {% endif %}

  {% if recipe.steps.length %}
  <section class="ed-section">
    <div class="ed-section-head">
      <h2>Method</h2>
    </div>
    <ol class="rx-steps">
      {% for step in recipe.steps %}
      <li>{{ step }}</li>
      {% endfor %}
    </ol>
  </section>
  {% endif %}

  {% if recipe.notes and recipe.hasFullRecipe %}
  <section class="ed-section">
    <div class="ed-section-head">
      <h2>Notes &amp; pitfalls</h2>
    </div>
    <div class="rx-notes ed-prose">
      {{ recipe.notes | safe }}
    </div>
  </section>
  {% endif %}

  {% if not recipe.hasFullRecipe and recipe.all_ingredients.length == 0 %}
  <section class="ed-section">
    <div class="rx-notes">
      <p>No full recipe saved yet for this one. It's in the family meal rotation.</p>
    </div>
  </section>
  {% endif %}

  <footer class="ed-footer">
    <a class="ed-link" href="/family/recipes/">← All recipes</a>
    <span class="ed-link-muted">Source: <code>recipe-{{ recipe.slug }}.md</code></span>
  </footer>

</div>

<script>
(function() {
  const KEY = 'recipe-checked:{{ recipe.slug }}';
  const boxes = document.querySelectorAll('#rx-ing .ing input[type="checkbox"]');
  const reset = document.getElementById('rx-reset');

  // Restore state
  let checked = {};
  try {
    checked = JSON.parse(localStorage.getItem(KEY) || '{}');
  } catch (e) { checked = {}; }

  boxes.forEach(box => {
    if (checked[box.dataset.ing]) {
      box.checked = true;
      box.closest('.ing').classList.add('checked');
    }
    box.addEventListener('change', () => {
      box.closest('.ing').classList.toggle('checked', box.checked);
      checked[box.dataset.ing] = box.checked;
      localStorage.setItem(KEY, JSON.stringify(checked));
    });
  });

  // Click anywhere on the row toggles (except the checkbox itself, which native-handles it)
  document.querySelectorAll('#rx-ing .ing').forEach(li => {
    li.addEventListener('click', e => {
      if (e.target.tagName === 'INPUT') return;
      const box = li.querySelector('input[type="checkbox"]');
      box.checked = !box.checked;
      box.dispatchEvent(new Event('change'));
    });
  });

  if (reset) {
    reset.addEventListener('click', () => {
      boxes.forEach(box => {
        box.checked = false;
        box.closest('.ing').classList.remove('checked');
      });
      localStorage.removeItem(KEY);
    });
  }
})();
</script>
