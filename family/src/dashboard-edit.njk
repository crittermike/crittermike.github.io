title: Dashboard Edit (Spike)
permalink: "/dashboard-edit/index.html"
eleventyExcludeFromCollections: true
---

<!--
  GRIDSTACK SPIKE — drag/resize/add/remove sandbox.
  Does NOT touch /dashboard/. Layout persisted to localStorage key:
    crittercrew.dashedit.layout.v1   (positions + which tiles are present)
  Toggle edit mode via Unlock. In edit mode:
    - drag/resize any tile
    - ✕ on each tile removes it
    - "+ Add tile" in toolbar opens picker of removed tiles
-->

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack.min.css">
<script src="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack-all.js"></script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap');

  #site-nav { display: none !important; }
  html, body { overflow: hidden; height: 100%; margin: 0; }

  /* === DESIGN TOKENS (match /dashboard/) === */
  :root {
    --warm-bg: #f5f1ea;
    --card-bg: #ffffff;
    --text-dark: #1f2328;
    --text-mid: #57606a;
    --text-light: #8b949e;
    --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.06);
    --accent-orange: #d96a2a;
    --accent-teal: #2da44e;
    --accent-gold: #bf8700;
    --accent-rose: #cf222e;
    --accent-blue: #0969da;
    --border: #e3e6ea;
    --border-soft: #eef0f3;
    --surface: #ffffff;
    --surface-mute: rgba(0,0,0,0.025);
    --surface-mute-2: rgba(0,0,0,0.035);
    --surface-mute-3: rgba(0,0,0,0.05);
    --surface-mute-track: rgba(0,0,0,0.04);
    --on-accent: #ffffff;
  }

  /* === DARK THEME (auto-switched after sunset by JS) === */
  :root[data-theme="dark"] {
    --warm-bg: #0f1217;
    --card-bg: #181c23;
    --text-dark: #f1f4fa;
    --text-mid: #d6dce6;
    --text-light: #a8b1bf;
    --shadow: 0 1px 3px rgba(0,0,0,0.45), 0 4px 14px rgba(0,0,0,0.55);
    --accent-orange: #f08a55;
    --accent-teal: #4ac373;
    --accent-gold: #e0a93b;
    --accent-rose: #f06372;
    --accent-blue: #5aa9f5;
    --border: #2a313c;
    --border-soft: #232932;
    --surface: #1f242c;
    --surface-mute: rgba(255,255,255,0.04);
    --surface-mute-2: rgba(255,255,255,0.06);
    --surface-mute-3: rgba(255,255,255,0.09);
    --surface-mute-track: rgba(255,255,255,0.16);
    --on-accent: #0f1217;
  }

  /* Smooth the flip so it's not a jump-scare at sunset */
  html, body, .stage, .grid-stack-item-content, .ed-bar,
  .ed-bar button, .picker, .pick-item, .ed-toast {
    transition: background-color 0.5s ease, color 0.4s ease, border-color 0.5s ease;
  }

  body {
    background: var(--warm-bg);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
    color: var(--text-dark);
  }

  /* === FLOATING TOOLBAR (hidden by default, toggled by top-right tap) ===
     Self-contained light control-panel palette so it stays crisp over either
     the day or the night dashboard theme. */
  .ed-bar {
    --tb-bg: #ffffff; --tb-soft: #f1f5f9; --tb-line: #e2e8f0;
    --tb-ink: #0f172a; --tb-ink-soft: #334155; --tb-mut: #64748b;
    --tb-amber: #f59e0b; --tb-danger: #dc2626;
    position: fixed;
    top: 12px; right: 12px;
    display: none;
    flex-direction: column;
    gap: 12px;
    padding: 14px;
    width: min(94vw, 600px);
    background: var(--tb-bg);
    border: 1px solid var(--tb-line);
    border-radius: 16px;
    box-shadow: 0 18px 44px rgba(15,23,42,0.24);
    z-index: 10000;
    color: var(--tb-ink);
    font-size: 13px;
  }
  .ed-bar.open { display: flex; }
  .ed-tap {
    position: fixed;
    top: 0; right: 0;
    width: 80px; height: 80px;
    z-index: 9999;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  /* Shared button base */
  .ed-bar button {
    font-family: inherit;
    border: 1px solid var(--tb-line);
    background: var(--tb-soft);
    border-radius: 9px;
    padding: 7px 12px;
    font-size: 13px; font-weight: 600;
    color: var(--tb-ink-soft);
    cursor: pointer; white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
    transition: background .12s ease, border-color .12s ease, color .12s ease;
  }
  .ed-bar button:hover { background: #e7edf3; color: var(--tb-ink); }
  .ed-bar button:disabled { opacity: 0.45; cursor: not-allowed; }
  .ed-bar button.danger { color: var(--tb-danger); background: var(--tb-bg); border-color: #f1cccc; }
  .ed-bar button.danger:hover { background: #fdecec; color: var(--tb-danger); }

  /* Header: section caption + mode toggles (Auto / Edit) */
  .ed-head { display: flex; align-items: center; gap: 10px; }
  .ed-cap {
    flex: 1 1 auto; min-width: 0;
    font-size: 11px; font-weight: 700; letter-spacing: 0.6px;
    text-transform: uppercase; color: var(--tb-mut);
  }
  .ed-head-actions { display: flex; gap: 8px; flex: 0 0 auto; }
  .ed-auto::before { content: "◇"; margin-right: 6px; }
  .ed-auto.on { background: #16a34a; color: #fff; border-color: transparent; }
  .ed-auto.on:hover { background: #15803d; color: #fff; }
  .ed-auto.on::before { content: "◆"; }
  .ed-edit-toggle { background: var(--tb-ink); color: #fff; border-color: var(--tb-ink); }
  .ed-edit-toggle:hover { background: #1e293b; color: #fff; }
  body[data-edit="1"] .ed-edit-toggle { background: var(--tb-amber); color: #422006; border-color: var(--tb-amber); }
  body[data-edit="1"] .ed-edit-toggle:hover { background: #d97706; color: #422006; }

  /* Segmented view switcher — reads as one "pick one" control */
  .ed-seg {
    display: flex; gap: 4px;
    background: var(--tb-soft);
    border: 1px solid var(--tb-line);
    border-radius: 12px;
    padding: 4px;
  }
  .ed-seg .tpl-pill {
    flex: 1 1 0; min-width: 0;
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    border: 1px solid transparent;
    background: transparent;
    border-radius: 9px;
    padding: 9px 10px;
    font-size: 13.5px; font-weight: 600;
    color: var(--tb-mut);
    cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    -webkit-tap-highlight-color: transparent;
    transition: background .12s ease, color .12s ease, box-shadow .12s ease;
  }
  .ed-seg .tpl-pill:hover { color: var(--tb-ink); }
  .ed-seg .tpl-pill .emo { font-size: 15px; line-height: 1; flex: 0 0 auto; }
  .ed-seg .tpl-pill.active {
    background: var(--tb-bg);
    color: var(--tb-ink);
    font-weight: 700;
    box-shadow: 0 1px 2px rgba(15,23,42,0.12), 0 2px 8px rgba(15,23,42,0.08);
  }

  /* Edit-only management zone, split into labeled groups */
  .ed-edit-zone { display: none; }
  body[data-edit="1"] .ed-edit-zone {
    display: flex; flex-wrap: wrap; align-items: flex-end; gap: 10px 18px;
    padding-top: 12px;
    border-top: 1px dashed var(--tb-line);
  }
  .ed-group { display: flex; flex-direction: column; gap: 7px; }
  .ed-group--tiles { margin-left: auto; }
  .ed-glabel {
    font-size: 10px; font-weight: 700; letter-spacing: 0.7px;
    text-transform: uppercase; color: var(--tb-mut);
  }
  .ed-group-btns { display: flex; gap: 6px; }

  /* === STAGE === */
  .stage {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    padding: max(env(safe-area-inset-top), 24px) max(env(safe-area-inset-right), 6px) max(env(safe-area-inset-bottom), 6px) max(env(safe-area-inset-left), 6px);
    overflow: hidden;
    box-sizing: border-box;
  }

  /* === GRIDSTACK SHELL === */
  .grid-stack {
    background: transparent;
    height: 100% !important;
  }
  .grid-stack-item-content {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow);
    padding: 12px 14px 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    inset: 4px !important;
  }
  body[data-edit="1"] .grid-stack-item-content {
    border-color: #fbbf24;
    border-style: dashed;
    cursor: move;
  }
  body[data-edit="1"] .grid-stack-item-content > .tile-h,
  body[data-edit="1"] .grid-stack-item-content > .tile-body { pointer-events: none; }

  .tile-rm {
    display: none;
    position: absolute;
    top: 6px; right: 6px;
    width: 26px; height: 26px;
    border-radius: 999px;
    background: var(--accent-rose);
    color: var(--on-accent);
    border: none;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    z-index: 5;
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    -webkit-tap-highlight-color: transparent;
  }
  body[data-edit="1"] .tile-rm { display: block; }

  /* === SHARED TILE TYPOGRAPHY (matches /dashboard/ card-h) === */
  .tile-h {
    margin: 0 0 10px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-mid);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-shrink: 0;
  }
  .tile-h .sub {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-light);
    font-weight: 600;
  }
  .tile-h .pill {
    background: var(--surface-mute-3);
    color: var(--text-dark);
    font-size: 0.62rem;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .tile-h .h-action {
    background: var(--surface-mute-3);
    color: var(--text-dark);
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    cursor: pointer;
    border: none;
    text-transform: uppercase;
  }
  .tile-h .h-action:hover, .tile-h .h-action:active { background: rgba(0,0,0,0.08); }

  /* === MODAL (See all events) === */
  .modal-bg {
    display: none;
    position: fixed; inset: 0;
    background: rgba(15, 20, 28, 0.55);
    z-index: 350;
    align-items: flex-start;
    justify-content: center;
    padding-top: 24px;
  }
  .modal-bg.open { display: flex; }
  .modal-bg .modal {
    background: var(--card-bg);
    border-radius: 14px;
    width: min(560px, 92vw);
    max-height: 88vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
  }
  .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--border-soft);
  }
  .modal-head h2 { margin: 0; font-size: 1rem; color: var(--text-dark); }
  .modal-close {
    background: none; border: none;
    font-size: 1.1rem;
    cursor: pointer;
    color: var(--text-mid);
    padding: 4px 8px;
  }
  .modal-body { padding: 14px 18px; overflow: auto; }
  .cal-filter {
    width: 100%;
    box-sizing: border-box;
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.9rem;
    margin-bottom: 10px;
    background: var(--warm-bg);
    color: var(--text-dark);
  }
  .cal-month-h {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--accent-orange);
    font-weight: 700;
    margin: 14px 0 4px;
    padding-top: 6px;
    border-top: 1px solid var(--border-soft);
  }
  .tile-body {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    font-size: 0.85rem;
    color: var(--text-dark);
    display: flex;
    flex-direction: column;
  }

  /* === KIDS TILE === */
  .kids-grid {
    display: grid;
    grid-template-columns: 1fr auto auto;
    column-gap: 18px;
    row-gap: 9px;
    align-items: baseline;
  }
  .kids-grid .h {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-light);
    font-weight: 700;
  }
  .kids-grid .h.r { text-align: right; }
  .kids-grid .nm {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-dark);
  }
  .kids-grid .v {
    font-size: 1.05rem;
    font-weight: 700;
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--text-dark);
  }
  .kids-grid .v.danger { color: var(--accent-rose); }
  .kids-grid .v.warn   { color: var(--accent-gold); }

  /* === PER-KID TILE (one combined tile per kid: sugar/allowance/reading/today) === */
  .kidtile-body { overflow-y: auto; gap: 12px; }
  .kidtile-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .kidtile-stat { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .kidtile-stat .lbl {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-light);
    font-weight: 700;
  }
  .kidtile-stat .v {
    font-size: 1.15rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--text-dark);
  }
  .kidtile-stat .v.danger { color: var(--accent-rose); }
  .kidtile-stat .v.warn   { color: var(--accent-gold); }
  .kidtile-sec-lbl {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-light);
    font-weight: 700;
    margin-bottom: 6px;
  }

  /* === COUNTDOWNS (matches /dashboard/ .cd-item) === */
  .cd-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow: hidden;
  }
  .cd-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    background: var(--surface-mute);
    border-radius: 10px;
    min-height: 0;
  }
  .cd-item .n {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--accent-orange);
    font-variant-numeric: tabular-nums;
    min-width: 1.6em;
    text-align: right;
    flex-shrink: 0;
  }
  .cd-item .lbl {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1.2;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    word-break: break-word;
  }
  .cd-item .lbl .unit {
    color: var(--text-mid);
    font-weight: 500;
    font-size: 0.72rem;
    margin-right: 4px;
  }
  .cd-item.is-today .n { color: var(--accent-teal); font-size: 1.2rem; }

  /* === CALENDAR (matches /dashboard/ cal-row) === */
  .cal-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
    min-height: 0;
  }
  .cal-row {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 10px;
    align-items: baseline;
    padding: 6px 10px;
    border-radius: 7px;
    background: var(--surface-mute);
    font-size: 0.85rem;
    line-height: 1.25;
  }
  .cal-row.today-row { background: rgba(217,106,42,0.10); }
  .cal-row.today-row .t { color: var(--accent-orange); }
  .cal-bucket-h {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-dark);
    font-weight: 700;
    margin: 10px 0 2px;
    padding: 5px 0 2px;
    border-top: 1px solid var(--border-soft);
  }
  .cal-bucket-h:first-child { margin-top: 0; padding-top: 0; border-top: none; }
  .cal-bucket-h.today { color: var(--accent-orange); }
  .cal-bucket-h .cal-bucket-count {
    font-size: 0.58rem;
    font-weight: 600;
    color: var(--text-light);
    letter-spacing: 0.5px;
  }
  .cal-row .t {
    color: var(--text-light);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .cal-row .w { color: var(--text-dark); }

  /* === CHORES (matches /dashboard/ .chores) === */
  .chores-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 20px;
    row-gap: 4px;
    overflow: hidden;
    min-height: 0;
    flex: 1;
    align-content: start;
  }
  .chores-col {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .chores-col-h {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent-orange);
    line-height: 1;
    margin: 2px 0 10px;
    letter-spacing: -0.5px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    flex-shrink: 0;
  }
  .chores-groups {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    gap: 16px;
  }
  .chores-group { margin: 0; display: flex; flex-direction: column; flex: 0 0 auto; min-height: 0; }
  .chores-group-h {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-light);
    font-weight: 800;
    margin: 0 0 6px;
  }
  .chores-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .chore-item {
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.4;
    font-size: 0.78rem;
    color: var(--text-dark);
  }
  .chore-item input[type="checkbox"] {
    width: 16px; height: 16px;
    margin: 0; padding: 0;
    accent-color: var(--accent-teal);
    cursor: pointer;
    flex-shrink: 0;
  }
  .chore-label { flex: 1; min-width: 0; }
  .chore-item.all-done .chore-label {
    text-decoration: line-through;
    color: var(--text-light);
  }

  /* Monthly section visibility — driven by body[data-w-of-m] set in renderChoresPill() */
  .chores-monthly { display: none; }
  body[data-w-of-m="1"] .chores-monthly[data-n="1"],
  body[data-w-of-m="2"] .chores-monthly[data-n="2"],
  body[data-w-of-m="3"] .chores-monthly[data-n="3"],
  body[data-w-of-m="4"] .chores-monthly[data-n="4"],
  body[data-w-of-m="5"] .chores-monthly[data-n="4"] { display: flex; }

  /* === BUDGET (matches /dashboard/ .budget) === */
  .budget-cats {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    justify-content: space-around;
  }
  .budget-cat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .budget-cat .name {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-dark);
  }
  .budget-cat .name .status {
    font-size: 0.58rem;
    font-weight: 600;
    color: var(--text-mid);
    text-transform: none;
    letter-spacing: 0;
  }
  .budget-cat .name .status.over { color: var(--accent-rose); }
  .budget-bars {
    position: relative;
    height: 8px;
    background: var(--surface-mute-track);
    border-radius: 999px;
    overflow: hidden;
  }
  .budget-bars .actual {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    border-radius: 999px;
    transition: width 0.4s ease;
  }
  .budget-bars .actual.ok   { background: var(--accent-teal); }
  .budget-bars .actual.warn { background: var(--accent-gold); }
  .budget-bars .actual.over { background: var(--accent-rose); }
  .budget-bars .pace {
    position: absolute;
    top: -2px;
    width: 2px;
    height: 12px;
    background: var(--text-mid);
    border-radius: 1px;
    transform: translateX(-1px);
  }

  /* === WEATHER === */
  .weather-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 10px;
  }
  .weather-row .icon { font-size: 1.8rem; line-height: 1; }
  .weather-row .temp {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text-dark);
    font-variant-numeric: tabular-nums;
  }
  .weather-row .hilo {
    color: var(--text-light);
    font-size: 0.75rem;
    font-weight: 600;
  }
  .weather-days {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
    text-align: center;
  }
  .weather-days .d {
    color: var(--text-light);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .weather-days .ic { font-size: 1.15rem; line-height: 1.3; }
  .weather-days .hl {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: 0.72rem;
    color: var(--text-dark);
  }

  /* === SUNRISE / SUNSET BAR === */
  .sun-bar {
    position: relative;
    height: 16px;
    margin-top: 10px;
    border-radius: 8px;
    overflow: hidden;
    background: linear-gradient(90deg, #16233f 0%, #21386180 50%, #16233f 100%);
  }
  .sun-bar .sun-day {
    position: absolute;
    top: 0;
    bottom: 0;
    background: linear-gradient(90deg, #f6b04e 0%, #ffe08a 50%, #f49a3c 100%);
  }
  .sun-bar .sun-now {
    position: absolute;
    top: -2px;
    bottom: -2px;
    width: 2px;
    background: #fff;
    box-shadow: 0 0 2px rgba(0,0,0,0.85);
  }
  .sun-bar .sun-now::after {
    content: '';
    position: absolute;
    top: -3px;
    left: 50%;
    transform: translateX(-50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 2px rgba(0,0,0,0.85);
  }
  .sun-meta {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.4px;
    font-variant-numeric: tabular-nums;
  }

  /* === MEAL PLAN === */
  .meal-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.82rem;
    overflow: hidden;
  }
  .meal-list .row {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 8px;
    align-items: baseline;
    padding: 4px 0;
    border-bottom: 1px solid var(--border-soft);
  }
  .meal-list .row:last-child { border-bottom: none; }
  .meal-list .row.today .nm { color: var(--accent-orange); font-weight: 700; }
  .meal-list .dow {
    color: var(--text-light);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .meal-list .nm { color: var(--text-dark); }

  /* === SUMMER READING === */
  .reading-list { display: flex; flex-direction: column; gap: 10px; }
  .reading-row { cursor: pointer; -webkit-tap-highlight-color: transparent; }
  .reading-row.editing { cursor: default; }
  .reading-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.78rem;
    margin-bottom: 3px;
  }
  .reading-name { color: var(--text-dark); font-weight: 700; }
  .reading-count { color: var(--text-mid); font-variant-numeric: tabular-nums; }
  .reading-row.editing .reading-count { display: none; }
  .reading-editor {
    display: flex;
    gap: 6px;
    align-items: center;
    margin: 2px 0 4px;
  }
  .reading-editor[hidden] { display: none; }
  .reading-input {
    flex: 1 1 auto;
    min-width: 0;
    font-size: 0.9rem;
    padding: 4px 6px;
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--card-bg);
    color: var(--text-dark);
  }
  .reading-input::-webkit-outer-spin-button,
  .reading-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .reading-add, .reading-cancel, .reading-reset {
    border: 1px solid var(--border-soft);
    background: var(--card-bg);
    color: var(--text-dark);
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 0.78rem;
    cursor: pointer;
  }
  .reading-add { background: var(--accent-teal); color: white; border-color: transparent; font-weight: 700; }
  .reading-row .progress {
    height: 4px;
    background: var(--border-soft);
    border-radius: 2px;
    overflow: hidden;
  }
  .reading-row .progress .bar {
    height: 100%;
    background: var(--accent-orange);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  /* === TODAY'S ASSIGNMENTS === */
  .assn-list { display: flex; flex-direction: column; gap: 10px; }
  .assn-kid-h {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-mid);
    font-weight: 700;
    margin-bottom: 4px;
  }
  .assn-list .todo-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .assn-list .todo {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    user-select: none;
    font-size: 0.85rem;
    color: var(--text-dark);
  }
  .assn-list .todo input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--border-soft);
    border-radius: 4px;
    margin: 0;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
  }
  .assn-list .todo input[type="checkbox"]:checked {
    background: var(--accent-teal);
    border-color: var(--accent-teal);
  }
  .assn-list .todo input[type="checkbox"]:checked::after {
    content: "✓";
    position: absolute;
    inset: 0;
    color: white;
    font-size: 12px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .assn-list .todo input[type="checkbox"]:checked + .todo-label {
    text-decoration: line-through;
    color: var(--text-mid);
  }

  /* === RECIPE OF THE DAY === */
  .recipe-box {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .recipe-day {
    display: flex;
    flex-direction: column;
    padding-bottom: 8px;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--border-soft);
  }
  .recipe-day-next { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .recipe-day-today { border-bottom: none; margin-bottom: 6px; padding-bottom: 0; flex: 1 1 auto; min-height: 0; }
  .recipe-daylbl {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 2px;
  }
  .recipe-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.15;
    margin-bottom: 8px;
  }
  .recipe-meta {
    font-size: 0.75rem;
    color: var(--text-mid);
    margin-bottom: 10px;
  }
  .recipe-meta .pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--border-soft);
    margin-right: 6px;
    font-weight: 600;
  }
  .recipe-link {
    margin-top: auto;
    font-size: 0.82rem;
    color: var(--accent-teal);
    text-decoration: none;
    font-weight: 700;
  }
  .recipe-link:hover { text-decoration: underline; }
  .recipe-tomorrow {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding-top: 8px;
    border-top: 1px solid var(--border-soft);
    cursor: pointer;
    min-width: 0;
  }
  .recipe-tomorrow.no-recipe { cursor: default; }
  .rt-lbl {
    font-size: 0.55rem;
    font-weight: 700;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    flex-shrink: 0;
  }
  .rt-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-width: 0;
  }

  /* === JOKE OF THE DAY === */
  .joke-text {
    font-size: 1.05rem;
    line-height: 1.35;
    color: var(--text-dark);
    font-weight: 600;
  }

  /* === VERSE OF THE DAY === */
  .bible-text {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 0.98rem;
    line-height: 1.4;
    color: var(--text-dark);
  }
  .bible-ref {
    margin-top: 8px;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .bible-ver {
    color: var(--text-light);
    font-weight: 600;
  }

  /* === PLACEHOLDER === */
  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--text-light);
    font-style: italic;
    font-size: 0.85rem;
    flex: 1;
  }

  /* === ADD-TILE PICKER === */
  .picker-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(15, 20, 28, 0.55);
    z-index: 300;
    align-items: center;
    justify-content: center;
  }
  .picker-backdrop.show { display: flex; }
  .picker {
    background: var(--card-bg);
    border-radius: 14px;
    width: min(420px, 92vw);
    max-height: 80vh;
    overflow: auto;
    padding: 18px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
  }
  .picker h3 { margin: 0 0 14px; font-size: 1rem; color: var(--text-dark); }
  .picker .pick-list { display: flex; flex-direction: column; gap: 8px; }
  .picker .pick-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 14px;
    background: var(--warm-bg);
    border-radius: 10px;
    cursor: pointer;
    font-size: 0.92rem;
    color: var(--text-dark);
  }
  .picker .pick-item:hover { background: #ebe5d6; }
  .picker .pick-item .add {
    color: var(--text-mid);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.5px;
  }
  .picker .empty {
    color: var(--text-light);
    font-style: italic;
    font-size: 0.85rem;
    text-align: center;
    padding: 20px 0;
  }
  .picker .close {
    float: right;
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    color: var(--text-mid);
  }

  /* === TOAST === */
  .ed-toast {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--text-dark);
    color: var(--on-accent);
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.25s;
    pointer-events: none;
    z-index: 400;
  }
  .ed-toast.show { opacity: 1; }
</style>

<div class="ed-tap" id="edTap" title="Edit toolbar"></div>
<div class="ed-bar" id="edBar">
  <div class="ed-head">
    <span class="ed-cap">Dashboard view</span>
    <div class="ed-head-actions">
      <button id="tplAuto" class="ed-auto" title="Auto-switch by day: weekday → School Day, weekend → Weekend">Auto</button>
      <button id="edToggle" class="ed-edit-toggle">✏️ Edit</button>
    </div>
  </div>
  <div class="ed-seg" id="tplSwitch" role="tablist"></div>
  <div class="ed-edit-zone">
    <div class="ed-group">
      <span class="ed-glabel">This view</span>
      <div class="ed-group-btns">
        <button id="tplNew" title="Create a new view from the current layout">+ New</button>
        <button id="tplRename">Rename</button>
        <button id="tplDelete" class="danger">Delete</button>
      </div>
    </div>
    <div class="ed-group ed-group--tiles">
      <span class="ed-glabel">Layout</span>
      <div class="ed-group-btns">
        <button id="edAdd" disabled>+ Add tile</button>
        <button id="edReset" class="danger">Reset</button>
      </div>
    </div>
  </div>
</div>

<div class="stage">
  <div class="grid-stack" id="grid">
    <!-- Tiles injected by JS from the catalog below -->
  </div>
</div>

<!-- TILE CATALOG: defines every available tile (id + label + default size + HTML) -->
<script type="application/json" id="tileCatalog">
[
{% for kid in kids %}
  { "id": "kid-{{ kid.key }}", "label": "🧒 {{ kid.name }}", "w": 3, "h": 4 },
{% endfor %}
  { "id": "kids",       "label": "👨‍👩‍👦‍👦 Kids (sugar/allowance)", "w": 3, "h": 3 },
  { "id": "budget",     "label": "💳 Budget",                       "w": 3, "h": 2 },
  { "id": "countdowns", "label": "⏳ Countdowns",                   "w": 3, "h": 3 },
  { "id": "calendar",   "label": "📅 Upcoming events",              "w": 5, "h": 5 },
  { "id": "chores",     "label": "🧹 Weekend chores",               "w": 4, "h": 5 },
  { "id": "weather",    "label": "☀️ Weather",                      "w": 3, "h": 3 },
  { "id": "meals",       "label": "🍽️ Meal plan",                    "w": 3, "h": 3 },
  { "id": "reading",     "label": "📚 Summer reading",               "w": 3, "h": 3 },
  { "id": "assignments", "label": "✏️ Today's assignments",          "w": 3, "h": 3 },
  { "id": "recipe",      "label": "🍲 What's cooking (today + tomorrow)", "w": 3, "h": 3 },
  { "id": "joke",        "label": "😂 Joke of the day",              "w": 3, "h": 2 },
  { "id": "bible",       "label": "✝️ Verse of the day",             "w": 3, "h": 2 },
  { "id": "newish",      "label": "✨ Blank placeholder",            "w": 9, "h": 3 }
]
</script>

<!-- Default layout if no saved state -->
<script type="application/json" id="defaultLayout">
[
  { "id": "calendar",    "x": 3, "y": 0, "w": 5, "h": 5 },
  { "id": "chores",      "x": 8, "y": 0, "w": 4, "h": 5 },
  { "id": "budget",      "x": 0, "y": 0, "w": 3, "h": 2 },
  { "id": "countdowns",  "x": 0, "y": 2, "w": 3, "h": 3 },
  { "id": "recipe",      "x": 0, "y": 9, "w": 3, "h": 3 },
  { "id": "joke",        "x": 3, "y": 9, "w": 5, "h": 3 },
  { "id": "bible",       "x": 8, "y": 9, "w": 4, "h": 3 },
{% for kid in kids %}
  { "id": "kid-{{ kid.key }}", "x": {{ loop.index0 * 3 }}, "y": 5, "w": 3, "h": 4 }{{ "," if not loop.last }}
{% endfor %}
]
</script>

<!-- HIDDEN TILE TEMPLATES — server-rendered content cloned into the grid on demand -->
<div id="tileTemplates" style="display:none">

  <div data-tpl="kids">
    <div class="tile-h"><span>👨‍👩‍👦‍👦 Kids</span><span class="sub">Sugar · Allowance</span></div>
    <div class="tile-body">
      <div class="kids-grid">
        {% for kid in kids %}
          <div class="nm">{{ kid.name }}</div>
          {% if kid.sugar.balance is not none %}
            {% set neg = kid.sugar.balance < 0 %}
            {% set low = kid.sugar.balance >= 0 and kid.sugar.balance < kid.sugar.refill * 0.5 %}
            <div class="v{% if neg %} danger{% elif low %} warn{% endif %}">{{ kid.sugar.balance }}g</div>
          {% else %}
            <div class="v">—</div>
          {% endif %}
          {% if kid.allowance.balance_str %}
            {% set negA = '-' in kid.allowance.balance_str %}
            <div class="v{% if negA %} danger{% endif %}">{{ kid.allowance.balance_str }}</div>
          {% else %}
            <div class="v">—</div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

{% for kid in kids %}
  <div data-tpl="kid-{{ kid.key }}">
    <div class="tile-h"><span>{{ kid.name }}</span><span class="sub">{{ kid.grade }}</span></div>
    <div class="tile-body kidtile-body">
      <div class="kidtile-stats">
        <div class="kidtile-stat">
          <span class="lbl">🍭 Sugar</span>
          {% if kid.sugar.balance is not none %}
            {% set neg = kid.sugar.balance < 0 %}
            {% set low = kid.sugar.balance >= 0 and kid.sugar.balance < kid.sugar.refill * 0.5 %}
            <span class="v{% if neg %} danger{% elif low %} warn{% endif %}">{{ kid.sugar.balance }}g</span>
          {% else %}
            <span class="v">—</span>
          {% endif %}
        </div>
        <div class="kidtile-stat">
          <span class="lbl">💵 Allowance</span>
          {% if kid.allowance.balance_str %}
            {% set negA = '-' in kid.allowance.balance_str %}
            <span class="v{% if negA %} danger{% endif %}">{{ kid.allowance.balance_str }}</span>
          {% else %}
            <span class="v">—</span>
          {% endif %}
        </div>
      </div>

      {% if kid.reading %}
      <div>
        <div class="kidtile-sec-lbl">📚 Summer reading</div>
        <div class="reading-row" data-kid="{{ kid.key }}" data-base="{{ kid.reading.pages }}" data-target="{{ kid.reading.target }}">
          <div class="reading-head">
            <span class="reading-count"><span class="reading-pages">{{ kid.reading.pages }}</span> / {{ kid.reading.target }} pgs</span>
          </div>
          <div class="reading-editor" hidden>
            <input type="number" inputmode="numeric" pattern="[0-9]*" min="0" max="9999" step="1" class="reading-input" placeholder="total pages">
            <button type="button" class="reading-add">Save</button>
            <button type="button" class="reading-reset" title="Reset to 0">↺</button>
            <button type="button" class="reading-cancel">✕</button>
          </div>
          <div class="progress"><div class="bar reading-bar" style="width: {{ kid.reading.pct }}%"></div></div>
        </div>
      </div>
      {% endif %}

      <div>
        <div class="kidtile-sec-lbl">✏️ Today</div>
        <div class="assn-list">
          {% if kid.assignments and kid.assignments.length %}
            <ul class="todo-list" data-kid="{{ kid.key }}">
              {% for a in kid.assignments %}
              <li>
                <label class="todo">
                  <input type="checkbox" data-kid="{{ kid.key }}" data-id="{{ a.id }}">
                  <span class="todo-label">{{ a.label }}</span>
                </label>
              </li>
              {% endfor %}
            </ul>
          {% else %}
            <div class="placeholder">Nothing today 🎉</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endfor %}

  <div data-tpl="budget">
    <div class="tile-h"><span>💳 Budget</span><span class="sub" id="budgetMonth">—</span></div>
    <div class="tile-body">
      <div class="budget-cats">
        <div class="budget-cat" data-cat="shopping" data-pct="42">
          <div class="name"><span>Shopping</span><span class="status" id="status-shopping"></span></div>
          <div class="budget-bars">
            <div class="actual" id="bar-shopping"></div>
            <div class="pace" id="pace-shopping"></div>
          </div>
        </div>
        <div class="budget-cat" data-cat="food" data-pct="68">
          <div class="name"><span>Food</span><span class="status" id="status-food"></span></div>
          <div class="budget-bars">
            <div class="actual" id="bar-food"></div>
            <div class="pace" id="pace-food"></div>
          </div>
        </div>
        <div class="budget-cat" data-cat="ent" data-pct="89">
          <div class="name"><span>Entertainment</span><span class="status" id="status-ent"></span></div>
          <div class="budget-bars">
            <div class="actual" id="bar-ent"></div>
            <div class="pace" id="pace-ent"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div data-tpl="countdowns">
    <div class="tile-h"><span>⏳ Countdowns</span></div>
    <div class="tile-body">
      <div class="cd-list" id="cdList"></div>
    </div>
  </div>

  <div data-tpl="calendar">
    <div class="tile-h"><span>📅 Upcoming</span><button class="h-action" id="calExpand">See all</button></div>
    <div class="tile-body">
      <div class="cal-list" id="calList"></div>
    </div>
  </div>

  <div data-tpl="chores">
    <div class="tile-h"><span>🧹 Weekend chores</span><span class="pill" id="choresWkPill">—</span></div>
    <div class="tile-body">
      <div class="chores-body">
        <div class="chores-col">
          <div class="chores-col-h">Saturday</div>
          <div class="chores-groups">
            <div class="chores-group">
              <div class="chores-group-h">{{ chores.quick.title }}</div>
              <ul class="chores-list">
                {% for item in chores.quick.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% for m in chores.monthly %}
            <div class="chores-monthly chores-group" data-n="{{ m.n }}">
              <div class="chores-group-h">{{ m.sat.title }}</div>
              <ul class="chores-list">
                {% for item in m.sat.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% endfor %}
          </div>
        </div>
        <div class="chores-col">
          <div class="chores-col-h">Sunday</div>
          <div class="chores-groups">
            <div class="chores-group">
              <div class="chores-group-h">{{ chores.laundry.title }}</div>
              <ul class="chores-list">
                {% for item in chores.laundry.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% for m in chores.monthly %}
            <div class="chores-monthly chores-group" data-n="{{ m.n }}">
              <div class="chores-group-h">{{ m.sun.title }}</div>
              <ul class="chores-list">
                {% for item in m.sun.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div data-tpl="weather">
    <div class="tile-h"><span>☀️ Weather</span><span class="sub">Greenville</span></div>
    <div class="tile-body">
      {% if weather %}
      <div class="weather-row">
        <span class="icon">{{ weather.now.icon }}</span>
        <span class="temp">{{ weather.now.temp }}°</span>
        <span class="hilo">H {{ weather.now.hi }} / L {{ weather.now.lo }}</span>
      </div>
      <div class="weather-days">
        {% for d in weather.days %}
          <div>
            <div class="d">{{ d.d }}</div>
            <div class="ic">{{ d.icon }}</div>
            <div class="hl">{{ d.hi }}/{{ d.lo }}</div>
          </div>
        {% endfor %}
      </div>
      {% if weather.sun and weather.sun.sunrises and weather.sun.sunrises.length %}
      <div class="sun-bar" id="sunBar"
           data-sunrise="{{ weather.sun.sunrises[0] }}"
           data-sunset="{{ weather.sun.sunsets[0] }}"></div>
      {% endif %}
      {% else %}
      <div class="placeholder">Weather unavailable</div>
      {% endif %}
    </div>
  </div>

  <div data-tpl="meals">
    <div class="tile-h"><span>🍽️ Meal plan</span><span class="sub">This week</span></div>
    <div class="tile-body">
      <div class="meal-list">
        {% for m in mealweek %}
          <div class="row{% if m.isToday %} today{% endif %}">
            <span class="dow">{{ m.dow_short }}</span>
            <span class="nm">{{ m.name }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div data-tpl="reading">
    <div class="tile-h"><span>📚 Summer reading</span></div>
    <div class="tile-body">
      <div class="reading-list">
        {% for kid in kids %}
          {% if kid.reading %}
            <div class="reading-row" data-kid="{{ kid.key }}" data-base="{{ kid.reading.pages }}" data-target="{{ kid.reading.target }}">
              <div class="reading-head">
                <span class="reading-name">{{ kid.name }}</span>
                <span class="reading-count"><span class="reading-pages">{{ kid.reading.pages }}</span> / {{ kid.reading.target }} pgs</span>
              </div>
              <div class="reading-editor" hidden>
                <input type="number" inputmode="numeric" pattern="[0-9]*" min="0" max="9999" step="1" class="reading-input" placeholder="total pages">
                <button type="button" class="reading-add">Save</button>
                <button type="button" class="reading-reset" title="Reset to 0">↺</button>
                <button type="button" class="reading-cancel">✕</button>
              </div>
              <div class="progress"><div class="bar reading-bar" style="width: {{ kid.reading.pct }}%"></div></div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div data-tpl="assignments">
    <div class="tile-h"><span>✏️ Today's assignments</span></div>
    <div class="tile-body">
      <div class="assn-list">
        {% set anyAssn = false %}
        {% for kid in kids %}
          {% if kid.assignments and kid.assignments.length %}
            {% set anyAssn = true %}
            <div class="assn-kid">
              <div class="assn-kid-h">{{ kid.name }}</div>
              <ul class="todo-list" data-kid="{{ kid.key }}">
                {% for a in kid.assignments %}
                  <li>
                    <label class="todo">
                      <input type="checkbox" data-kid="{{ kid.key }}" data-id="{{ a.id }}">
                      <span class="todo-label">{{ a.label }}</span>
                    </label>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        {% endfor %}
        {% if not anyAssn %}
          <div class="placeholder">Nothing assigned today. Go outside.</div>
        {% endif %}
      </div>
    </div>
  </div>

  <div data-tpl="recipe">
    {% set rToday = null %}{% set rTomorrow = null %}
    {% for m in mealweek %}
      {% if m.isToday %}{% set rToday = m %}{% endif %}
      {% if m.isTomorrow %}{% set rTomorrow = m %}{% endif %}
    {% endfor %}
    <div class="tile-h"><span>🍲 What's cooking</span></div>
    <div class="tile-body">
      <div class="recipe-day recipe-day-today">
        <div class="recipe-daylbl">Today</div>
        <div class="recipe-name">{{ rToday.name or 'TBD' }}</div>
        {% if rToday.recipe %}
          <div class="recipe-meta">
            {% if rToday.recipe.effort %}<span class="pill">{{ rToday.recipe.effort }}</span>{% endif %}
            {% if rToday.recipe.protein_g %}{{ rToday.recipe.protein_g }}g protein{% endif %}
          </div>
          <a class="recipe-link" href="/recipes/{{ rToday.recipe.slug }}/" target="_blank" rel="noopener">Open recipe →</a>
        {% endif %}
      </div>
      <div class="recipe-tomorrow{% if not rTomorrow.recipe %} no-recipe{% endif %}"
           {% if rTomorrow.recipe %}data-recipe-href="/recipes/{{ rTomorrow.recipe.slug }}/"{% endif %}>
        <span class="rt-lbl">Tomorrow</span>
        <span class="rt-name">{{ rTomorrow.name or 'TBD' }}</span>
      </div>
    </div>
  </div>

  <div data-tpl="joke">
    <div class="tile-h"><span>😂 Joke of the day</span></div>
    <div class="tile-body">
      {% if joke and joke.joke %}
        <div class="joke-text">{{ joke.joke }}</div>
      {% else %}
        <div class="placeholder">No joke today 🤷</div>
      {% endif %}
    </div>
  </div>

  <div data-tpl="bible">
    <div class="tile-h"><span>✝️ Verse of the day</span></div>
    <div class="tile-body">
      {% if bible and bible.text %}
        <div class="bible-text">“{{ bible.text }}”</div>
        <div class="bible-ref">— {{ bible.reference }}{% if bible.version %} <span class="bible-ver">{{ bible.version }}</span>{% endif %}</div>
      {% else %}
        <div class="placeholder">Verse unavailable</div>
      {% endif %}
    </div>
  </div>

  <div data-tpl="newish">
    <div class="tile-h"><span>✨ New block</span></div>
    <div class="placeholder">Drop something here — dinner, weekend goal, sports, read-aloud</div>
  </div>

</div>

<!-- Cal "see all" modal -->
<div class="modal-bg" id="calModal">
  <div class="modal">
    <div class="modal-head">
      <h2>📅 All upcoming events</h2>
      <button class="modal-close" id="calModalClose">✕</button>
    </div>
    <div class="modal-body">
      <input type="text" class="cal-filter" id="calFilter" placeholder="Filter events..." autocomplete="off" />
      <div id="calFullList"></div>
    </div>
  </div>
</div>

<!-- Add-tile picker modal -->
<div class="picker-backdrop" id="picker">
  <div class="picker">
    <button class="close" id="pickerClose">✕</button>
    <h3>Add a tile</h3>
    <div class="pick-list" id="pickerList"></div>
  </div>
</div>

<div class="ed-toast" id="edToast">Saved</div>

<script>
(function(){
  const STORAGE_KEY = 'crittercrew.dashedit.layout.v1';

  const CATALOG = JSON.parse(document.getElementById('tileCatalog').textContent);
  const CATALOG_BY_ID = Object.fromEntries(CATALOG.map(c => [c.id, c]));
  const DEFAULT_LAYOUT = JSON.parse(document.getElementById('defaultLayout').textContent);

  const TEMPLATES = {};
  document.querySelectorAll('#tileTemplates [data-tpl]').forEach(el => {
    TEMPLATES[el.dataset.tpl] = el.innerHTML;
  });

  // Compute cell height to fit viewport
  const stage = document.querySelector('.stage');
  const stageH = stage.clientHeight - 12;
  const cellH = Math.floor(stageH / 8);

  const grid = GridStack.init({
    column: 12,
    cellHeight: cellH,
    margin: 4,
    float: false,
    disableDrag: true,
    disableResize: true,
    handle: '.grid-stack-item-content',
    acceptWidgets: false,
  }, '#grid');

  function tileHTML(id) {
    const body = TEMPLATES[id] || '<div class="placeholder">Missing template: ' + id + '</div>';
    // GridStack wraps `content` in its own .grid-stack-item-content — do NOT add another, or you get a double border.
    return '<button class="tile-rm" data-rm="' + id + '" title="Remove">✕</button>' + body;
  }

  function addTile(spec) {
    const catalog = CATALOG_BY_ID[spec.id];
    if (!catalog) return;
    grid.addWidget({
      id: spec.id,
      x: spec.x, y: spec.y,
      w: spec.w || catalog.w,
      h: spec.h || catalog.h,
      content: tileHTML(spec.id),
    });
    hydrateTile(spec.id);
  }

  // === LIVE DATA HYDRATION (runs after each tile is added) ===
  function hydrateTile(id) {
    if (id === 'countdowns')   renderCountdowns();
    if (id === 'budget')       renderBudget();
    if (id === 'chores')       renderChoresPill();
    if (id === 'calendar')     renderCalendar();
    if (id === 'reading')      hydrateReading();
    if (id === 'assignments')  hydrateAssignments();
    if (id === 'recipe')       renderRecipeOfDay();
    if (id === 'weather')      renderSunBar();
    if (id.indexOf('kid-') === 0) { hydrateReading(); hydrateAssignments(); }
  }

  // === CALENDAR (mirrors /dashboard/: filter past → bucket by today/tomorrow/this week/etc → render) ===
  const EVENTS = {{ calendar | dump | safe }};
  const _td = new Date();
  const _todayStr = _td.getFullYear() + '-' + String(_td.getMonth()+1).padStart(2,'0') + '-' + String(_td.getDate()).padStart(2,'0');
  const _DOW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const _BUCKET_LABELS = { today:'Today', tomorrow:'Tomorrow', thisweek:'This week', nextweek:'Next week', later:'Later' };
  const _BUCKET_ORDER = ['today','tomorrow','thisweek','nextweek','later'];
  function _bucketFor(ev) {
    const d = new Date(ev.date + 'T00:00:00');
    const diff = Math.round((d - new Date(_todayStr + 'T00:00')) / 86400000);
    if (diff <= 0) return 'today';
    if (diff === 1) return 'tomorrow';
    if (diff < 7) return 'thisweek';
    if (diff < 14) return 'nextweek';
    return 'later';
  }
  function _notPast(ev) {
    if (ev.date > _todayStr) return true;
    if (ev.date < _todayStr) return false;
    if (ev.all_day) return true;
    if (ev.end) { const e = Date.parse(ev.end); if (!isNaN(e) && e < Date.now()) return false; }
    return true;
  }
  function _fmtWhen(ev) {
    const d = new Date(ev.date + 'T00:00');
    const diff = Math.round((d - new Date(_todayStr + 'T00:00')) / 86400000);
    const time = ev.all_day ? 'all day' : (ev.time || '');
    if (diff === 0 || diff === 1) return time;
    if (diff >= 2 && diff < 14) return _DOW[d.getDay()] + (ev.all_day ? '' : ' ' + ev.time);
    const mo = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()];
    return mo + ' ' + d.getDate() + (ev.all_day ? '' : ' ' + ev.time);
  }
  function renderCalendar() {
    const wrap = document.getElementById('calList');
    if (!wrap) return;
    const upcoming = EVENTS.filter(_notPast).slice(0, 14);
    const groups = {};
    upcoming.forEach(ev => { const k = _bucketFor(ev); (groups[k] = groups[k] || []).push(ev); });
    const html = _BUCKET_ORDER.filter(k => groups[k] && groups[k].length).map(k => {
      const isToday = k === 'today';
      const head = '<div class="cal-bucket-h' + (isToday ? ' today' : '') + '">' +
        '<span>' + _BUCKET_LABELS[k] + '</span>' +
        '<span class="cal-bucket-count">' + groups[k].length + '</span>' +
        '</div>';
      const rows = groups[k].map(ev => {
        const isT = ev.date === _todayStr;
        return '<div class="cal-row' + (isT ? ' today-row' : '') + '">' +
          '<span class="t">' + _fmtWhen(ev) + '</span>' +
          '<span class="w">' + ev.what + '</span>' +
          '</div>';
      }).join('');
      return head + rows;
    }).join('');
    wrap.innerHTML = html || '<div class="empty">No upcoming events.</div>';
    _wireCalExpand();
  }

  // Full "See all" modal with text filter
  function _renderCalFull(filter) {
    const f = (filter || '').trim().toLowerCase();
    const list = EVENTS.filter(_notPast).filter(e => !f || (e.what || '').toLowerCase().includes(f));
    const wrap = document.getElementById('calFullList');
    if (!wrap) return;
    if (!list.length) {
      wrap.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text-mid)">No matching events.</div>';
      return;
    }
    const near = list.filter(ev => _bucketFor(ev) !== 'later');
    const later = list.filter(ev => _bucketFor(ev) === 'later');
    function _rowHTML(ev) {
      const isT = ev.date === _todayStr;
      return '<div class="cal-row' + (isT ? ' today-row' : '') + '">' +
        '<span class="t">' + _fmtWhen(ev) + '</span>' +
        '<span class="w">' + ev.what + '</span>' +
        '</div>';
    }
    let html = '';
    if (near.length) {
      const groups = {};
      near.forEach(ev => { const k = _bucketFor(ev); (groups[k] = groups[k] || []).push(ev); });
      _BUCKET_ORDER.filter(k => groups[k] && groups[k].length).forEach(k => {
        const isToday = k === 'today';
        html += '<div class="cal-bucket-h' + (isToday ? ' today' : '') + '">' +
          '<span>' + _BUCKET_LABELS[k] + '</span>' +
          '<span class="cal-bucket-count">' + groups[k].length + '</span>' +
          '</div>';
        html += groups[k].map(_rowHTML).join('');
      });
    }
    if (later.length) {
      const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      let cur = '';
      later.forEach(ev => {
        const d = new Date(ev.date + 'T00:00:00');
        const mk = months[d.getMonth()] + ' ' + d.getFullYear();
        if (mk !== cur) { html += '<div class="cal-month-h">' + mk + '</div>'; cur = mk; }
        html += _rowHTML(ev);
      });
    }
    wrap.innerHTML = html;
  }
  let _calBound = false;
  function _wireCalExpand() {
    if (_calBound) return;
    const btn = document.getElementById('calExpand');
    const modal = document.getElementById('calModal');
    const closeBtn = document.getElementById('calModalClose');
    const filter = document.getElementById('calFilter');
    if (!btn || !modal) return;
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      modal.classList.add('open');
      filter.value = '';
      _renderCalFull('');
      setTimeout(() => filter.focus(), 50);
    });
    closeBtn.addEventListener('click', () => modal.classList.remove('open'));
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('open'); });
    filter.addEventListener('input', (e) => _renderCalFull(e.target.value));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') modal.classList.remove('open');
    });
    _calBound = true;
  }

  // Countdowns: same source-of-truth as /dashboard/, computed live
  const COUNTDOWNS = [
    { label: "Mike's birthday",     date: '2026-06-13' },
    { label: 'California',          date: '2026-06-18' },
    { label: 'Dude Perfect',        date: '2026-06-26' },
    { label: '4th of July',         date: '2026-07-04' },
    { label: 'lake trip',           date: '2026-07-06' },
    { label: 'school',              date: '2026-08-13' },
  ];
  function renderCountdowns() {
    const wrap = document.getElementById('cdList');
    if (!wrap) return;
    const today = new Date();
    const todayMid = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    const items = COUNTDOWNS
      .map(c => {
        const [y, m, d] = c.date.split('-').map(Number);
        const target = new Date(y, m - 1, d);
        const days = Math.round((target - todayMid) / 86400000);
        return { ...c, days };
      })
      .filter(c => c.days >= 0)
      .sort((a, b) => a.days - b.days);
    wrap.innerHTML = items.map(c => {
      const isToday = c.days === 0;
      const nTxt = isToday ? '🎉' : c.days;
      const unit = isToday ? '' : '<span class="unit">' + (c.days === 1 ? 'day to' : 'days to') + '</span>';
      const lbl = isToday ? c.label + ' is today!' : unit + c.label;
      return '<div class="cd-item' + (isToday ? ' is-today' : '') + '">' +
               '<span class="n">' + nTxt + '</span>' +
               '<span class="lbl">' + lbl + '</span>' +
             '</div>';
    }).join('');
  }

  // Budget: same hardcoded pcts + same pace logic as /dashboard/
  function renderBudget() {
    const now = new Date();
    const dayOfMonth = now.getDate();
    const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
    const monthPct = Math.round((dayOfMonth / daysInMonth) * 100);
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const monthEl = document.getElementById('budgetMonth');
    if (monthEl) monthEl.textContent = months[now.getMonth()] + ' · day ' + dayOfMonth + '/' + daysInMonth;

    document.querySelectorAll('.budget-cat').forEach(cat => {
      const key = cat.dataset.cat;
      const pct = parseInt(cat.dataset.pct, 10);
      const bar = document.getElementById('bar-' + key);
      const pace = document.getElementById('pace-' + key);
      const status = document.getElementById('status-' + key);
      if (!bar || !pace || !status) return;

      bar.style.width = Math.min(pct, 100) + '%';
      pace.style.left = Math.min(monthPct, 100) + '%';

      if (pct >= 100) {
        bar.className = 'actual over';
        status.textContent = 'over';
        status.className = 'status over';
      } else if (pct > monthPct + 8) {
        bar.className = 'actual warn';
        status.textContent = 'pacing high';
        status.className = 'status';
      } else {
        bar.className = 'actual ok';
        status.textContent = 'on pace';
        status.className = 'status';
      }
    });
  }

  function renderChoresPill() {
    const pill = document.getElementById('choresWkPill');
    const now = new Date();
    const dow = now.getDay();
    const sat = new Date(now);
    if (dow === 0) sat.setDate(now.getDate() - 1);
    else if (dow !== 6) sat.setDate(now.getDate() + (6 - dow));
    const w = Math.min(4, Math.ceil(sat.getDate() / 7));
    document.body.dataset.wOfM = String(w);
    if (pill) {
      const labels = { 1: '1st weekend', 2: '2nd weekend', 3: '3rd weekend', 4: '4th weekend' };
      pill.textContent = labels[w] || ('Wk ' + w);
    }
    // Persist chore checks per weekend (Sat date as key)
    const yyyy = sat.getFullYear();
    const mm = String(sat.getMonth() + 1).padStart(2, '0');
    const dd = String(sat.getDate()).padStart(2, '0');
    const CHORE_KEY = 'chores-' + yyyy + '-' + mm + '-' + dd;
    let state = {};
    try { state = JSON.parse(localStorage.getItem(CHORE_KEY) || '{}'); } catch {}
    // GC old chore-* keys (keep only current weekend)
    try {
      for (let i = localStorage.length - 1; i >= 0; i--) {
        const k = localStorage.key(i);
        if (k && k.startsWith('chores-') && k !== CHORE_KEY) localStorage.removeItem(k);
      }
    } catch {}
    function updateRowStrike(item) {
      const boxes = item.querySelectorAll('input[type="checkbox"]');
      const allDone = Array.from(boxes).every(b => b.checked);
      item.classList.toggle('all-done', allDone);
    }
    document.querySelectorAll('.chore-item').forEach(item => {
      const id = item.dataset.id;
      if (!id) return;
      item.querySelectorAll('input[type="checkbox"]').forEach(box => {
        const slot = box.dataset.slot || '0';
        const key = id + ':' + slot;
        if (state[key]) box.checked = true;
        if (box.dataset._wired) return;
        box.dataset._wired = '1';
        box.addEventListener('change', () => {
          if (box.checked) state[key] = true;
          else delete state[key];
          localStorage.setItem(CHORE_KEY, JSON.stringify(state));
          updateRowStrike(item);
        });
      });
      updateRowStrike(item);
    });
  }

  // === SUMMER READING (tap-to-add pages; persists locally) ===
  function hydrateReading() {
    const STORAGE_KEY = 'reading-local-adds';
    let store = {};
    try { store = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}
    function save() { localStorage.setItem(STORAGE_KEY, JSON.stringify(store)); }

    document.querySelectorAll('.reading-row').forEach(row => {
      if (row.dataset._wired) return;
      row.dataset._wired = '1';
      const kid = row.dataset.kid;
      const base = parseInt(row.dataset.base, 10) || 0;
      const target = parseInt(row.dataset.target, 10) || 0;
      const pagesEl = row.querySelector('.reading-pages');
      const barEl = row.querySelector('.reading-bar');
      const editor = row.querySelector('.reading-editor');
      const input = row.querySelector('.reading-input');
      const addBtn = row.querySelector('.reading-add');
      const cancelBtn = row.querySelector('.reading-cancel');
      const resetBtn = row.querySelector('.reading-reset');

      // Drop stale local override once the server total catches up.
      if (store[kid] != null && store[kid] <= base) { delete store[kid]; save(); }

      function currentPages() { return store[kid] != null ? store[kid] : base; }
      function render() {
        const p = currentPages();
        pagesEl.textContent = p;
        const pct = target > 0 ? Math.min(100, Math.round((p / target) * 100)) : 0;
        barEl.style.width = pct + '%';
      }
      function openEditor() {
        row.classList.add('editing');
        editor.hidden = false;
        input.value = currentPages();
        setTimeout(() => { input.focus(); input.select(); }, 0);
      }
      function closeEditor() {
        row.classList.remove('editing');
        editor.hidden = true;
      }
      row.addEventListener('click', (e) => {
        if (row.classList.contains('editing')) return;
        if (e.target.closest('.reading-editor')) return;
        openEditor();
      });
      addBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const n = parseInt(input.value, 10);
        if (!isNaN(n) && n >= 0) {
          // Input is the TOTAL pages read so far. Keep a local override only
          // when it's ahead of the server; otherwise follow the server value.
          if (n > base) store[kid] = n; else delete store[kid];
          save(); render();
        }
        closeEditor();
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); addBtn.click(); }
        if (e.key === 'Escape') { e.preventDefault(); closeEditor(); }
      });
      cancelBtn.addEventListener('click', (e) => { e.stopPropagation(); closeEditor(); });
      resetBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!confirm('Reset ' + kid + ' to ' + base + ' pgs?')) return;
        delete store[kid]; save(); render(); closeEditor();
      });
      render();
    });
  }

  // === TODAY'S ASSIGNMENTS (per-day localStorage, ET) ===
  function hydrateAssignments() {
    function todayKey() {
      const parts = new Intl.DateTimeFormat('en-CA', {
        timeZone: 'America/New_York',
        year: 'numeric', month: '2-digit', day: '2-digit',
      }).formatToParts(new Date());
      const map = {};
      parts.forEach(p => map[p.type] = p.value);
      return map.year + '-' + map.month + '-' + map.day;
    }
    const date = todayKey();
    const STORAGE_KEY = 'kid-todos';
    let state = {};
    try { state = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}
    if (state.date !== date) state = { date, checks: {} };

    document.querySelectorAll('.assn-list .todo input[type="checkbox"]').forEach(box => {
      if (box.dataset._wired) return;
      box.dataset._wired = '1';
      const key = box.dataset.kid + '|' + box.dataset.id;
      if (state.checks[key]) box.checked = true;
      box.addEventListener('change', () => {
        if (box.checked) state.checks[key] = true;
        else delete state.checks[key];
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      });
    });
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  // === RECIPE OF THE DAY (deterministic daily pick from rotation) ===
  const RECIPES = {{ recipes | dump | safe }};
  function renderRecipeOfDay() {
    const nameEl = document.getElementById('recipeName');
    const metaEl = document.getElementById('recipeMeta');
    const dateEl = document.getElementById('recipeDate');
    const linkEl = document.getElementById('recipeLink');
    if (!nameEl) return;
    const rotation = (RECIPES || []).filter(r => r.in_rotation);
    if (!rotation.length) {
      nameEl.textContent = 'No rotation recipes yet';
      metaEl.textContent = '';
      linkEl.style.display = 'none';
      return;
    }
    // Deterministic pick: epoch-day index mod rotation length (so it changes daily, same all day)
    const today = new Date();
    const epochDay = Math.floor(Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()) / 86400000);
    const pick = rotation[epochDay % rotation.length];
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    if (dateEl) dateEl.textContent = months[today.getMonth()] + ' ' + today.getDate();
    nameEl.textContent = pick.name;
    const bits = [];
    if (pick.effort) bits.push('<span class="pill">' + pick.effort + '</span>');
    if (pick.prep_min || pick.cook_min) {
      const total = (pick.prep_min || 0) + (pick.cook_min || 0);
      if (total > 0) bits.push(total + ' min');
    }
    if (pick.protein_g) bits.push(pick.protein_g + 'g protein');
    metaEl.innerHTML = bits.join(' · ');
    if (pick.hasFullRecipe) {
      linkEl.href = '/recipes/' + pick.slug + '/';
      linkEl.style.display = '';
    } else {
      linkEl.style.display = 'none';
    }
  }

  // === SUNRISE / SUNSET BAR (24h light/dark with a live "now" marker) ===
  let _sunNowTimer = null;
  function _fracFromISO(iso) {
    // iso is local-naive ("YYYY-MM-DDTHH:mm") in America/New_York; the kiosk
    // runs in ET so parsing as local time is correct.
    const m = /T(\d{2}):(\d{2})/.exec(iso || '');
    if (!m) return null;
    return (parseInt(m[1], 10) + parseInt(m[2], 10) / 60) / 24;
  }
  function _fmtClock(iso) {
    const m = /T(\d{2}):(\d{2})/.exec(iso || '');
    if (!m) return '';
    let h = parseInt(m[1], 10);
    const min = m[2];
    const ap = h >= 12 ? 'p' : 'a';
    h = h % 12; if (h === 0) h = 12;
    return h + ':' + min + ap;
  }
  function renderSunBar() {
    const bar = document.getElementById('sunBar');
    if (!bar) return;
    const sr = _fracFromISO(bar.dataset.sunrise);
    const ss = _fracFromISO(bar.dataset.sunset);
    if (sr == null || ss == null) { bar.style.display = 'none'; return; }
    if (!bar.dataset._built) {
      bar.dataset._built = '1';
      const day = document.createElement('div');
      day.className = 'sun-day';
      day.style.left = (sr * 100) + '%';
      day.style.width = ((ss - sr) * 100) + '%';
      const now = document.createElement('div');
      now.className = 'sun-now';
      bar.appendChild(day);
      bar.appendChild(now);
      const meta = document.createElement('div');
      meta.className = 'sun-meta';
      meta.innerHTML = '<span>↑ ' + _fmtClock(bar.dataset.sunrise) + '</span>' +
                       '<span>↓ ' + _fmtClock(bar.dataset.sunset) + '</span>';
      bar.insertAdjacentElement('afterend', meta);
    }
    function placeNow() {
      const el = document.getElementById('sunBar');
      if (!el) { if (_sunNowTimer) { clearInterval(_sunNowTimer); _sunNowTimer = null; } return; }
      const nowEl = el.querySelector('.sun-now');
      if (!nowEl) return;
      const d = new Date();
      const frac = (d.getHours() + d.getMinutes() / 60) / 24;
      nowEl.style.left = (frac * 100) + '%';
    }
    placeNow();
    if (_sunNowTimer) clearInterval(_sunNowTimer);
    _sunNowTimer = setInterval(placeNow, 60000);
  }

  // === DASHBOARD TEMPLATES (named layouts you can switch between) ===
  // Each template is a full tile arrangement. The resolved-active one is
  // rendered; edits (move/resize/add/remove) save back to it. "Auto" picks a
  // template by the day of week so the kiosk switches hands-free.
  const TPL_KEY = 'crittercrew.dashedit.templates.v2';

  // Roster-driven kid tile ids, so per-kid tiles stay in sync with kids.js.
  const KID_IDS = [{% for kid in kids %}'kid-{{ kid.key }}'{% if not loop.last %}, {% endif %}{% endfor %}];
  function kidRow(y, h) {
    h = h || 4;
    return KID_IDS.map((id, i) => ({ id: id, x: (i % 4) * 3, y: y + Math.floor(i / 4) * h, w: 3, h: h }));
  }

  function tplEsc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // Seed templates. "everyday" reuses the server-rendered DEFAULT_LAYOUT; the
  // others are hand-tuned. Every tile id here must exist in CATALOG.
  function seedTemplates() {
    return {
      activeId: 'everyday',
      auto: true,
      order: ['school', 'weekend', 'everyday'],
      templates: {
        school: {
          id: 'school', emoji: '🎒', name: 'School Day', match: 'weekday',
          layout: [
            { id: 'weather',    x: 0, y: 0, w: 3, h: 2 },
            { id: 'countdowns', x: 0, y: 2, w: 3, h: 3 },
            { id: 'calendar',   x: 3, y: 0, w: 6, h: 5 },
            { id: 'recipe',     x: 9, y: 0, w: 3, h: 5 }
          ].concat(kidRow(5, 4)).concat([
            { id: 'joke',  x: 0, y: 9, w: 6, h: 2 },
            { id: 'bible', x: 6, y: 9, w: 6, h: 2 }
          ])
        },
        weekend: {
          id: 'weekend', emoji: '🏖️', name: 'Weekend', match: 'weekend',
          layout: [
            { id: 'chores',   x: 0, y: 0, w: 4, h: 6 },
            { id: 'calendar', x: 4, y: 0, w: 5, h: 6 },
            { id: 'meals',    x: 9, y: 0, w: 3, h: 3 },
            { id: 'recipe',   x: 9, y: 3, w: 3, h: 3 }
          ].concat(kidRow(6, 3)).concat([
            { id: 'joke',  x: 0, y: 9, w: 6, h: 2 },
            { id: 'bible', x: 6, y: 9, w: 6, h: 2 }
          ])
        },
        everyday: {
          id: 'everyday', emoji: '📋', name: 'Everyday', match: null,
          layout: DEFAULT_LAYOUT
        }
      }
    };
  }

  function saveStore(s) { localStorage.setItem(TPL_KEY, JSON.stringify(s)); }

  function loadStore() {
    let store = null;
    try {
      const raw = localStorage.getItem(TPL_KEY);
      if (raw) store = JSON.parse(raw);
    } catch (e) { console.warn('Bad templates store, reseeding', e); }
    if (!store || !store.templates || !Array.isArray(store.order) || !store.order.length) {
      store = seedTemplates();
      // Migrate a pre-existing single layout (v1) into "Everyday" so an
      // already-customized kiosk keeps its arrangement; pin it (auto off).
      try {
        const old = localStorage.getItem(STORAGE_KEY);
        if (old) {
          const parsed = JSON.parse(old);
          if (Array.isArray(parsed) && parsed.length) {
            store.templates.everyday.layout = parsed;
            store.activeId = 'everyday';
            store.auto = false;
          }
        }
      } catch (e) {}
      saveStore(store);
    }
    return store;
  }

  let STORE = loadStore();

  function todayMatch() {
    const dow = new Date().getDay(); // 0 Sun .. 6 Sat
    return (dow === 0 || dow === 6) ? 'weekend' : 'weekday';
  }

  function resolveActiveId() {
    if (STORE.auto) {
      const want = todayMatch();
      const hit = STORE.order.find(id => STORE.templates[id] && STORE.templates[id].match === want);
      if (hit) return hit;
    }
    if (STORE.templates[STORE.activeId]) return STORE.activeId;
    return STORE.order[0];
  }

  let applying = false;
  function clearGrid() {
    grid.engine.nodes.slice().forEach(n => { if (n.el) grid.removeWidget(n.el, true); });
  }
  function applyTemplate(id) {
    const tpl = STORE.templates[id];
    if (!tpl) return;
    applying = true;
    clearGrid();
    (tpl.layout || []).forEach(addTile);
    applying = false;
    renderSwitcher();
    refreshAddButton();
  }

  function currentLayout() {
    return grid.engine.nodes
      .sort((a, b) => (a.y - b.y) || (a.x - b.x))
      .map(n => ({ id: n.id, x: n.x, y: n.y, w: n.w, h: n.h }));
  }

  function renderSwitcher() {
    const wrap = document.getElementById('tplSwitch');
    const activeId = resolveActiveId();
    wrap.innerHTML = '';
    STORE.order.forEach(id => {
      const tpl = STORE.templates[id];
      if (!tpl) return;
      const pill = document.createElement('button');
      pill.className = 'tpl-pill' + (id === activeId ? ' active' : '');
      pill.dataset.tpl = id;
      pill.innerHTML = '<span class="emo">' + (tpl.emoji || '🗂') + '</span>' + tplEsc(tpl.name);
      pill.addEventListener('click', () => {
        STORE.auto = false;          // tapping a view pins it (manual override)
        STORE.activeId = id;
        saveStore(STORE);
        applyTemplate(id);
        showToast(tpl.name);
      });
      wrap.appendChild(pill);
    });
    const autoBtn = document.getElementById('tplAuto');
    if (autoBtn) {
      autoBtn.classList.toggle('on', !!STORE.auto);
      autoBtn.setAttribute('aria-pressed', STORE.auto ? 'true' : 'false');
    }
  }

  // Wire template management controls (Auto / New / Rename / Delete).
  document.getElementById('tplAuto').addEventListener('click', () => {
    STORE.auto = !STORE.auto;
    if (STORE.auto) STORE.activeId = resolveActiveId();
    saveStore(STORE);
    applyTemplate(resolveActiveId());
    showToast(STORE.auto ? 'Auto by day: on' : 'Auto by day: off');
  });
  document.getElementById('tplNew').addEventListener('click', () => {
    const name = (prompt('Name this view (e.g. "Sick Day", "Summer")') || '').trim();
    if (!name) return;
    let id = 'view-' + name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 24);
    if (!id || id === 'view-') id = 'view';
    let n = 2; const base = id;
    while (STORE.templates[id]) id = base + '-' + (n++);
    STORE.templates[id] = { id: id, emoji: '🗂', name: name, match: null, layout: currentLayout() };
    STORE.order.push(id);
    STORE.auto = false; STORE.activeId = id;
    saveStore(STORE);
    applyTemplate(id);
    showToast('Created ' + name);
  });
  document.getElementById('tplRename').addEventListener('click', () => {
    const id = resolveActiveId();
    const tpl = STORE.templates[id];
    if (!tpl) return;
    const name = (prompt('Rename view', tpl.name) || '').trim();
    if (!name) return;
    tpl.name = name;
    saveStore(STORE);
    renderSwitcher();
    showToast('Renamed');
  });
  document.getElementById('tplDelete').addEventListener('click', () => {
    const id = resolveActiveId();
    const tpl = STORE.templates[id];
    if (!tpl) return;
    if (STORE.order.length <= 1) { alert('Keep at least one view.'); return; }
    if (!confirm('Delete the "' + tpl.name + '" view?')) return;
    delete STORE.templates[id];
    STORE.order = STORE.order.filter(x => x !== id);
    STORE.auto = false;
    STORE.activeId = STORE.order[0];
    saveStore(STORE);
    applyTemplate(STORE.activeId);
    showToast('Deleted');
  });

  // Initial render of the active template.
  applyTemplate(resolveActiveId());

  const toast = document.getElementById('edToast');
  // === AUTO-RELOAD every 10 min (mirrors /dashboard/) ===
  setTimeout(() => location.reload(), 10 * 60 * 1000);

  // === LOCK VIEWPORT ZOOM (iPad kiosk: no accidental pinch) ===
  (function lockZoom() {
    let vp = document.querySelector('meta[name="viewport"]');
    if (!vp) {
      vp = document.createElement('meta');
      vp.name = 'viewport';
      document.head.appendChild(vp);
    }
    vp.setAttribute(
      'content',
      'width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no, viewport-fit=cover'
    );
    // iOS Safari ignores user-scalable=no — block gesture events too.
    ['gesturestart', 'gesturechange', 'gestureend'].forEach(ev =>
      document.addEventListener(ev, e => e.preventDefault(), { passive: false })
    );
    // Double-tap-to-zoom: swallow it.
    let lastTouch = 0;
    document.addEventListener('touchend', e => {
      const now = Date.now();
      if (now - lastTouch <= 350) e.preventDefault();
      lastTouch = now;
    }, { passive: false });
  })();

  // === DAY/NIGHT THEME (sunrise → light, sunset → dark, mirrors /dashboard/) ===
  (function themeInit() {
    const SUN = {{ (weather.sun if weather and weather.sun else { sunrises: [], sunsets: [] }) | dump | safe }};
    const sunrises = (SUN.sunrises || []).map(s => new Date(s)).filter(d => !isNaN(d));
    const sunsets  = (SUN.sunsets  || []).map(s => new Date(s)).filter(d => !isNaN(d));

    function fallbackIsNight(now) {
      const h = now.getHours();
      return h >= 20 || h < 7;
    }
    function flatBoundaries() {
      const arr = [];
      sunrises.forEach(d => arr.push({ at: d, nightAfter: false }));
      sunsets.forEach(d => arr.push({ at: d, nightAfter: true }));
      arr.sort((a, b) => a.at - b.at);
      return arr;
    }
    function decide(now) {
      const bs = flatBoundaries();
      if (!bs.length) return { isNight: fallbackIsNight(now), nextFlipMs: 60 * 60 * 1000 };
      let lastPast = null, nextFuture = null;
      for (const b of bs) {
        if (b.at <= now) lastPast = b;
        else { nextFuture = b; break; }
      }
      const isNight = lastPast ? lastPast.nightAfter : !bs[0].nightAfter;
      const nextFlipMs = nextFuture ? (nextFuture.at - now) : null;
      return { isNight, nextFlipMs };
    }
    let scheduledTimer = null;
    function apply() {
      const { isNight, nextFlipMs } = decide(new Date());
      const want = isNight ? 'dark' : 'light';
      if (document.documentElement.getAttribute('data-theme') !== want) {
        document.documentElement.setAttribute('data-theme', want);
      }
      if (scheduledTimer) clearTimeout(scheduledTimer);
      const wait = nextFlipMs == null
        ? 6 * 60 * 60 * 1000
        : Math.max(1000, Math.min(nextFlipMs + 500, 6 * 60 * 60 * 1000));
      scheduledTimer = setTimeout(apply, wait);
    }
    apply();
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) apply();
    });
  })();

  // === BOTTOM-RIGHT REFRESH TAP (mirrors /dashboard/) ===
  (function addRefreshTap() {
    const tap = document.createElement('div');
    tap.style.cssText = 'position:fixed;right:0;bottom:0;width:80px;height:80px;z-index:9999;cursor:pointer;';
    tap.addEventListener('click', () => location.reload());
    document.body.appendChild(tap);
  })();
  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toast._t);
    toast._t = setTimeout(() => toast.classList.remove('show'), 1200);
  }

  function currentIds() {
    return grid.engine.nodes.map(n => n.id);
  }

  function refreshAddButton() {
    const missing = CATALOG.filter(c => !currentIds().includes(c.id));
    document.getElementById('edAdd').disabled = missing.length === 0;
  }

  function persist() {
    if (applying) return;
    const id = resolveActiveId();
    if (STORE.templates[id]) {
      STORE.templates[id].layout = currentLayout();
      saveStore(STORE);
    }
    refreshAddButton();
    showToast('Saved');
  }

  grid.on('change added removed', persist);

  // Tile remove buttons
  document.getElementById('grid').addEventListener('click', (ev) => {
    const btn = ev.target.closest('.tile-rm');
    if (!btn) return;
    const id = btn.dataset.rm;
    const node = grid.engine.nodes.find(n => n.id === id);
    if (node) grid.removeWidget(node.el, true);
  });

  // Tomorrow-recipe tap → open recipe
  document.getElementById('grid').addEventListener('click', (ev) => {
    if (document.body.dataset.edit === '1') return;
    const row = ev.target.closest('.recipe-tomorrow[data-recipe-href]');
    if (!row) return;
    window.open(row.dataset.recipeHref, '_blank', 'noopener');
  });

  // Edit mode toggle
  const toggleBtn = document.getElementById('edToggle');
  toggleBtn.addEventListener('click', () => {
    const locked = document.body.dataset.edit !== '1';
    if (locked) {
      document.body.dataset.edit = '1';
      grid.enableMove(true);
      grid.enableResize(true);
      toggleBtn.textContent = '✓ Done';
    } else {
      delete document.body.dataset.edit;
      grid.enableMove(false);
      grid.enableResize(false);
      toggleBtn.textContent = '✏️ Edit';
    }
  });

  // Reset — restore the CURRENT view to its seeded default layout.
  document.getElementById('edReset').addEventListener('click', () => {
    const id = resolveActiveId();
    const tpl = STORE.templates[id];
    const seed = seedTemplates();
    const seededLayout = (seed.templates[id] && seed.templates[id].layout) || seed.templates.everyday.layout;
    if (!confirm('Reset the "' + (tpl ? tpl.name : 'current') + '" view to its default layout?')) return;
    STORE.templates[id].layout = seededLayout;
    saveStore(STORE);
    applyTemplate(id);
    showToast('Reset ' + (tpl ? tpl.name : ''));
  });

  // Top-right tap target → toggle floating toolbar.
  // Tap outside the bar closes it.
  (function wireToolbarTap() {
    const tap = document.getElementById('edTap');
    const bar = document.getElementById('edBar');
    tap.addEventListener('click', (e) => {
      e.stopPropagation();
      bar.classList.toggle('open');
    });
    document.addEventListener('click', (e) => {
      if (!bar.classList.contains('open')) return;
      if (bar.contains(e.target) || tap.contains(e.target)) return;
      bar.classList.remove('open');
    });
  })();

  // Add-tile picker
  const picker = document.getElementById('picker');
  const pickerList = document.getElementById('pickerList');
  document.getElementById('edAdd').addEventListener('click', () => {
    const present = new Set(currentIds());
    const missing = CATALOG.filter(c => !present.has(c.id));
    pickerList.innerHTML = '';
    if (missing.length === 0) {
      pickerList.innerHTML = '<div class="empty">All tiles are already on the dashboard.</div>';
    } else {
      missing.forEach(c => {
        const el = document.createElement('div');
        el.className = 'pick-item';
        el.innerHTML = '<span>' + c.label + '</span><span class="add">ADD</span>';
        el.addEventListener('click', () => {
          addTile({ id: c.id, x: 0, y: 9999, w: c.w, h: c.h });
          picker.classList.remove('show');
          showToast('Added: ' + c.label);
        });
        pickerList.appendChild(el);
      });
    }
    picker.classList.add('show');
  });
  document.getElementById('pickerClose').addEventListener('click', () => picker.classList.remove('show'));
  picker.addEventListener('click', (ev) => { if (ev.target === picker) picker.classList.remove('show'); });
})();
</script>
