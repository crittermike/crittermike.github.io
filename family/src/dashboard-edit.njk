---
layout: base.njk
title: Dashboard Edit (Spike)
permalink: "/dashboard-edit/index.html"
eleventyExcludeFromCollections: true
---

<!--
  GRIDSTACK SPIKE — drag/resize/add/remove sandbox.
  Does NOT touch /dashboard/. Layout persisted to localStorage key:
    crittercrew.dashedit.layout.v1   (positions + which tiles are present)
  Toggle edit mode via Unlock. In edit mode:
    - drag/resize any tile
    - ✕ on each tile removes it
    - "+ Add tile" in toolbar opens picker of removed tiles
-->

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack.min.css">
<script src="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack-all.js"></script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap');

  #site-nav { display: none !important; }
  html, body { overflow: hidden; height: 100%; margin: 0; }

  /* === DESIGN TOKENS (match /dashboard/) === */
  :root {
    --warm-bg: #f5f1ea;
    --card-bg: #ffffff;
    --text-dark: #1f2328;
    --text-mid: #57606a;
    --text-light: #8b949e;
    --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.06);
    --accent-orange: #d96a2a;
    --accent-teal: #2da44e;
    --accent-gold: #bf8700;
    --accent-rose: #cf222e;
    --accent-blue: #0969da;
    --border: #e3e6ea;
    --border-soft: #eef0f3;
    --surface: #ffffff;
    --surface-mute: rgba(0,0,0,0.025);
    --surface-mute-2: rgba(0,0,0,0.035);
    --surface-mute-3: rgba(0,0,0,0.05);
    --surface-mute-track: rgba(0,0,0,0.04);
    --on-accent: #ffffff;
  }

  body {
    background: var(--warm-bg);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
    color: var(--text-dark);
  }

  /* === FLOATING TOOLBAR (hidden by default, toggled by top-right tap) === */
  .ed-bar {
    position: fixed;
    top: 12px; right: 12px;
    display: none;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    z-index: 10000;
    font-size: 13px;
  }
  .ed-bar.open { display: flex; }
  .ed-tap {
    position: fixed;
    top: 0; right: 0;
    width: 80px; height: 80px;
    z-index: 9999;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .ed-bar .ed-title {
    font-weight: 700;
    color: var(--text-dark);
    font-size: 14px;
  }
  .ed-bar .ed-title .pill {
    display: inline-block;
    margin-left: 8px;
    padding: 2px 8px;
    background: #fef3c7;
    color: #92400e;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ed-bar .ed-actions { display: flex; gap: 8px; align-items: center; }
  .ed-bar button {
    border: 1px solid var(--border);
    background: var(--card-bg);
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dark);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .ed-bar button.primary {
    background: var(--text-dark);
    color: var(--on-accent);
    border-color: var(--text-dark);
  }
  .ed-bar button.danger {
    background: var(--card-bg);
    color: var(--accent-rose);
    border-color: #f4c0c8;
  }
  .ed-bar button:disabled { opacity: 0.4; cursor: not-allowed; }
  body[data-edit="1"] .ed-bar { background: #fef3c7; border-color: #fbbf24; }

  /* === STAGE === */
  .stage {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    padding: 6px;
    overflow: hidden;
  }

  /* === GRIDSTACK SHELL === */
  .grid-stack {
    background: transparent;
    height: 100% !important;
  }
  .grid-stack-item-content {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow);
    padding: 12px 14px 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    inset: 4px !important;
  }
  body[data-edit="1"] .grid-stack-item-content {
    border-color: #fbbf24;
    border-style: dashed;
    cursor: move;
  }
  body[data-edit="1"] .grid-stack-item-content > .tile-h,
  body[data-edit="1"] .grid-stack-item-content > .tile-body { pointer-events: none; }

  .tile-rm {
    display: none;
    position: absolute;
    top: 6px; right: 6px;
    width: 26px; height: 26px;
    border-radius: 999px;
    background: var(--accent-rose);
    color: var(--on-accent);
    border: none;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    z-index: 5;
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    -webkit-tap-highlight-color: transparent;
  }
  body[data-edit="1"] .tile-rm { display: block; }

  /* === SHARED TILE TYPOGRAPHY (matches /dashboard/ card-h) === */
  .tile-h {
    margin: 0 0 10px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-mid);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-shrink: 0;
  }
  .tile-h .sub {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-light);
    font-weight: 600;
  }
  .tile-h .pill {
    background: var(--surface-mute-3);
    color: var(--text-dark);
    font-size: 0.62rem;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .tile-h .h-action {
    background: var(--surface-mute-3);
    color: var(--text-dark);
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    cursor: pointer;
    border: none;
    text-transform: uppercase;
  }
  .tile-h .h-action:hover, .tile-h .h-action:active { background: rgba(0,0,0,0.08); }

  /* === MODAL (See all events) === */
  .modal-bg {
    display: none;
    position: fixed; inset: 0;
    background: rgba(15, 20, 28, 0.55);
    z-index: 350;
    align-items: flex-start;
    justify-content: center;
    padding-top: 24px;
  }
  .modal-bg.open { display: flex; }
  .modal-bg .modal {
    background: var(--card-bg);
    border-radius: 14px;
    width: min(560px, 92vw);
    max-height: 88vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
  }
  .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--border-soft);
  }
  .modal-head h2 { margin: 0; font-size: 1rem; color: var(--text-dark); }
  .modal-close {
    background: none; border: none;
    font-size: 1.1rem;
    cursor: pointer;
    color: var(--text-mid);
    padding: 4px 8px;
  }
  .modal-body { padding: 14px 18px; overflow: auto; }
  .cal-filter {
    width: 100%;
    box-sizing: border-box;
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.9rem;
    margin-bottom: 10px;
    background: var(--warm-bg);
    color: var(--text-dark);
  }
  .cal-month-h {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--accent-orange);
    font-weight: 700;
    margin: 14px 0 4px;
    padding-top: 6px;
    border-top: 1px solid var(--border-soft);
  }
  .tile-body {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    font-size: 0.85rem;
    color: var(--text-dark);
    display: flex;
    flex-direction: column;
  }

  /* === KIDS TILE === */
  .kids-grid {
    display: grid;
    grid-template-columns: 1fr auto auto;
    column-gap: 18px;
    row-gap: 9px;
    align-items: baseline;
  }
  .kids-grid .h {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-light);
    font-weight: 700;
  }
  .kids-grid .h.r { text-align: right; }
  .kids-grid .nm {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-dark);
  }
  .kids-grid .v {
    font-size: 1.05rem;
    font-weight: 700;
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--text-dark);
  }
  .kids-grid .v.danger { color: var(--accent-rose); }
  .kids-grid .v.warn   { color: var(--accent-gold); }

  /* === COUNTDOWNS (matches /dashboard/ .cd-item) === */
  .cd-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow: hidden;
  }
  .cd-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    background: var(--surface-mute);
    border-radius: 10px;
    min-height: 0;
  }
  .cd-item .n {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--accent-orange);
    font-variant-numeric: tabular-nums;
    min-width: 1.6em;
    text-align: right;
    flex-shrink: 0;
  }
  .cd-item .lbl {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1.2;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    word-break: break-word;
  }
  .cd-item .lbl .unit {
    color: var(--text-mid);
    font-weight: 500;
    font-size: 0.72rem;
    margin-right: 4px;
  }
  .cd-item.is-today .n { color: var(--accent-teal); font-size: 1.2rem; }

  /* === CALENDAR (matches /dashboard/ cal-row) === */
  .cal-list {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0;
  }
  .cal-row {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 8px;
    align-items: baseline;
    padding: 6px 0;
    border-bottom: 1px solid var(--border-soft);
    font-size: 0.85rem;
    line-height: 1.25;
  }
  .cal-row:last-child { border-bottom: none; }
  .cal-row.today-row { background: rgba(217,106,42,0.10); border-radius: 6px; padding-left: 6px; padding-right: 6px; }
  .cal-row.today-row .t { color: var(--accent-orange); }
  .cal-bucket-h {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-dark);
    font-weight: 700;
    margin: 10px 0 2px;
    padding: 5px 0 2px;
    border-top: 1px solid var(--border-soft);
  }
  .cal-bucket-h:first-child { margin-top: 0; padding-top: 0; border-top: none; }
  .cal-bucket-h.today { color: var(--accent-orange); }
  .cal-bucket-h .cal-bucket-count {
    font-size: 0.58rem;
    font-weight: 600;
    color: var(--text-light);
    letter-spacing: 0.5px;
  }
  .cal-row .t {
    color: var(--text-light);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    font-variant-numeric: tabular-nums;
  }
  .cal-row .w { color: var(--text-dark); }

  /* === CHORES (matches /dashboard/ .chores) === */
  .chores-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 20px;
    row-gap: 4px;
    overflow: hidden;
    min-height: 0;
    flex: 1;
    align-content: start;
  }
  .chores-col {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .chores-col-h {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent-orange);
    line-height: 1;
    margin: 2px 0 10px;
    letter-spacing: -0.5px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    flex-shrink: 0;
  }
  .chores-groups {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    gap: 16px;
  }
  .chores-group { margin: 0; display: flex; flex-direction: column; flex: 0 0 auto; min-height: 0; }
  .chores-group-h {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-light);
    font-weight: 800;
    margin: 0 0 6px;
  }
  .chores-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .chore-item {
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.4;
    font-size: 0.78rem;
    color: var(--text-dark);
  }
  .chore-item input[type="checkbox"] {
    width: 16px; height: 16px;
    margin: 0; padding: 0;
    accent-color: var(--accent-teal);
    cursor: pointer;
    flex-shrink: 0;
  }
  .chore-label { flex: 1; min-width: 0; }
  .chore-item.all-done .chore-label {
    text-decoration: line-through;
    color: var(--text-light);
  }

  /* Monthly section visibility — driven by body[data-w-of-m] set in renderChoresPill() */
  .chores-monthly { display: none; }
  body[data-w-of-m="1"] .chores-monthly[data-n="1"],
  body[data-w-of-m="2"] .chores-monthly[data-n="2"],
  body[data-w-of-m="3"] .chores-monthly[data-n="3"],
  body[data-w-of-m="4"] .chores-monthly[data-n="4"],
  body[data-w-of-m="5"] .chores-monthly[data-n="4"] { display: flex; }

  /* === BUDGET (matches /dashboard/ .budget) === */
  .budget-cats {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    justify-content: space-around;
  }
  .budget-cat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .budget-cat .name {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-dark);
  }
  .budget-cat .name .status {
    font-size: 0.58rem;
    font-weight: 600;
    color: var(--text-mid);
    text-transform: none;
    letter-spacing: 0;
  }
  .budget-cat .name .status.over { color: var(--accent-rose); }
  .budget-bars {
    position: relative;
    height: 8px;
    background: var(--surface-mute-track);
    border-radius: 999px;
    overflow: hidden;
  }
  .budget-bars .actual {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    border-radius: 999px;
    transition: width 0.4s ease;
  }
  .budget-bars .actual.ok   { background: var(--accent-teal); }
  .budget-bars .actual.warn { background: var(--accent-gold); }
  .budget-bars .actual.over { background: var(--accent-rose); }
  .budget-bars .pace {
    position: absolute;
    top: -2px;
    width: 2px;
    height: 12px;
    background: var(--text-mid);
    border-radius: 1px;
    transform: translateX(-1px);
  }

  /* === WEATHER === */
  .weather-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 10px;
  }
  .weather-row .icon { font-size: 1.8rem; line-height: 1; }
  .weather-row .temp {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text-dark);
    font-variant-numeric: tabular-nums;
  }
  .weather-row .hilo {
    color: var(--text-light);
    font-size: 0.75rem;
    font-weight: 600;
  }
  .weather-days {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
    text-align: center;
  }
  .weather-days .d {
    color: var(--text-light);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .weather-days .ic { font-size: 1.15rem; line-height: 1.3; }
  .weather-days .hl {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: 0.72rem;
    color: var(--text-dark);
  }

  /* === MEAL PLAN === */
  .meal-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.82rem;
    overflow: hidden;
  }
  .meal-list .row {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 8px;
    align-items: baseline;
    padding: 4px 0;
    border-bottom: 1px solid var(--border-soft);
  }
  .meal-list .row:last-child { border-bottom: none; }
  .meal-list .row.today .nm { color: var(--accent-orange); font-weight: 700; }
  .meal-list .dow {
    color: var(--text-light);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .meal-list .nm { color: var(--text-dark); }

  /* === DINNER === */
  .dinner-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.15;
    margin-bottom: 6px;
  }
  .dinner-note {
    font-size: 0.78rem;
    color: var(--text-mid);
  }

  /* === SUMMER READING === */
  .reading-list { display: flex; flex-direction: column; gap: 10px; }
  .reading-row { cursor: pointer; -webkit-tap-highlight-color: transparent; }
  .reading-row.editing { cursor: default; }
  .reading-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.78rem;
    margin-bottom: 3px;
  }
  .reading-name { color: var(--text-dark); font-weight: 700; }
  .reading-count { color: var(--text-mid); font-variant-numeric: tabular-nums; }
  .reading-row.editing .reading-count { display: none; }
  .reading-editor {
    display: flex;
    gap: 6px;
    align-items: center;
    margin: 2px 0 4px;
  }
  .reading-editor[hidden] { display: none; }
  .reading-input {
    flex: 1 1 auto;
    min-width: 0;
    font-size: 0.9rem;
    padding: 4px 6px;
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--card-bg);
    color: var(--text-dark);
  }
  .reading-input::-webkit-outer-spin-button,
  .reading-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .reading-add, .reading-cancel, .reading-reset {
    border: 1px solid var(--border-soft);
    background: var(--card-bg);
    color: var(--text-dark);
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 0.78rem;
    cursor: pointer;
  }
  .reading-add { background: var(--accent-teal); color: white; border-color: transparent; font-weight: 700; }
  .reading-row .progress {
    height: 4px;
    background: var(--border-soft);
    border-radius: 2px;
    overflow: hidden;
  }
  .reading-row .progress .bar {
    height: 100%;
    background: var(--accent-orange);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  /* === TODAY'S ASSIGNMENTS === */
  .assn-list { display: flex; flex-direction: column; gap: 10px; }
  .assn-kid-h {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-mid);
    font-weight: 700;
    margin-bottom: 4px;
  }
  .assn-list .todo-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .assn-list .todo {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    user-select: none;
    font-size: 0.85rem;
    color: var(--text-dark);
  }
  .assn-list .todo input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--border-soft);
    border-radius: 4px;
    margin: 0;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
  }
  .assn-list .todo input[type="checkbox"]:checked {
    background: var(--accent-teal);
    border-color: var(--accent-teal);
  }
  .assn-list .todo input[type="checkbox"]:checked::after {
    content: "✓";
    position: absolute;
    inset: 0;
    color: white;
    font-size: 12px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .assn-list .todo input[type="checkbox"]:checked + .todo-label {
    text-decoration: line-through;
    color: var(--text-mid);
  }

  /* === RECIPE OF THE DAY === */
  .recipe-box {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .recipe-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.15;
    margin-bottom: 8px;
  }
  .recipe-meta {
    font-size: 0.75rem;
    color: var(--text-mid);
    margin-bottom: 10px;
  }
  .recipe-meta .pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--border-soft);
    margin-right: 6px;
    font-weight: 600;
  }
  .recipe-link {
    margin-top: auto;
    font-size: 0.82rem;
    color: var(--accent-teal);
    text-decoration: none;
    font-weight: 700;
  }
  .recipe-link:hover { text-decoration: underline; }

  /* === PLACEHOLDER === */
  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--text-light);
    font-style: italic;
    font-size: 0.85rem;
