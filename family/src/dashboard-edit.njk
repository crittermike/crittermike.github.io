  }

  /* === ADD-TILE PICKER === */
  .picker-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(15, 20, 28, 0.55);
    z-index: 300;
    align-items: center;
    justify-content: center;
  }
  .picker-backdrop.show { display: flex; }
  .picker {
    background: var(--card-bg);
    border-radius: 14px;
    width: min(420px, 92vw);
    max-height: 80vh;
    overflow: auto;
    padding: 18px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
  }
  .picker h3 { margin: 0 0 14px; font-size: 1rem; color: var(--text-dark); }
  .picker .pick-list { display: flex; flex-direction: column; gap: 8px; }
  .picker .pick-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 14px;
    background: var(--warm-bg);
    border-radius: 10px;
    cursor: pointer;
