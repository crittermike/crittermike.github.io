<!-- HIDDEN TILE TEMPLATES — server-rendered content cloned into the grid on demand -->
<div id="tileTemplates" style="display:none">

  <div data-tpl="kids">
    <div class="tile-h"><span>👨‍👩‍👦‍👦 Kids</span><span class="sub">Sugar · Allowance</span></div>
    <div class="tile-body">
      <div class="kids-grid">
        {% for kid in kids %}
          <div class="nm">{{ kid.name }}</div>
          {% if kid.sugar.balance is not none %}
            {% set neg = kid.sugar.balance < 0 %}
            {% set low = kid.sugar.balance >= 0 and kid.sugar.balance < kid.sugar.refill * 0.5 %}
            <div class="v{% if neg %} danger{% elif low %} warn{% endif %}">{{ kid.sugar.balance }}g</div>
          {% else %}
            <div class="v">—</div>
          {% endif %}
          {% if kid.allowance.balance_str %}
            {% set negA = '-' in kid.allowance.balance_str %}
            <div class="v{% if negA %} danger{% endif %}">{{ kid.allowance.balance_str }}</div>
          {% else %}
            <div class="v">—</div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div data-tpl="budget">
    <div class="tile-h"><span>💳 Budget</span><span class="sub" id="budgetMonth">—</span></div>
    <div class="tile-body">
      <div class="budget-cats">
        <div class="budget-cat" data-cat="shopping" data-pct="42">
          <div class="name"><span>Shopping</span><span class="status" id="status-shopping"></span></div>
          <div class="budget-bars">
            <div class="actual" id="bar-shopping"></div>
            <div class="pace" id="pace-shopping"></div>
          </div>
        </div>
        <div class="budget-cat" data-cat="food" data-pct="68">
          <div class="name"><span>Food</span><span class="status" id="status-food"></span></div>
          <div class="budget-bars">
            <div class="actual" id="bar-food"></div>
            <div class="pace" id="pace-food"></div>
          </div>
        </div>
        <div class="budget-cat" data-cat="ent" data-pct="89">
          <div class="name"><span>Entertainment</span><span class="status" id="status-ent"></span></div>
          <div class="budget-bars">
            <div class="actual" id="bar-ent"></div>
            <div class="pace" id="pace-ent"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div data-tpl="countdowns">
    <div class="tile-h"><span>⏳ Countdowns</span></div>
    <div class="tile-body">
      <div class="cd-list" id="cdList"></div>
    </div>
  </div>

  <div data-tpl="calendar">
    <div class="tile-h"><span>📅 Upcoming</span><button class="h-action" id="calExpand">See all</button></div>
    <div class="tile-body">
      <div class="cal-list" id="calList"></div>
    </div>
  </div>

  <div data-tpl="chores">
    <div class="tile-h"><span>🧹 Weekend chores</span><span class="pill" id="choresWkPill">—</span></div>
    <div class="tile-body">
      <div class="chores-body">
        <div class="chores-col">
          <div class="chores-col-h">Saturday</div>
          <div class="chores-groups">
            <div class="chores-group">
              <div class="chores-group-h">{{ chores.quick.title }}</div>
              <ul class="chores-list">
                {% for item in chores.quick.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% for m in chores.monthly %}
            <div class="chores-monthly chores-group" data-n="{{ m.n }}">
              <div class="chores-group-h">{{ m.sat.title }}</div>
              <ul class="chores-list">
                {% for item in m.sat.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% endfor %}
          </div>
        </div>
        <div class="chores-col">
          <div class="chores-col-h">Sunday</div>
          <div class="chores-groups">
            <div class="chores-group">
              <div class="chores-group-h">{{ chores.laundry.title }}</div>
              <ul class="chores-list">
                {% for item in chores.laundry.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% for m in chores.monthly %}
            <div class="chores-monthly chores-group" data-n="{{ m.n }}">
              <div class="chores-group-h">{{ m.sun.title }}</div>
              <ul class="chores-list">
                {% for item in m.sun.items %}<li class="chore-item" data-id="{{ item.id }}"><input type="checkbox" data-chore="{{ item.id }}" data-slot="0"><span class="chore-label">{{ item.label }}</span></li>{% endfor %}
              </ul>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div data-tpl="weather">
    <div class="tile-h"><span>☀️ Weather</span><span class="sub">Greenville</span></div>
    <div class="tile-body">
      {% if weather %}
      <div class="weather-row">
        <span class="icon">{{ weather.now.icon }}</span>
        <span class="temp">{{ weather.now.temp }}°</span>
        <span class="hilo">H {{ weather.now.hi }} / L {{ weather.now.lo }}</span>
      </div>
      <div class="weather-days">
        {% for d in weather.days %}
          <div>
            <div class="d">{{ d.d }}</div>
            <div class="ic">{{ d.icon }}</div>
            <div class="hl">{{ d.hi }}/{{ d.lo }}</div>
          </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="placeholder">Weather unavailable</div>
      {% endif %}
    </div>
  </div>

  <div data-tpl="meals">
    <div class="tile-h"><span>🍽️ Meal plan</span><span class="sub">This week</span></div>
    <div class="tile-body">
      <div class="meal-list">
        {% for m in mealweek %}
          <div class="row{% if m.isToday %} today{% endif %}">
            <span class="dow">{{ m.dow_short }}</span>
            <span class="nm">{{ m.name }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div data-tpl="dinner">
    <div class="tile-h"><span>🍳 Tonight</span></div>
    <div class="tile-body">
      <div class="dinner-name">{{ dinner.name or 'TBD' }}</div>
      {% if dinner.note %}<div class="dinner-note">{{ dinner.note }}</div>{% endif %}
    </div>
  </div>

  <div data-tpl="reading">
    <div class="tile-h"><span>📚 Summer reading</span></div>
    <div class="tile-body">
      <div class="reading-list">
        {% for kid in kids %}
          {% if kid.reading %}
            <div class="reading-row" data-kid="{{ kid.key }}" data-base="{{ kid.reading.pages }}" data-target="{{ kid.reading.target }}">
              <div class="reading-head">
                <span class="reading-name">{{ kid.name }}</span>
                <span class="reading-count"><span class="reading-pages">{{ kid.reading.pages }}</span> / {{ kid.reading.target }} pgs</span>
              </div>
              <div class="reading-editor" hidden>
                <input type="number" inputmode="numeric" pattern="[0-9]*" min="1" max="9999" step="1" class="reading-input" placeholder="pages">
                <button type="button" class="reading-add">Add</button>
                <button type="button" class="reading-reset" title="Reset to 0">↺</button>
                <button type="button" class="reading-cancel">✕</button>
              </div>
              <div class="progress"><div class="bar reading-bar" style="width: {{ kid.reading.pct }}%"></div></div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div data-tpl="assignments">
    <div class="tile-h"><span>✏️ Today's assignments</span></div>
    <div class="tile-body">
      <div class="assn-list">
        {% set anyAssn = false %}
        {% for kid in kids %}
          {% if kid.assignments and kid.assignments.length %}
            {% set anyAssn = true %}
            <div class="assn-kid">
              <div class="assn-kid-h">{{ kid.name }}</div>
              <ul class="todo-list" data-kid="{{ kid.key }}">
                {% for a in kid.assignments %}
                  <li>
                    <label class="todo">
                      <input type="checkbox" data-kid="{{ kid.key }}" data-id="{{ a.id }}">
                      <span class="todo-label">{{ a.label }}</span>
                    </label>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        {% endfor %}
        {% if not anyAssn %}
          <div class="placeholder">Nothing assigned today. Go outside.</div>
        {% endif %}
      </div>
    </div>
  </div>

  <div data-tpl="recipe">
    <div class="tile-h"><span>🍲 Recipe of the day</span><span class="sub" id="recipeDate">—</span></div>
    <div class="tile-body">
      <div class="recipe-box" id="recipeBox">
        <div class="recipe-name" id="recipeName">—</div>
        <div class="recipe-meta" id="recipeMeta"></div>
        <a class="recipe-link" id="recipeLink" href="#" target="_blank" rel="noopener">Open recipe →</a>
      </div>
