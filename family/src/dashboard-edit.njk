  }
  .picker .close {
    float: right;
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    color: var(--text-mid);
  }

  /* === TOAST === */
  .ed-toast {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--text-dark);
    color: var(--on-accent);
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.25s;
