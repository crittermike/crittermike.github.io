<!-- RECIPE MODAL (content swapped per tapped day) -->
{% if mealweek %}
<div class="modal-bg" id="recipeModal">
  <div class="modal modal-recipe">
    <div class="modal-head">
      <h2 id="recipeTitle">Recipe</h2>
      <button class="modal-close" onclick="closeModal('recipeModal')">✕</button>
    </div>
    <div class="modal-body" id="recipeBody"></div>
  </div>
</div>

<script>
  // Recipe lookup table built from mealweek
  const RECIPES = {
    {% for m in mealweek %}{% if m.recipe %}
    {{ m.recipe.slug | dump | safe }}: {
      name: {{ m.recipe.name | dump | safe }},
      servings: {{ (m.recipe.servings or 0) | dump | safe }},
      prep_min: {{ (m.recipe.prep_min or 0) | dump | safe }},
      cook_min: {{ (m.recipe.cook_min or 0) | dump | safe }},
      effort: {{ (m.recipe.effort or '') | dump | safe }},
      protein_g: {{ (m.recipe.protein_g or 0) | dump | safe }},
      cal: {{ (m.recipe.cal or 0) | dump | safe }},
      ingredient_groups: {{ (m.recipe.ingredient_groups or []) | dump | safe }},
      steps: {{ (m.recipe.steps or []) | dump | safe }},
      notes: {{ (m.recipe.notes or '') | dump | safe }},
      body_html: {{ (m.recipe.body_html or '') | dump | safe }}
    },
    {% endif %}{% endfor %}
  };

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  // very light markdown: **bold** and *italic* (steps frequently use these)
  function mdInline(s) {
    return escHtml(s)
      .replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>')
      .replace(/\*([^*]+)\*/g, '<i>$1</i>');
  }

  function openRecipe(slug) {
    const r = RECIPES[slug];
    if (!r) return;
    document.getElementById('recipeTitle').textContent = r.name;

    let html = '<div class="meta">';
    if (r.servings) html += '<span><b>Serves:</b> ' + escHtml(r.servings) + '</span>';
    if (r.prep_min) html += '<span><b>Prep:</b> ' + escHtml(r.prep_min) + ' min</span>';
    if (r.cook_min) html += '<span><b>Cook:</b> ' + escHtml(r.cook_min) + ' min</span>';
    if (r.effort) html += '<span><b>Effort:</b> ' + escHtml(r.effort) + '</span>';
    if (r.protein_g) html += '<span><b>Protein:</b> ' + escHtml(r.protein_g) + 'g</span>';
    if (r.cal) html += '<span><b>Cal:</b> ' + escHtml(r.cal) + '</span>';
    html += '</div>';

    const groups = Array.isArray(r.ingredient_groups) ? r.ingredient_groups : [];
    const steps = Array.isArray(r.steps) ? r.steps : [];
    const hasStructured = groups.length > 0 || steps.length > 0;

    if (hasStructured) {
      html += '<div class="recipe-cols">';

      // LEFT: ingredients
      html += '<div class="recipe-col"><h3>Ingredients</h3>';
      if (groups.length === 0) {
        html += '<div class="recipe-empty">No ingredients listed.</div>';
      } else {
        groups.forEach(g => {
          if (g.heading) html += '<div class="group-h">' + escHtml(g.heading) + '</div>';
          html += '<ul>';
          (g.items || []).forEach(it => { html += '<li>' + mdInline(it) + '</li>'; });
          html += '</ul>';
        });
      }
      html += '</div>';

      // RIGHT: steps
      html += '<div class="recipe-col"><h3>Steps</h3>';
      if (steps.length === 0) {
        html += '<div class="recipe-empty">No steps written up yet. Wing it.</div>';
      } else {
        html += '<ol>';
        steps.forEach(s => { html += '<li>' + mdInline(s) + '</li>'; });
        html += '</ol>';
      }
      html += '</div>';

      html += '</div>'; // /recipe-cols

      if (r.notes && r.notes.trim()) {
        html += '<div class="recipe-notes">' + mdInline(r.notes) + '</div>';
      }
    } else {
      // Fallback to raw body_html if no structured data
      html += r.body_html || '<div class="recipe-empty">No recipe details.</div>';
    }

    document.getElementById('recipeBody').innerHTML = html;
    openModal('recipeModal');
  }

  document.querySelectorAll('[data-recipe]').forEach(row => {
    row.addEventListener('click', () => openRecipe(row.dataset.recipe));
  });
</script>
{% endif %}

<!-- CALENDAR FULL MODAL -->
<div class="modal-bg" id="calModal">
  <div class="modal">
    <div class="modal-head">
      <h2>📅 All upcoming events</h2>
      <button class="modal-close" onclick="closeModal('calModal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="text" class="cal-filter" id="calFilter" placeholder="Filter events..." autocomplete="off" />
      <div id="calFullList"></div>
    </div>
  </div>
</div>

<script>
  // === EVENTS DATA (built at build time from cal_today.py via _data/calendar.js) ===
  const events = {{ calendar | dump | safe }};

  const today = new Date();
  // Use LOCAL date components, not toISOString() (which is UTC and rolls to "tomorrow" after ~8pm ET).
  const todayStr = today.getFullYear() + '-' +
    String(today.getMonth() + 1).padStart(2, '0') + '-' +
    String(today.getDate()).padStart(2, '0');

  function fmtWhen(ev) {
    const d = new Date(ev.date + 'T00:00');
    const dow = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];
    const diffDays = Math.round((d - new Date(todayStr + 'T00:00')) / 86400000);
    const time = ev.all_day ? 'all day' : ev.time;
    // For Today/Tomorrow buckets the header carries the day, so just show time.
    if (diffDays === 0) return time;
    if (diffDays === 1) return time;
    if (diffDays >= 2 && diffDays < 14) return dow + (ev.all_day ? '' : ' ' + ev.time);
    const mo = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()];
    return mo + ' ' + d.getDate() + (ev.all_day ? '' : ' ' + ev.time);
  }

  // Bucket an event by its distance from today.
  function bucketFor(ev) {
    const d = new Date(ev.date + 'T00:00:00');
    const diffDays = Math.round((d - new Date(todayStr + 'T00:00')) / 86400000);
    if (diffDays <= 0) return 'today';
    if (diffDays === 1) return 'tomorrow';
    if (diffDays < 7) return 'thisweek';
    if (diffDays < 14) return 'nextweek';
    return 'later';
  }
  const BUCKET_LABELS = {
    today: 'Today',
    tomorrow: 'Tomorrow',
    thisweek: 'This week',
    nextweek: 'Next week',
    later: 'Later'
  };
  const BUCKET_ORDER = ['today', 'tomorrow', 'thisweek', 'nextweek', 'later'];

  // Hide events that already ended. Uses end time if present, else falls back
  // to the start date (so a past day is fully filtered). All-day events stay
  // visible through end of day.
  function notPast(ev) {
    if (ev.date > todayStr) return true;
    if (ev.date < todayStr) return false;
    // today: drop if it has an end time in the past
    if (ev.all_day) return true;
    if (ev.end) {
      const endMs = Date.parse(ev.end);
      if (!isNaN(endMs) && endMs < Date.now()) return false;
    }
    return true;
  }

  function rowHTML(ev) {
    const isToday = ev.date === todayStr;
    return '<div class="cal-row' + (isToday ? ' today-row' : '') + '">' +
      '<span class="when">' + fmtWhen(ev) + '</span>' +
      '<span class="what">' + ev.what + '</span>' +
      '</div>';
  }

  // Group a flat list of events by bucket key. Returns array of {key, label, items}.
  function groupByBucket(list) {
    const groups = {};
    list.forEach(ev => {
      const k = bucketFor(ev);
      (groups[k] = groups[k] || []).push(ev);
    });
    return BUCKET_ORDER
      .filter(k => groups[k] && groups[k].length)
      .map(k => ({ key: k, label: BUCKET_LABELS[k], items: groups[k] }));
  }

  function bucketHTML(group) {
    const isToday = group.key === 'today';
    return '<div class="cal-bucket-h' + (isToday ? ' today' : '') + '">' +
      '<span>' + group.label + '</span>' +
      '<span class="cal-bucket-count">' + group.items.length + '</span>' +
      '</div>' +
      group.items.map(rowHTML).join('');
  }

  // Render preview (top ~14 upcoming, past events filtered, grouped by bucket)
  function renderPreview() {
    const upcoming = events.filter(notPast).slice(0, 14);
    const grouped = groupByBucket(upcoming);
    document.getElementById('calPreview').innerHTML = grouped.map(bucketHTML).join('');
  }
  renderPreview();

  // Render full modal list. Bucketed at the top (Today/Tomorrow/This week/Next week), then by month for the rest.
  function renderFullList(filter = '') {
    const f = filter.trim().toLowerCase();
    const filtered = events
      .filter(notPast)
      .filter(e => !f || e.what.toLowerCase().includes(f));
    if (filtered.length === 0) {
      document.getElementById('calFullList').innerHTML = '<div style="padding:20px;text-align:center;color:var(--text-mid)">No matching events.</div>';
      return;
    }
    // Split: events in this-or-next-week buckets get top treatment; "later" falls through to month grouping.
    const nearTerm = filtered.filter(ev => bucketFor(ev) !== 'later');
    const later = filtered.filter(ev => bucketFor(ev) === 'later');
    let html = '';
    if (nearTerm.length) {
      html += groupByBucket(nearTerm).map(bucketHTML).join('');
    }
    if (later.length) {
      const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      let currentMonth = '';
      later.forEach(ev => {
        const d = new Date(ev.date + 'T00:00:00');
        const monthKey = months[d.getMonth()] + ' ' + d.getFullYear();
        if (monthKey !== currentMonth) {
          html += '<div class="cal-month-h">' + monthKey + '</div>';
          currentMonth = monthKey;
        }
        html += rowHTML(ev);
      });
    }
    document.getElementById('calFullList').innerHTML = '<div class="cal-full-list">' + html + '</div>';
  }

  // === MODAL CONTROLS ===
  function openModal(id) {
    document.getElementById(id).classList.add('open');
    if (id === 'calModal') {
      renderFullList();
      setTimeout(() => document.getElementById('calFilter').focus(), 50);
    }
  }
  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }
  window.closeModal = closeModal;

  const dinnerCard = null;
  document.getElementById('calExpand').addEventListener('click', (e) => { e.stopPropagation(); openModal('calModal'); });
  document.getElementById('calFilter').addEventListener('input', (e) => renderFullList(e.target.value));

  // Click backdrop to close
  document.querySelectorAll('.modal-bg').forEach(bg => {
    bg.addEventListener('click', (e) => { if (e.target === bg) bg.classList.remove('open'); });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') document.querySelectorAll('.modal-bg.open').forEach(m => m.classList.remove('open'));
  });

  // === COUNTDOWNS ===
  // [{ label, date: 'YYYY-MM-DD' }] all non-past, sorted soonest-first
  const COUNTDOWNS = [
    { label: "Mike's birthday", date: '2026-06-13' },
    { label: 'California',      date: '2026-06-18' },
    { label: 'Dude Perfect',    date: '2026-06-26' },
    { label: 'lake trip',       date: '2026-07-06' },
    { label: 'first day of school', date: '2026-08-13' },
  ];
  function renderCountdown() {
    const wrap = document.getElementById('countdowns');
    const today = new Date();
    const todayMid = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    const items = COUNTDOWNS
      .map(c => {
        const [y, m, d] = c.date.split('-').map(Number);
        const target = new Date(y, m - 1, d);
        const days = Math.round((target - todayMid) / 86400000);
        return { ...c, days };
      })
      .filter(c => c.days >= 0)
      .sort((a, b) => a.days - b.days);
    const parts = items.map(c => {
      const isToday = c.days === 0;
      const nTxt = isToday ? '🎉' : c.days;
      const unit = isToday ? '' : '<span class="unit">' + (c.days === 1 ? 'day to' : 'days to') + '</span>';
      const lblTxt = isToday ? c.label + ' is today!' : unit + c.label;
      return (
        '<div class="cd-item' + (isToday ? ' is-today' : '') + '">' +
          '<span class="n">' + nTxt + '</span>' +
          '<span class="lbl">' + lblTxt + '</span>' +
        '</div>'
      );
    });
    wrap.innerHTML = parts.join('');
  }
  renderCountdown();

  // === AUTO-RELOAD (was paired with clock tick) ===
  setTimeout(() => location.reload(), 10 * 60 * 1000);

  // === DAY/NIGHT THEME (sunrise → light, sunset → dark) ===
  // Sun times come from Open-Meteo at build time, local-naive ISO strings
  // in America/New_York. We parse them as local time, find the boundary
  // closest to "now", flip the theme, and schedule the next flip exactly
  // when it's due. Reschedules on visibilitychange so a Kindle/iPad waking
  // up after sleep snaps to the right theme right away.
  (function themeInit() {
    const SUN = {{ (weather.sun if weather and weather.sun else { sunrises: [], sunsets: [] }) | dump | safe }};
    const sunrises = (SUN.sunrises || []).map(s => new Date(s)).filter(d => !isNaN(d));
    const sunsets  = (SUN.sunsets  || []).map(s => new Date(s)).filter(d => !isNaN(d));

    // Fallback when the build had no weather data: rough static window for SC.
    // (May → Sep is 7am/8pm; we just go simple and pick "dark from 8pm to 7am".)
    function fallbackIsNight(now) {
      const h = now.getHours();
      return h >= 20 || h < 7;
    }

    function flatBoundaries() {
      // Returns sorted [{at: Date, nightAfter: bool}, ...]
      const arr = [];
      sunrises.forEach(d => arr.push({ at: d, nightAfter: false }));
      sunsets.forEach(d => arr.push({ at: d, nightAfter: true }));
      arr.sort((a, b) => a.at - b.at);
      return arr;
    }

    function decide(now) {
      // Returns { isNight: bool, nextFlipMs: number|null }
      const bs = flatBoundaries();
      if (!bs.length) {
        return { isNight: fallbackIsNight(now), nextFlipMs: 60 * 60 * 1000 };
      }
      // Find the most recent boundary at or before `now`
      let lastPast = null;
      let nextFuture = null;
      for (const b of bs) {
        if (b.at <= now) lastPast = b;
        else { nextFuture = b; break; }
      }
      const isNight = lastPast
        ? lastPast.nightAfter
        : !bs[0].nightAfter; // before the first sunrise/sunset in data
      const nextFlipMs = nextFuture ? (nextFuture.at - now) : null;
      return { isNight, nextFlipMs };
    }

    function apply() {
      const { isNight, nextFlipMs } = decide(new Date());
      const want = isNight ? 'dark' : 'light';
      if (document.documentElement.getAttribute('data-theme') !== want) {
        document.documentElement.setAttribute('data-theme', want);
      }
      // Schedule the next flip. Cap at ~6h so we re-check periodically even
      // if the sun data runs out (the 10-minute auto-reload also bails us out).
      if (scheduledTimer) clearTimeout(scheduledTimer);
      const wait = nextFlipMs == null
        ? 6 * 60 * 60 * 1000
        : Math.max(1000, Math.min(nextFlipMs + 500, 6 * 60 * 60 * 1000));
      scheduledTimer = setTimeout(apply, wait);
    }

    let scheduledTimer = null;
    apply();

    // Tab/screen wake-up: re-evaluate immediately.
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) apply();
    });
  })();

  // === LOCK VIEWPORT ZOOM (iPad kiosk: no accidental pinch) ===
  (function lockZoom() {
    let vp = document.querySelector('meta[name="viewport"]');
    if (!vp) {
      vp = document.createElement('meta');
      vp.name = 'viewport';
      document.head.appendChild(vp);
    }
    vp.setAttribute(
      'content',
      'width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no, viewport-fit=cover'
    );
    // iOS Safari ignores user-scalable=no — block gesture events too.
    ['gesturestart', 'gesturechange', 'gestureend'].forEach(ev =>
      document.addEventListener(ev, e => e.preventDefault(), { passive: false })
    );
    // Double-tap-to-zoom: swallow it.
    let lastTouch = 0;
    document.addEventListener('touchend', e => {
      const now = Date.now();
      if (now - lastTouch <= 350) e.preventDefault();
      lastTouch = now;
    }, { passive: false });
  })();

  // === KID TODO CHECKBOXES (per-day localStorage) ===
  (function todoInit() {
    function todayKey() {
      // ET date string YYYY-MM-DD
      const parts = new Intl.DateTimeFormat('en-CA', {
        timeZone: 'America/New_York',
        year: 'numeric', month: '2-digit', day: '2-digit',
      }).formatToParts(new Date());
      const map = {};
      parts.forEach(p => map[p.type] = p.value);
      return map.year + '-' + map.month + '-' + map.day;
    }
    const date = todayKey();
    const STORAGE_KEY = 'kid-todos';

    // Load and prune stale dates
    let state = {};
    try { state = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}
    if (state.date !== date) state = { date, checks: {} };

    // --- Celebration helpers ---
    const ACCENTS = ['#d96a2a', '#2da44e', '#bf8700', '#cf222e', '#0969da', '#8250df'];

    function burstConfetti(cx, cy, count, power) {
      count = count || 16;
      power = power || 1;
      for (let i = 0; i < count; i++) {
        const piece = document.createElement('div');
        piece.className = 'confetti-piece';
        const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.6;
        const dist = (38 + Math.random() * 46) * power;
        const dx = Math.cos(angle) * dist;
        const dy = Math.sin(angle) * dist + (28 + Math.random() * 40) * power; // gravity bias
        piece.style.left = cx + 'px';
        piece.style.top = cy + 'px';
        piece.style.background = ACCENTS[i % ACCENTS.length];
        piece.style.setProperty('--dx', dx.toFixed(1) + 'px');
        piece.style.setProperty('--dy', dy.toFixed(1) + 'px');
        piece.style.setProperty('--rot', Math.round(Math.random() * 720 - 360) + 'deg');
        if (Math.random() > 0.5) piece.style.borderRadius = '50%';
        const sz = (6 + Math.random() * 6).toFixed(1) + 'px';
        piece.style.width = sz;
        piece.style.height = sz;
        document.body.appendChild(piece);
        piece.addEventListener('animationend', () => piece.remove(), { once: true });
      }
    }

    function centerOf(el) {
      const r = el.getBoundingClientRect();
      return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
    }

    // --- Sound (Web Audio, synthesized so there's no asset to host) ---
    let audioCtx = null;
    function ensureAudio() {
      if (!audioCtx) {
        const AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return null;
        audioCtx = new AC();
      }
      // iOS starts the context suspended; the tap that called us unlocks it.
      if (audioCtx.state === 'suspended') audioCtx.resume();
      return audioCtx;
    }
    function tone(freq, startOffset, dur, peak, type, partialGain) {
      const ctx = audioCtx;
      const t0 = ctx.currentTime + startOffset;
      const env = ctx.createGain();
      env.gain.setValueAtTime(0.0001, t0);
      env.gain.exponentialRampToValueAtTime(peak, t0 + 0.008);
      env.gain.exponentialRampToValueAtTime(0.0001, t0 + dur);
      env.connect(ctx.destination);
      const o1 = ctx.createOscillator();
      o1.type = type || 'sine';
      o1.frequency.value = freq;
      o1.connect(env);
      o1.start(t0);
      o1.stop(t0 + dur);
      // optional softer octave partial for extra shimmer
      const pg = partialGain == null ? 0.3 : partialGain;
      if (pg > 0) {
        const o2 = ctx.createOscillator();
        o2.type = type || 'sine';
        o2.frequency.value = freq * 2.0;
        const o2g = ctx.createGain();
        o2g.gain.value = pg;
        o2.connect(o2g).connect(env);
        o2.start(t0);
        o2.stop(t0 + dur);
      }
    }
    function playDing() {
      if (!ensureAudio()) return;
      // Same voice as the final note of the all-done fanfare (C6)
      try { tone(1046.50, 0, 0.60, 0.40); } catch (e) {}
    }
    function playFanfare() {
      if (!ensureAudio()) return;
      try {                                              // C-E-G-C major arpeggio
        tone(523.25, 0.00, 0.45, 0.34);
        tone(659.25, 0.10, 0.45, 0.34);
        tone(783.99, 0.20, 0.50, 0.34);
        tone(1046.50, 0.30, 0.60, 0.40);
      } catch (e) {}
    }

    function celebrate(box) {
      box.classList.add('just-checked');
      box.addEventListener('animationend', () => box.classList.remove('just-checked'), { once: true });

      const row = box.closest('.todo');
      if (row) {
        row.classList.add('celebrate');
        setTimeout(() => row.classList.remove('celebrate'), 700);
      }

      const c = centerOf(box);
      burstConfetti(c.x, c.y, 16, 1);

      // All of this kid's tasks done? Bigger party.
      const card = box.closest('.kid');
      const kidBoxes = card ? card.querySelectorAll('.todo input[type="checkbox"]') : [];
      const allDone = kidBoxes.length && [...kidBoxes].every(b => b.checked);
      if (allDone) {
        card.classList.add('all-done');
        setTimeout(() => card.classList.remove('all-done'), 800);
        const cc = centerOf(card);
        setTimeout(() => burstConfetti(cc.x, cc.y, 36, 1.6), 120);
        playFanfare();
      } else {
        playDing();
      }
    }

    const boxes = document.querySelectorAll('.todo input[type="checkbox"]');
    boxes.forEach(box => {
      const key = box.dataset.kid + '|' + box.dataset.id;
      if (state.checks[key]) box.checked = true;
      box.addEventListener('change', () => {
        if (box.checked) {
          state.checks[key] = true;
          celebrate(box);
        } else {
          delete state.checks[key];
        }
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      });
    });
    // Persist date roll-over even before any clicks
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  })();

  // === SUMMER READING TAP-TO-ADD (persists locally; resets when server pages catch up) ===
  (function readingInit() {
    const STORAGE_KEY = 'reading-local-adds';
    let store = {};
    try { store = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}

    function save() { localStorage.setItem(STORAGE_KEY, JSON.stringify(store)); }

    document.querySelectorAll('.reading-row').forEach(row => {
      const kid = row.dataset.kid;
      const base = parseInt(row.dataset.base, 10) || 0;
      const target = parseInt(row.dataset.target, 10) || 0;
      const pagesEl = row.querySelector('.reading-pages');
      const barEl = row.querySelector('.reading-bar');
      const editor = row.querySelector('.reading-editor');
      const input = row.querySelector('.reading-input');
      const addBtn = row.querySelector('.reading-add');
      const cancelBtn = row.querySelector('.reading-cancel');
      const resetBtn = row.querySelector('.reading-reset');

      // If server pages have caught up to (or past) the local add, drop the local delta.
      const rec = store[kid];
      if (rec && rec.serverBase != null && base >= rec.serverBase + rec.added) {
        delete store[kid];
        save();
      }

      function currentLocalAdd() {
        const r = store[kid];
        return r ? r.added : 0;
      }
      function render() {
        const total = base + currentLocalAdd();
        pagesEl.textContent = total;
        const pct = target > 0 ? Math.min(100, Math.round((total / target) * 100)) : 0;
        if (barEl) barEl.style.width = pct + '%';
      }
      function bump() {
        pagesEl.classList.remove('bumped');
        // restart animation
        void pagesEl.offsetWidth;
        pagesEl.classList.add('bumped');
      }

      render();

      function openEditor(ev) {
        if (ev) { ev.preventDefault(); ev.stopPropagation(); }
        if (row.classList.contains('editing')) return;
        row.classList.add('editing');
        editor.hidden = false;
        input.value = '';
        // tiny delay so iOS reliably focuses + opens the number keyboard
        setTimeout(() => { input.focus(); input.select(); }, 30);
      }
      function closeEditor() {
        row.classList.remove('editing');
        editor.hidden = true;
        input.value = '';
        if (resetBtn) {
          resetBtn.classList.remove('armed');
          resetBtn.textContent = '↺';
        }
      }
      function commit() {
        const n = parseInt(input.value, 10);
        if (!Number.isFinite(n) || n <= 0) { closeEditor(); return; }
        const prev = store[kid] || { serverBase: base, added: 0 };
        // If server base changed since last add, reset baseline
        if (prev.serverBase !== base) { prev.serverBase = base; prev.added = 0; }
        prev.added += n;
        store[kid] = prev;
        save();
        closeEditor();
        render();
        bump();
      }

      // Tap the count (or anywhere on the row when not editing) to open
      row.addEventListener('click', (e) => {
        if (row.classList.contains('editing')) return;
        // Ignore clicks on the editor itself if it somehow leaks through
        if (e.target.closest('.reading-editor')) return;
        openEditor(e);
      });

      addBtn.addEventListener('click', (e) => { e.stopPropagation(); commit(); });
      cancelBtn.addEventListener('click', (e) => { e.stopPropagation(); closeEditor(); });
      if (resetBtn) {
        resetBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          // Two-tap confirm so a kid can't wipe their pages by mistake.
          if (!resetBtn.classList.contains('armed')) {
            resetBtn.classList.add('armed');
            resetBtn.textContent = 'Sure?';
            return;
          }
          delete store[kid];
          save();
          closeEditor();
          render();
          bump();
        });
      }

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); commit(); }
        else if (e.key === 'Escape') { e.preventDefault(); closeEditor(); }
      });
      input.addEventListener('click', (e) => e.stopPropagation());
    });
  })();

  // === BUDGET STRIP ===
  function renderBudget() {
    const now = new Date();
    const dayOfMonth = now.getDate();
    const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
    const monthPct = Math.round((dayOfMonth / daysInMonth) * 100);
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    document.getElementById('budgetMonth').textContent = months[now.getMonth()] + ' · day ' + dayOfMonth + '/' + daysInMonth;

    document.querySelectorAll('.budget-cat').forEach(cat => {
      const key = cat.dataset.cat;
      const pct = parseInt(cat.dataset.pct, 10);
      const bar = document.getElementById('bar-' + key);
      const pace = document.getElementById('pace-' + key);
      const status = document.getElementById('status-' + key);

      bar.style.width = Math.min(pct, 100) + '%';
      pace.style.left = Math.min(monthPct, 100) + '%';

      // Color: green if ahead of pace, yellow if slightly behind, red if blown past 100
      if (pct >= 100) {
        bar.className = 'actual over';
        status.textContent = 'over';
        status.className = 'budget-status over';
      } else if (pct > monthPct + 8) {
        bar.className = 'actual warn';
        status.textContent = 'pacing high';
        status.className = 'budget-status';
      } else {
        bar.className = 'actual ok';
        status.textContent = 'on pace';
        status.className = 'budget-status';
      }
    });
  }
  renderBudget();

  // === WEEKEND MODE + CHORES CHECKLIST ===
  (function weekendMode() {
    const now = new Date();
    const dow = now.getDay(); // 0=Sun, 6=Sat
    const isWeekend = (dow === 0 || dow === 6);
    if (!isWeekend) return;

    // Compute weekend-of-month, anchored on Saturday.
    const satDate = new Date(now);
    if (dow === 0) satDate.setDate(now.getDate() - 1); // Sun → its Saturday
    const w = Math.min(4, Math.ceil(satDate.getDate() / 7));

    document.body.dataset.weekend = '1';
    document.body.dataset.wOfM = String(w);

    const pill = document.getElementById('choresWkPill');
    if (pill) {
      const labels = { 1: '1st weekend', 2: '2nd weekend', 3: '3rd weekend', 4: '4th weekend' };
      pill.textContent = labels[w] || ('Wk ' + w);
    }

    // Persist chore checks per weekend (Sat date as the key).
    const yyyy = satDate.getFullYear();
    const mm = String(satDate.getMonth() + 1).padStart(2, '0');
    const dd = String(satDate.getDate()).padStart(2, '0');
    const STORAGE_KEY = 'chores-' + yyyy + '-' + mm + '-' + dd;
    let state = {};
    try { state = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}

    // Garbage-collect old chore-* keys (keep only current weekend).
    try {
      for (let i = localStorage.length - 1; i >= 0; i--) {
        const k = localStorage.key(i);
        if (k && k.startsWith('chores-') && k !== STORAGE_KEY) localStorage.removeItem(k);
      }
    } catch {}

    function rowKey(id, slot) { return id + ':' + slot; }
    function updateRowStrike(item) {
      const boxes = item.querySelectorAll('input[type="checkbox"]');
      const allDone = Array.from(boxes).every(b => b.checked);
      item.classList.toggle('all-done', allDone);
    }

    document.querySelectorAll('.chore-item').forEach(item => {
      const id = item.dataset.id;
      item.querySelectorAll('input[type="checkbox"]').forEach(box => {
        const slot = box.dataset.slot;
        if (state[rowKey(id, slot)]) box.checked = true;
        box.addEventListener('change', () => {
          state[rowKey(id, slot)] = box.checked;
          if (!box.checked) delete state[rowKey(id, slot)];
          localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
          updateRowStrike(item);
        });
      });
      updateRowStrike(item);
    });
  })();

  // Invisible refresh tap target in bottom-right corner (for standalone PWA mode
  // where there's no pull-to-refresh or reload button)
  (function addRefreshTap() {
    const tap = document.createElement('div');
    tap.style.cssText = 'position:fixed;right:0;bottom:0;width:80px;height:80px;z-index:9999;cursor:pointer;';
    tap.addEventListener('click', () => location.reload());
    document.body.appendChild(tap);
  })();
</script>
