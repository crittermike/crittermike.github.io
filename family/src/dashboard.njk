---
layout: base.njk
title: Family Dashboard
permalink: "/dashboard/index.html"
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap');
  /* Wall-mounted Kindle Fire 10": no nav, no scroll */
  #site-nav { display: none !important; }
  html, body { overflow: hidden; height: 100%; }
  body { background: var(--warm-bg); }

  /* === LIGHT THEME OVERRIDE (dashboard only) === */
  :root {
    --warm-bg: #f5f1ea;
    --card-bg: #ffffff;
    --text-dark: #1f2328;
    --text-mid: #57606a;
    --text-light: #8b949e;
    --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.06);
    --shadow-hover: 0 2px 6px rgba(0,0,0,0.06), 0 8px 20px rgba(0,0,0,0.10);
    --accent-orange: #d96a2a;
    --accent-teal: #2da44e;
    --accent-gold: #bf8700;
    --accent-rose: #cf222e;
    --accent-blue: #0969da;
    --accent-purple: #8250df;
    /* Semantic surface/border vars (themed) */
    --border: #e3e6ea;
    --border-soft: #eef0f3;
    --input-border: #d0d4da;
    --surface: #ffffff;
    --surface-mute: rgba(0,0,0,0.025);
    --surface-mute-2: rgba(0,0,0,0.035);
    --surface-mute-3: rgba(0,0,0,0.05);
    --surface-mute-4: rgba(0,0,0,0.06);
    --surface-mute-track: rgba(0,0,0,0.04);
    --modal-overlay: rgba(15,20,28,0.55);
    --checkbox-border: #3a4250;
    --filter-bg: #f5f1ea;
    --pace-marker: #ffffff;
    --pace-marker-shadow: rgba(0,0,0,0.12);
    --on-accent: #ffffff;
    --reset-text: #b1273b;
    --reset-border: #e3b6bf;
    --reset-armed: #b1273b;
  }

  /* === DARK THEME (auto-switched after sunset by JS) === */
  :root[data-theme="dark"] {
    --warm-bg: #0f1217;
    --card-bg: #181c23;
    --text-dark: #f1f4fa;
    --text-mid: #d6dce6;
    --text-light: #a8b1bf;
    --shadow: 0 1px 3px rgba(0,0,0,0.45), 0 4px 14px rgba(0,0,0,0.55);
    --shadow-hover: 0 2px 6px rgba(0,0,0,0.55), 0 10px 24px rgba(0,0,0,0.65);
    /* Warmer accents that pop on dark without searing eyeballs */
    --accent-orange: #f08a55;
    --accent-teal: #4ac373;
    --accent-gold: #e0a93b;
    --accent-rose: #f06372;
    --accent-blue: #5aa9f5;
    --accent-purple: #b18cf5;
    --border: #2a313c;
    --border-soft: #232932;
    --input-border: #353d4a;
    --surface: #1f242c;
    --surface-mute: rgba(255,255,255,0.04);
    --surface-mute-2: rgba(255,255,255,0.06);
    --surface-mute-3: rgba(255,255,255,0.09);
    --surface-mute-4: rgba(255,255,255,0.12);
    --surface-mute-track: rgba(255,255,255,0.16);
    --modal-overlay: rgba(0,0,0,0.7);
    --checkbox-border: #6b7382;
    --filter-bg: #20262f;
    --pace-marker: #e6e9ef;
    --pace-marker-shadow: rgba(0,0,0,0.6);
    --on-accent: #0f1217;
    --reset-text: #f06372;
    --reset-border: #5a2b34;
    --reset-armed: #c44a5a;
  }

  /* Smooth the flip so it's not a jump-scare at sunset */
  html, body, .card, .kid, .budget, .cd-card, .modal, .topbar,
  .week-row, .cal-row, .hw-item, .todo, .cd-item, .reading-input,
  .cal-filter, .modal-close {
    transition: background-color 0.5s ease, color 0.4s ease, border-color 0.5s ease;
  }

  .dash {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 72px 155px 155px 1fr;
    grid-template-areas:
      "top    top    top    top"
      "today  cal    cal    new"
      "budget cal    cal    new"
      "kid1   kid2   kid3   kid4";
    gap: 10px;
    padding: 10px;
    height: 100vh;
    box-sizing: border-box;
  }

  /* === TOP BAR === */
  .topbar {
    grid-area: top;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px;
    padding: 0 4px;
    margin-top: 12px;
    overflow: hidden;
  }
  .fc-days { gap: 18px; }
  .clock-block {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .clock {
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    color: var(--accent-orange);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .date-inline {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1;
  }
  .date-inline .dow {
    color: var(--text-mid);
    margin-right: 6px;
  }
  .wordmark {
    font-family: 'Fraunces', 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: 2.1rem;
    letter-spacing: -0.5px;
    color: var(--text-dark);
    line-height: 1;
    font-feature-settings: 'ss01' on, 'ss02' on;
    white-space: nowrap;
  }
  .wordmark .crew {
    color: inherit;
  }

  .countdowns {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .countdown {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(45,164,78,0.14);
    border: 1px solid rgba(45,164,78,0.40);
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent-teal);
    white-space: nowrap;
  }
  .countdown .n { font-weight: 800; }
  .countdown .lbl { color: var(--text-dark); font-weight: 600; }

  .forecast {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-content: flex-end;
  }
  .fc-now {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-right: 18px;
    border-right: 1px solid var(--border);
  }
  .fc-now .icon { font-size: 1.5rem; }
  .fc-now .temp { font-size: 1.4rem; font-weight: 800; line-height: 1; }
  .fc-now .lo-hi { font-size: 0.72rem; color: var(--text-mid); font-weight: 600; line-height: 1; margin-top: 2px; }
  .fc-now .meta { display: flex; flex-direction: column; gap: 3px; }

  .fc-days { display: flex; gap: 14px; }
  .fc-day {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 44px;
  }
  .fc-day .d { font-size: 0.6rem; color: var(--text-mid); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; line-height: 1; }
  .fc-day .i { font-size: 0.95rem; line-height: 1; margin: 1px 0; }
  .fc-day .hi { font-size: 0.78rem; font-weight: 700; line-height: 1; }
  .fc-day .lo { font-size: 0.65rem; color: var(--text-mid); font-weight: 500; line-height: 1; }

  /* === SHARED CARD === */
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 0;
    box-shadow: var(--shadow);
  }
  .card-h {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    margin: 0 0 10px;
    font-weight: 700;
  }
  .card-h .h-action {
    background: var(--surface-mute-3);
    color: var(--text-dark);
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    cursor: pointer;
    border: none;
    text-transform: uppercase;
  }
  .card-h .h-action:hover, .card-h .h-action:active {
    background: var(--surface-mute-4);
  }

  /* === WEEK MEAL PLAN === */
  .today { grid-area: today; }
  .week-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;
  }
  .week-row {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 10px;
    align-items: center;
    padding: 6px 9px;
    border-radius: 7px;
    background: var(--surface-mute);
    cursor: pointer;
    transition: background 0.15s;
    min-height: 0;
  }
  .week-row:hover, .week-row:active { background: var(--surface-mute-3); }
  .week-row.today-row {
    background: rgba(217,106,42,0.12);
  }
  .week-row .dow {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .week-row.today-row .dow { color: var(--accent-orange); }
  .week-row .meal {
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text-dark);
  }
  .week-row.no-recipe { cursor: default; }
  .week-row.no-recipe:hover { background: var(--surface-mute); }
  .week-row.no-recipe.today-row:hover { background: rgba(217,106,42,0.12); }

  /* Today's dinner: hero block + tomorrow chip */
  .dinner-hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4px 0;
    cursor: pointer;
    min-height: 0;
  }
  .dinner-hero.no-recipe { cursor: default; }
  .dinner-hero .dinner-name {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-dark);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dinner-hero .dinner-tap {
    display: none;
  }
  .dinner-tomorrow {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 6px;
    cursor: pointer;
    min-width: 0;
  }
  .dinner-tomorrow.no-recipe { cursor: default; }
  .dinner-tomorrow .t-lbl {
    font-size: 0.55rem;
    font-weight: 700;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    flex-shrink: 0;
  }
  .dinner-tomorrow .t-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-width: 0;
  }

  /* === CALENDAR === */
  .cal { grid-area: cal; }
  .cal-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
  }
  .cal-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    align-items: center;
    padding: 6px 10px;
    border-radius: 7px;
    background: var(--surface-mute);
  }
  .cal-row.today-row {
    background: rgba(217,106,42,0.10);
  }
  .cal-row .when { font-weight: 700; color: var(--text-mid); font-size: 0.92rem; }
  .cal-row.today-row .when { color: var(--accent-orange); }
  .cal-row .what {
    font-size: 0.82rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cal-row .who {
    font-size: 0.62rem;
    background: var(--surface-mute-4);
    padding: 3px 9px;
    border-radius: 999px;
    color: var(--text-mid);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .cal-row .who.family    { background: rgba(217,106,42,0.16); color: var(--accent-orange); }
  .cal-row .who.nancy     { background: rgba(130,80,223,0.14); color: var(--accent-purple); }
  .cal-row .who.william   { background: rgba(45,164,78,0.16); color: var(--accent-teal); }
  .cal-row .who.henry     { background: rgba(9,105,218,0.14); color: var(--accent-blue); }
  .cal-row .who.charlie   { background: rgba(207,34,46,0.14); color: var(--accent-rose); }
  .cal-row .who.thomas    { background: rgba(191,135,0,0.16); color: var(--accent-gold); }
  .cal-row .who.parents   { background: rgba(130,80,223,0.14); color: var(--accent-purple); }
  .cal-row .who.mike      { background: rgba(45,164,78,0.16); color: var(--accent-teal); }

  /* === KID COLUMNS === */
  .kid {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
    min-height: 0;
  }
  .kid-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border-soft);
  }
  .kid-name { font-family: 'Fraunces', Georgia, serif; font-size: 1.5rem; font-weight: 600; letter-spacing: -0.3px; color: var(--text-dark); }
  .kid-meta { font-size: 0.68rem; color: var(--text-mid); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }

  .kid-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .kid .section { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .kid .section .lbl {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.9px;
    color: var(--text-mid);
    font-weight: 700;
  }

  .hw-item {
    font-size: 0.9rem;
    padding: 9px 11px;
    background: var(--surface-mute-2);
    border-radius: 7px;
    line-height: 1.3;
  }
  .hw-item.none {
    color: var(--text-mid);
    font-style: italic;
    font-size: 0.82rem;
    padding: 7px 11px;
  }
  .hw-item .due {
    display: block;
    font-size: 0.7rem;
    color: var(--text-mid);
    margin-top: 4px;
    font-style: normal;
  }
  .hw-item .progress {
    margin-top: 8px;
    height: 4px;
    background: var(--border-soft);
    border-radius: 2px;
    overflow: hidden;
  }
  .hw-item .progress .bar {
    height: 100%;
    background: var(--accent-orange);
    border-radius: 2px;
  }

  /* Tappable summer-reading row */
  .reading-row { cursor: pointer; -webkit-tap-highlight-color: transparent; }
  .reading-row.editing { cursor: default; }
  .reading-tap-hint {
    font-size: 0.62rem;
    color: var(--text-mid);
    margin-left: 6px;
    opacity: 0.7;
    font-style: italic;
  }
  .reading-row.editing .reading-count { display: none; }
  .reading-editor {
    display: flex;
    gap: 6px;
    align-items: center;
    margin-top: 2px;
  }
  .reading-editor[hidden] { display: none; }
  .reading-input {
    flex: 1 1 auto;
    min-width: 0;
    font-size: 1rem;
    padding: 7px 9px;
    border: 1px solid var(--input-border);
    border-radius: 6px;
    background: var(--surface);
    -webkit-appearance: none;
    appearance: none;
  }
  .reading-input::-webkit-outer-spin-button,
  .reading-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .reading-add, .reading-cancel, .reading-reset {
    font-size: 0.85rem;
    padding: 7px 11px;
    border-radius: 6px;
    border: 1px solid var(--input-border);
    background: var(--surface);
    cursor: pointer;
    line-height: 1;
  }
  .reading-add {
    background: var(--accent-orange);
    color: var(--on-accent);
    border-color: var(--accent-orange);
    font-weight: 600;
  }
  .reading-reset {
    color: var(--reset-text);
    border-color: var(--reset-border);
  }
  .reading-reset.armed {
    background: var(--reset-armed);
    color: var(--on-accent);
    border-color: var(--reset-armed);
    font-weight: 600;
  }
  .reading-pages.bumped {
    animation: readingBump 600ms ease;
    color: var(--accent-orange);
  }
  @keyframes readingBump {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.25); }
    100% { transform: scale(1); }
  }

  /* Today's to-do checkboxes */
  .todo-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .todo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    padding: 7px 10px;
    background: var(--surface-mute-2);
    border-radius: 7px;
    cursor: pointer;
    user-select: none;
  }
  .todo input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border: 2px solid var(--checkbox-border);
    border-radius: 5px;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    margin: 0;
  }
  .todo input[type="checkbox"]:checked {
    background: var(--accent-teal);
    border-color: var(--accent-teal);
  }
  .todo input[type="checkbox"]:checked::after {
    content: "✓";
    position: absolute;
    inset: 0;
    color: var(--on-accent);
    font-size: 16px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .todo input[type="checkbox"]:checked + .todo-label {
    text-decoration: line-through;
    color: var(--text-mid);
  }
  .todo-label { flex: 1; color: var(--text-dark); }

  /* === CHECKBOX CELEBRATION === */
  /* Box pop + checkmark draw only fire on real user interaction (JS adds
     .just-checked), so localStorage-restored checks don't animate on load. */
  .todo input[type="checkbox"].just-checked {
    animation: box-pop 0.45s cubic-bezier(.2,1.3,.4,1);
  }
  @keyframes box-pop {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.4); }
    65%  { transform: scale(0.85); }
    100% { transform: scale(1); }
  }
  .todo input[type="checkbox"].just-checked::after {
    animation: check-in 0.45s cubic-bezier(.2,1.3,.4,1);
    transform-origin: center;
  }
  @keyframes check-in {
    0%   { transform: scale(0) rotate(-25deg); opacity: 0; }
    55%  { transform: scale(1.35) rotate(10deg); opacity: 1; }
    100% { transform: scale(1) rotate(0); opacity: 1; }
  }
  .todo.celebrate {
    animation: row-celebrate 0.7s ease;
  }
  @keyframes row-celebrate {
    0%   { background: var(--surface-mute-2); }
    25%  { background: rgba(45,164,78,0.30); box-shadow: 0 0 0 2px rgba(45,164,78,0.45); }
    100% { background: var(--surface-mute-2); box-shadow: none; }
  }

  /* All of a kid's tasks done → pulse the whole card */
  .kid.all-done {
    animation: kid-all-done 0.8s ease;
  }
  @keyframes kid-all-done {
    0%   { transform: scale(1); }
    30%  { transform: scale(1.025); box-shadow: 0 0 0 3px rgba(45,164,78,0.55), var(--shadow); }
    100% { transform: scale(1); box-shadow: var(--shadow); }
  }

  /* Confetti particles (spawned + removed by JS, fixed-position) */
  .confetti-piece {
    position: fixed;
    top: 0;
    left: 0;
    width: 9px;
    height: 9px;
    z-index: 9999;
    pointer-events: none;
    will-change: transform, opacity;
    transform: translate(-50%, -50%);
    animation: confetti-fly 0.85s cubic-bezier(.15,.6,.4,1) forwards;
  }
  @keyframes confetti-fly {
    0%   { opacity: 1; transform: translate(-50%, -50%) translate(0, 0) rotate(0); }
    100% { opacity: 0; transform: translate(-50%, -50%) translate(var(--dx), var(--dy)) rotate(var(--rot)); }
  }

  .stat-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .stat-num {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--accent-teal);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .stat-num.warn { color: var(--accent-gold); }
  .stat-num.danger { color: var(--accent-rose); }
  .stat-sub { font-size: 0.75rem; color: var(--text-mid); font-weight: 500; margin-left: auto; }

  /* === MODAL === */
  .modal-bg {
    position: fixed;
    inset: 0;
    background: var(--modal-overlay);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .modal-bg.open { display: flex; }
  /* Anchor specific modals to the top so on-screen keyboard doesn't cover them
     when filtering shrinks the content. */
  #calModal.modal-bg { align-items: flex-start; padding-top: 24px; }
  .modal {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    max-width: 1100px;
    width: 100%;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .modal.modal-recipe { max-width: 1100px; }
  .modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 22px;
    border-bottom: 1px solid var(--border-soft);
  }
  .modal-head h2 { font-size: 1.4rem; font-weight: 800; margin: 0; }
  .modal-close {
    background: var(--surface-mute-4);
    border: none;
    color: var(--text-dark);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 1.2rem;
    cursor: pointer;
    font-weight: 700;
  }
  .modal-body {
    padding: 18px 22px 22px;
    overflow-y: auto;
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .modal-body h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-mid);
    margin: 14px 0 8px;
  }
  .modal-body h3:first-child { margin-top: 0; }
  .modal-body ul, .modal-body ol { padding-left: 22px; margin: 0; }
  .modal-body li { margin-bottom: 6px; }
  .modal-body .meta {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--text-mid);
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-soft);
  }
  .modal-body .meta b { color: var(--text-dark); font-weight: 700; }

  /* Recipe two-column layout */
  .recipe-cols {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(0, 2fr);
    gap: 24px;
    align-items: start;
  }
  .recipe-col h3 {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-mid);
    margin: 0 0 10px;
  }
  .recipe-col ul, .recipe-col ol {
    padding-left: 22px;
    margin: 0;
  }
  .recipe-col li {
    margin-bottom: 8px;
    line-height: 1.45;
  }
  .recipe-col .group-h {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-mid);
    margin: 12px 0 6px;
    font-weight: 700;
  }
  .recipe-col .group-h:first-child { margin-top: 0; }
  .recipe-empty {
    color: var(--text-mid);
    font-style: italic;
    font-size: 0.88rem;
  }
  .recipe-notes {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--border-soft);
    font-size: 0.88rem;
    color: var(--text-mid);
  }
  @media (max-width: 720px) {
    .recipe-cols { grid-template-columns: 1fr; gap: 18px; }
  }

  /* Calendar expanded modal */
  .cal-filter {
    width: 100%;
    background: var(--filter-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-dark);
    padding: 10px 14px;
    font-size: 0.95rem;
    margin-bottom: 14px;
    box-sizing: border-box;
  }
  .cal-filter:focus { outline: none; border-color: var(--accent-orange); }
  .cal-full-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cal-full-list .cal-row { padding: 8px 12px; }
  .cal-full-list .cal-row .what { font-size: 0.9rem; }
  .cal-month-h {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-mid);
    font-weight: 700;
    margin: 14px 0 4px;
    padding-left: 4px;
  }
  .cal-month-h:first-child { margin-top: 0; }
  .cal-bucket-h {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-dark);
    font-weight: 700;
    margin: 12px 0 4px;
    padding: 6px 4px 2px;
    border-top: 1px solid var(--border-soft);
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .cal-bucket-h:first-child { margin-top: 0; padding-top: 0; border-top: none; }
  .cal-bucket-h .cal-bucket-count {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--text-light);
    letter-spacing: 0.5px;
  }
  .cal-bucket-h.today { color: var(--accent-orange); }

  /* === BUDGET STRIP (compact, stacks under meal block) === */
  .budget {
    grid-area: budget;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 8px 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
  }
  .budget-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-shrink: 0;
  }
  .budget-h {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    font-weight: 700;
  }
  .budget-month {
    font-size: 0.6rem;
    color: var(--text-mid);
    font-weight: 600;
  }
  .budget-cats {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    justify-content: space-around;
  }
  .budget-cat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .budget-cat .name {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .budget-cat .name .budget-status {
    font-size: 0.55rem;
    font-weight: 600;
    color: var(--text-mid);
    text-transform: none;
    letter-spacing: 0;
  }
  .budget-cat .name .budget-status.over { color: var(--accent-rose); }
  .budget-bars {
    position: relative;
    height: 10px;
    background: var(--surface-mute-track);
    border-radius: 4px;
    overflow: visible;
  }
  .budget-bars .actual {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    border-radius: 4px;
    transition: width 0.4s;
  }
  .budget-bars .actual.ok    { background: var(--accent-teal); }
  .budget-bars .actual.warn  { background: var(--accent-gold); }
  .budget-bars .actual.over  { background: var(--accent-rose); }
  .budget-bars .pace {
    position: absolute;
    top: -3px;
    height: calc(100% + 6px);
    width: 2px;
    background: var(--pace-marker);
    border-radius: 1px;
    box-shadow: 0 0 0 1px var(--pace-marker-shadow);
    transform: translateX(-1px);
  }
  .budget-bars .pace::after { display: none; }

  /* === COUNTDOWNS CARD === */
  .cd-card {
    grid-area: new;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px 14px;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }
  .cd-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow: hidden;
  }
  .cd-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    background: var(--surface-mute);
    border-radius: 10px;
    min-height: 0;
  }
  .cd-item .n {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--accent-orange);
    font-variant-numeric: tabular-nums;
    min-width: 1.6em;
    text-align: right;
    flex-shrink: 0;
  }
  .cd-item .lbl {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1.2;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    word-break: break-word;
  }
  .cd-item .lbl .unit {
    color: var(--text-mid);
    font-weight: 500;
    font-size: 0.72rem;
    margin-right: 4px;
  }
  .cd-item.is-today .n { color: var(--accent-teal); font-size: 1.2rem; }

  /* Grid assignments */
  .kid1 { grid-area: kid1; }
  .kid2 { grid-area: kid2; }
  .kid3 { grid-area: kid3; }
  .kid4 { grid-area: kid4; }

  /* === MOBILE (phones, sub-768px) ===
     Tablet layout untouched. Phone: scroll, single column, stack everything.
  */
  @media (max-width: 767px) {
    html, body { overflow: auto; height: auto; }

    .dash {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      grid-template-areas:
        "top"
        "today"
        "cal"
        "budget"
        "kid1"
        "kid2"
        "kid3"
        "kid4"
        "new";
      height: auto;
      min-height: 100vh;
      gap: 8px;
      padding: 8px;
    }

    /* Top bar: stack clock, weather, forecast vertically */
    .topbar {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 10px 14px;
    }
    .clock-block { justify-content: space-between; }
    .clock { font-size: 2rem; }
    .forecast {
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .fc-now { padding-right: 12px; }
    .fc-days { gap: 10px; flex-wrap: wrap; }
    .fc-day { min-width: 38px; }

    /* Cards: don't cap height, let content size */
    .card, .kid, .budget {
      overflow: visible;
      min-height: 0;
    }

    /* Calendar: tighten when columns shrink */
    .cal-row { grid-template-columns: 72px 1fr; gap: 8px; }
    .cal-row .what { white-space: normal; }

    /* Kid columns: ease up on font sizes */
    .kid-name { font-size: 1.15rem; }
    .stat-num { font-size: 1.5rem; }

    /* Dinner */
    .dinner-name { font-size: 1.2rem; }

    /* Modals: full-width on phone */
    .modal-bg { padding: 12px; }
    .modal { max-height: 95vh; }
    .modal-head { padding: 12px 16px; }
    .modal-body { padding: 14px 16px 18px; }
  }

  /* ============================================================
     WEEKEND MODE (Sat/Sun) — toggled by JS via body[data-weekend="1"]
     ============================================================ */

  /* Default: weekend-only blocks hidden */
  .kids-mini, .chores, .newish { display: none; }

  body[data-weekend="1"] .dash {
    grid-template-columns: 1.05fr 1.5fr 1.55fr;
    grid-template-rows: 72px 1fr 1fr 1fr;
    grid-template-areas:
      "top    top    top"
      "kmini  cal    chores"
      "budget cal    chores"
      "cdown  newish newish";
  }

  /* Hide weekday-only blocks */
  body[data-weekend="1"] .today,
  body[data-weekend="1"] .kid { display: none; }

  body[data-weekend="1"] .kids-mini { grid-area: kmini;  display: flex; }
  body[data-weekend="1"] .budget    { grid-area: budget; }
  body[data-weekend="1"] .cd-card   { grid-area: cdown; }
  body[data-weekend="1"] .cal       { grid-area: cal; }
  body[data-weekend="1"] .chores    { grid-area: chores; display: flex; align-self: stretch; max-height: 100%; }
  body[data-weekend="1"] .newish    { grid-area: newish; display: flex; }

  /* === NEWISH placeholder tile === */
  .newish {
    background: var(--card-bg);
    border: 1px dashed var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    box-shadow: var(--shadow);
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    gap: 8px;
  }
  .newish .card-h {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-mid);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .newish .newish-sub {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-light);
    font-weight: 600;
  }
  .newish .newish-body {
    font-size: 0.9rem;
    color: var(--text-light);
    font-style: italic;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    text-align: center;
  }

  /* === KIDS-MINI combined tile === */
  .kids-mini {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 12px 14px 14px;
    box-shadow: var(--shadow);
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }
  .kids-mini .card-h {
    margin: 0 0 8px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-mid);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .kids-mini-grid {
    display: grid;
    grid-template-columns: 1fr auto auto;
    column-gap: 16px;
    row-gap: 8px;
    align-items: baseline;
  }
  .kids-mini-grid .km-head {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-light);
    font-weight: 700;
  }
  .kids-mini-grid .km-head.right { text-align: right; }
  .kids-mini-grid .km-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-dark);
  }
  .kids-mini-grid .km-val {
    font-size: 1.05rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    text-align: right;
    color: var(--text-dark);
  }
  .kids-mini-grid .km-val.danger { color: var(--accent-rose); }
  .kids-mini-grid .km-val.warn   { color: var(--accent-gold); }

  /* === CHORES card === */
  .chores {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 18px 16px;
    box-shadow: var(--shadow);
    flex-direction: column;
    min-height: 0;
    height: 100%;
    overflow: hidden;
  }
  .chores .card-h {
    margin: 0 0 10px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-mid);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-shrink: 0;
  }
  .chores .card-h .wk-pill {
    background: var(--surface-mute-3);
    color: var(--text-dark);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .chores-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 22px;
    row-gap: 4px;
    overflow: hidden;
    min-height: 0;
    flex: 1;
    align-content: start;
  }
  .chores-col {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .chores-col-h {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.55rem;
    font-weight: 700;
    color: var(--accent-orange);
    line-height: 1;
    margin: 2px 0 10px;
    letter-spacing: -0.5px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    flex-shrink: 0;
  }
  .chores-groups {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    gap: 24px;
  }
  .chores-group {
    margin: 0;
    display: flex;
    flex-direction: column;
    flex: 0 0 auto;
    min-height: 0;
  }
  .chores-group-h {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-light);
    font-weight: 800;
    margin: 0 0 10px;
  }
  .chores-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .chore-item { display: flex; align-items: center; gap: 12px; line-height: 1.25; }
  .chore-checks {
    display: inline-flex;
    gap: 3px;
    flex-shrink: 0;
  }
  .chore-checks input[type="checkbox"] {
    width: 22px; height: 22px;
    margin: 0; padding: 0;
    accent-color: var(--accent-teal);
    cursor: pointer;
  }
  .chore-label {
    flex: 1;
    font-size: 0.82rem;
    color: var(--text-dark);
    font-weight: 500;
    min-width: 0;
    line-height: 1.3;
  }
  /* Strike when ALL boxes for that row are checked */
  .chore-item.all-done .chore-label {
    text-decoration: line-through;
    color: var(--text-light);
  }

  /* === Weekend monthly section visibility === */
  .chores-monthly { display: none; }
  body[data-w-of-m="1"] .chores-monthly[data-n="1"],
  body[data-w-of-m="2"] .chores-monthly[data-n="2"],
  body[data-w-of-m="3"] .chores-monthly[data-n="3"],
  body[data-w-of-m="4"] .chores-monthly[data-n="4"],
  body[data-w-of-m="5"] .chores-monthly[data-n="4"] { display: flex; }

  /* === Weekend phone fallback === */
  @media (max-width: 767px) {
    body[data-weekend="1"] .dash {
      grid-template-columns: 1fr;
      grid-template-areas:
        "top"
        "kmini"
        "cal"
        "chores"
        "budget"
        "cdown";
    }
    body[data-weekend="1"] .chores-body { grid-template-columns: 1fr; }
  }
</style>

<div class="dash">

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="wordmark">Critter <span class="crew">Crew</span></div>
    <div></div>
    <div class="forecast">
      {% if weather %}
      <div class="fc-now">
        <span class="icon">{{ weather.now.icon }}</span>
        <div class="meta">
          <span class="temp">{{ weather.now.temp }}°</span>
          <span class="lo-hi">L {{ weather.now.lo }}° · H {{ weather.now.hi }}°</span>
        </div>
      </div>
      <div class="fc-days">
        {% for day in weather.days %}
        <div class="fc-day"><span class="d">{{ day.d }}</span><span class="i">{{ day.icon }}</span><span class="hi">{{ day.hi }}°</span><span class="lo">{{ day.lo }}°</span></div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>

  <!-- KIDS MINI (weekend only): combined sugar + allowance tile -->
  <div class="kids-mini">
    <div class="kids-mini-grid">
      <div class="km-head">Name</div>
      <div class="km-head right">Sugar</div>
      <div class="km-head right">Allowance</div>
      {% for kid in kids %}
        <div class="km-name">{{ kid.name }}</div>
        {% if kid.sugar.balance is not none %}
          {% set neg = kid.sugar.balance < 0 %}
          {% set low = kid.sugar.balance >= 0 and kid.sugar.balance < kid.sugar.refill * 0.5 %}
          <div class="km-val{% if neg %} danger{% elif low %} warn{% endif %}">{{ kid.sugar.balance }}g</div>
        {% else %}
          <div class="km-val" style="color: var(--text-light);">—</div>
        {% endif %}
        {% if kid.allowance.balance_str %}
          {% set negA = '-' in kid.allowance.balance_str %}
          <div class="km-val{% if negA %} danger{% endif %}">{{ kid.allowance.balance_str }}</div>
        {% else %}
          <div class="km-val" style="color: var(--text-light);">—</div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- CHORES (weekend only): always-on quick clean / laundry + monthly rotation -->
  <div class="chores">
    <div class="card-h">
      <span>🧹 Weekend chores</span>
      <span class="wk-pill" id="choresWkPill">Wk —</span>
    </div>
    <div class="chores-body">
      <div class="chores-col">
        <div class="chores-col-h">Saturday</div>
        <div class="chores-groups">
        <div class="chores-group">
          <div class="chores-group-h">{{ chores.quick.title }}</div>
          <ul class="chores-list">
            {% for item in chores.quick.items %}
            <li class="chore-item" data-id="{{ item.id }}">
              <span class="chore-checks">
                <input type="checkbox" data-chore="{{ item.id }}" data-slot="0">
              </span>
              <span class="chore-label">{{ item.label }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% for m in chores.monthly %}
        <div class="chores-monthly chores-group" data-n="{{ m.n }}">
          <div class="chores-group-h">{{ m.sat.title }}</div>
          <ul class="chores-list">
            {% for item in m.sat.items %}
            <li class="chore-item" data-id="{{ item.id }}">
              <span class="chore-checks">
                <input type="checkbox" data-chore="{{ item.id }}" data-slot="0">
              </span>
              <span class="chore-label">{{ item.label }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
        </div>
      </div>
      <div class="chores-col">
        <div class="chores-col-h">Sunday</div>
        <div class="chores-groups">
        <div class="chores-group">
          <div class="chores-group-h">{{ chores.laundry.title }}</div>
          <ul class="chores-list">
            {% for item in chores.laundry.items %}
            <li class="chore-item" data-id="{{ item.id }}">
              <span class="chore-checks">
                <input type="checkbox" data-chore="{{ item.id }}" data-slot="0">
              </span>
              <span class="chore-label">{{ item.label }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% for m in chores.monthly %}
        <div class="chores-monthly chores-group" data-n="{{ m.n }}">
          <div class="chores-group-h">{{ m.sun.title }}</div>
          <ul class="chores-list">
            {% for item in m.sun.items %}
            <li class="chore-item" data-id="{{ item.id }}">
              <span class="chore-checks">
                <input type="checkbox" data-chore="{{ item.id }}" data-slot="0">
              </span>
              <span class="chore-label">{{ item.label }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <!-- NEWISH (weekend only): placeholder for new bottom block -->
  <div class="newish">
    <div class="card-h">
      <span>✨ New block</span>
      <span class="newish-sub">pick one: dinner · weekend goal · sports · read-aloud</span>
    </div>
    <div class="newish-body">
      Mike — pick what goes here and I'll wire it up.
    </div>
  </div>

