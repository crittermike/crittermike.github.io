---
layout: base.njk
title: Family Dashboard
permalink: "/dashboard/index.html"
---

<style>
  /* Wall-mounted Kindle Fire 10": no nav, no scroll */
  #site-nav { display: none !important; }
  html, body { overflow: hidden; height: 100%; }
  body { background: var(--warm-bg); }

  .dash {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 72px 155px 155px 1fr;
    grid-template-areas:
      "top    top    top    top"
      "today  cal    cal    new"
      "budget cal    cal    new"
      "kid1   kid2   kid3   kid4";
    gap: 10px;
    padding: 10px;
    height: 100vh;
    box-sizing: border-box;
  }

  /* === TOP BAR === */
  .topbar {
    grid-area: top;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px;
    padding: 0 4px;
    overflow: hidden;
  }
  .fc-days { gap: 18px; }
  .clock-block {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .clock {
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    color: var(--accent-orange);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .date-inline {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1;
  }
  .date-inline .dow {
    color: var(--text-mid);
    margin-right: 6px;
  }
  .countdowns {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .countdown {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(63,185,80,0.16);
    border: 1px solid rgba(63,185,80,0.35);
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent-teal);
    white-space: nowrap;
  }
  .countdown .n { font-weight: 800; }
  .countdown .lbl { color: var(--text-dark); font-weight: 600; }

  .forecast {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-content: flex-end;
  }
  .fc-now {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-right: 18px;
    border-right: 1px solid #30363d;
  }
  .fc-now .icon { font-size: 1.5rem; }
  .fc-now .temp { font-size: 1.4rem; font-weight: 800; line-height: 1; }
  .fc-now .lo-hi { font-size: 0.72rem; color: var(--text-mid); font-weight: 600; line-height: 1; margin-top: 2px; }
  .fc-now .meta { display: flex; flex-direction: column; gap: 3px; }

  .fc-days { display: flex; gap: 14px; }
  .fc-day {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 44px;
  }
  .fc-day .d { font-size: 0.6rem; color: var(--text-mid); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; line-height: 1; }
  .fc-day .i { font-size: 0.95rem; line-height: 1; margin: 1px 0; }
  .fc-day .hi { font-size: 0.78rem; font-weight: 700; line-height: 1; }
  .fc-day .lo { font-size: 0.65rem; color: var(--text-mid); font-weight: 500; line-height: 1; }

  /* === SHARED CARD === */
  .card {
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 14px 16px 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .card-h {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    margin: 0 0 10px;
    font-weight: 700;
  }
  .card-h .h-action {
    background: rgba(255,255,255,0.06);
    color: var(--text-dark);
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    cursor: pointer;
    border: none;
    text-transform: uppercase;
  }
  .card-h .h-action:hover, .card-h .h-action:active {
    background: rgba(255,255,255,0.12);
  }

  /* === WEEK MEAL PLAN === */
  .today { grid-area: today; }
  .week-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;
  }
  .week-row {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 10px;
    align-items: center;
    padding: 6px 9px;
    border-radius: 7px;
    background: rgba(255,255,255,0.02);
    cursor: pointer;
    transition: background 0.15s;
    min-height: 0;
  }
  .week-row:hover, .week-row:active { background: rgba(255,255,255,0.06); }
  .week-row.today-row {
    background: rgba(232,131,74,0.14);
  }
  .week-row .dow {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .week-row.today-row .dow { color: var(--accent-orange); }
  .week-row .meal {
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text-dark);
  }
  .week-row.no-recipe { cursor: default; }
  .week-row.no-recipe:hover { background: rgba(255,255,255,0.02); }
  .week-row.no-recipe.today-row:hover { background: rgba(232,131,74,0.14); }

  /* Today's dinner: hero block + tomorrow chip */
  .dinner-hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4px 0;
    cursor: pointer;
    min-height: 0;
  }
  .dinner-hero.no-recipe { cursor: default; }
  .dinner-hero .dinner-name {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-dark);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dinner-hero .dinner-tap {
    display: none;
  }
  .dinner-tomorrow {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 6px;
    cursor: pointer;
    min-width: 0;
  }
  .dinner-tomorrow.no-recipe { cursor: default; }
  .dinner-tomorrow .t-lbl {
    font-size: 0.55rem;
    font-weight: 700;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    flex-shrink: 0;
  }
  .dinner-tomorrow .t-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-width: 0;
  }

  /* === CALENDAR === */
  .cal { grid-area: cal; }
  .cal-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
  }
  .cal-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    align-items: center;
    padding: 6px 10px;
    border-radius: 7px;
    background: rgba(255,255,255,0.02);
  }
  .cal-row.today-row {
    background: rgba(232,131,74,0.12);
  }
  .cal-row .when { font-weight: 700; color: var(--text-mid); font-size: 0.92rem; }
  .cal-row.today-row .when { color: var(--accent-orange); }
  .cal-row .what {
    font-size: 1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cal-row .who {
    font-size: 0.62rem;
    background: rgba(255,255,255,0.08);
    padding: 3px 9px;
    border-radius: 999px;
    color: var(--text-mid);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .cal-row .who.family    { background: rgba(232,131,74,0.2); color: var(--accent-orange); }
  .cal-row .who.nancy     { background: rgba(188,140,255,0.18); color: var(--accent-purple); }
  .cal-row .who.william   { background: rgba(63,185,80,0.18); color: var(--accent-teal); }
  .cal-row .who.henry     { background: rgba(88,166,255,0.18); color: var(--accent-blue); }
  .cal-row .who.charlie   { background: rgba(248,81,73,0.18); color: var(--accent-rose); }
  .cal-row .who.thomas    { background: rgba(210,153,34,0.2); color: var(--accent-gold); }
  .cal-row .who.parents   { background: rgba(188,140,255,0.18); color: var(--accent-purple); }
  .cal-row .who.mike      { background: rgba(63,185,80,0.18); color: var(--accent-teal); }

  /* === KID COLUMNS === */
  .kid {
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
    min-height: 0;
  }
  .kid-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 6px;
    border-bottom: 1px solid #21262d;
  }
  .kid-name { font-size: 1.3rem; font-weight: 800; letter-spacing: -0.3px; color: var(--text-dark); }
  .kid-meta { font-size: 0.68rem; color: var(--text-mid); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }

  .kid-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .kid .section { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .kid .section .lbl {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.9px;
    color: var(--text-mid);
    font-weight: 700;
  }

  .hw-item {
    font-size: 0.9rem;
    padding: 9px 11px;
    background: rgba(255,255,255,0.03);
    border-radius: 7px;
    line-height: 1.3;
  }
  .hw-item.none {
    color: var(--text-mid);
    font-style: italic;
    font-size: 0.82rem;
    padding: 7px 11px;
  }
  .hw-item .due {
    display: block;
    font-size: 0.7rem;
    color: var(--text-mid);
    margin-top: 4px;
    font-style: normal;
  }
  .hw-item .progress {
    margin-top: 8px;
    height: 4px;
    background: #21262d;
    border-radius: 2px;
    overflow: hidden;
  }
  .hw-item .progress .bar {
    height: 100%;
    background: var(--accent-orange);
    border-radius: 2px;
  }

  /* Today's to-do checkboxes */
  .todo-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .todo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1rem;
    padding: 7px 10px;
    background: rgba(255,255,255,0.03);
    border-radius: 7px;
    cursor: pointer;
    user-select: none;
  }
  .todo input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border: 2px solid #3a4250;
    border-radius: 5px;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    margin: 0;
  }
  .todo input[type="checkbox"]:checked {
    background: var(--accent-teal);
    border-color: var(--accent-teal);
  }
  .todo input[type="checkbox"]:checked::after {
    content: "✓";
    position: absolute;
    inset: 0;
    color: #fff;
    font-size: 16px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .todo input[type="checkbox"]:checked + .todo-label {
    text-decoration: line-through;
    color: var(--text-mid);
  }
  .todo-label { flex: 1; color: var(--text-dark); }

  .stat-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .stat-num {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--accent-teal);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .stat-num.warn { color: var(--accent-gold); }
  .stat-num.danger { color: var(--accent-rose); }
  .stat-sub { font-size: 0.75rem; color: var(--text-mid); font-weight: 500; margin-left: auto; }

  /* === MODAL === */
  .modal-bg {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .modal-bg.open { display: flex; }
  .modal {
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 16px;
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 22px;
    border-bottom: 1px solid #21262d;
  }
  .modal-head h2 { font-size: 1.4rem; font-weight: 800; margin: 0; }
  .modal-close {
    background: rgba(255,255,255,0.08);
    border: none;
    color: var(--text-dark);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 1.2rem;
    cursor: pointer;
    font-weight: 700;
  }
  .modal-body {
    padding: 18px 22px 22px;
    overflow-y: auto;
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .modal-body h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-mid);
    margin: 14px 0 8px;
  }
  .modal-body h3:first-child { margin-top: 0; }
  .modal-body ul, .modal-body ol { padding-left: 22px; margin: 0; }
  .modal-body li { margin-bottom: 6px; }
  .modal-body .meta {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--text-mid);
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid #21262d;
  }
  .modal-body .meta b { color: var(--text-dark); font-weight: 700; }

  /* Calendar expanded modal */
  .cal-filter {
    width: 100%;
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 8px;
    color: var(--text-dark);
    padding: 10px 14px;
    font-size: 0.95rem;
    margin-bottom: 14px;
    box-sizing: border-box;
  }
  .cal-filter:focus { outline: none; border-color: var(--accent-orange); }
  .cal-full-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cal-full-list .cal-row { padding: 8px 12px; }
  .cal-full-list .cal-row .what { font-size: 0.9rem; }
  .cal-month-h {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-mid);
    font-weight: 700;
    margin: 14px 0 4px;
    padding-left: 4px;
  }
  .cal-month-h:first-child { margin-top: 0; }

  /* === BUDGET STRIP (compact, stacks under meal block) === */
  .budget {
    grid-area: budget;
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 8px 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
  }
  .budget-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-shrink: 0;
  }
  .budget-h {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    font-weight: 700;
  }
  .budget-month {
    font-size: 0.6rem;
    color: var(--text-mid);
    font-weight: 600;
  }
  .budget-cats {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    justify-content: space-around;
  }
  .budget-cat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .budget-cat .name {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .budget-cat .name .budget-status {
    font-size: 0.55rem;
    font-weight: 600;
    color: var(--text-mid);
    text-transform: none;
    letter-spacing: 0;
  }
  .budget-cat .name .budget-status.over { color: var(--accent-rose); }
  .budget-bars {
    position: relative;
    height: 10px;
    background: rgba(255,255,255,0.04);
    border-radius: 4px;
    overflow: visible;
  }
  .budget-bars .actual {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    border-radius: 4px;
    transition: width 0.4s;
  }
  .budget-bars .actual.ok    { background: var(--accent-teal); }
  .budget-bars .actual.warn  { background: var(--accent-gold); }
  .budget-bars .actual.over  { background: var(--accent-rose); }
  .budget-bars .pace {
    position: absolute;
    top: -3px;
    height: calc(100% + 6px);
    width: 2px;
    background: #ffffff;
    border-radius: 1px;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.6);
    transform: translateX(-1px);
  }
  .budget-bars .pace::after { display: none; }

  /* === NEW BLOCK PLACEHOLDER === */
  .new-block {
    grid-area: new;
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow: hidden;
  }
  .new-block-h {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    font-weight: 700;
  }
  .new-block-body {
    font-size: 0.85rem;
    color: var(--text-mid);
  }

  /* Grid assignments */
  .kid1 { grid-area: kid1; }
  .kid2 { grid-area: kid2; }
  .kid3 { grid-area: kid3; }
  .kid4 { grid-area: kid4; }

  /* === MOBILE (phones, sub-768px) ===
     Tablet layout untouched. Phone: scroll, single column, stack everything.
  */
  @media (max-width: 767px) {
    html, body { overflow: auto; height: auto; }

    .dash {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      grid-template-areas:
        "top"
        "today"
        "cal"
        "budget"
        "kid1"
        "kid2"
        "kid3"
        "kid4";
      height: auto;
      min-height: 100vh;
      gap: 8px;
      padding: 8px;
    }

    /* Top bar: stack clock, weather, forecast vertically */
    .topbar {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 10px 14px;
    }
    .clock-block { justify-content: space-between; }
    .clock { font-size: 2rem; }
    .forecast {
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .fc-now { padding-right: 12px; }
    .fc-days { gap: 10px; flex-wrap: wrap; }
    .fc-day { min-width: 38px; }

    /* Cards: don't cap height, let content size */
    .card, .kid, .budget {
      overflow: visible;
      min-height: 0;
    }

    /* Calendar: tighten when columns shrink */
    .cal-row { grid-template-columns: 72px 1fr; gap: 8px; }
    .cal-row .what { white-space: normal; }

    /* Kid columns: ease up on font sizes */
    .kid-name { font-size: 1.15rem; }
    .stat-num { font-size: 1.5rem; }

    /* Dinner */
    .dinner-name { font-size: 1.2rem; }

    /* Modals: full-width on phone */
    .modal-bg { padding: 12px; }
    .modal { max-height: 95vh; }
    .modal-head { padding: 12px 16px; }
    .modal-body { padding: 14px 16px 18px; }
  }
</style>

<div class="dash">

  <!-- TOP BAR -->
  <div class="topbar">
    <span class="countdowns" id="countdowns"></span>
    <div></div>
    <div class="forecast">
      {% if weather %}
      <div class="fc-now">
        <span class="icon">{{ weather.now.icon }}</span>
        <div class="meta">
          <span class="temp">{{ weather.now.temp }}°</span>
          <span class="lo-hi">L {{ weather.now.lo }}° · H {{ weather.now.hi }}°</span>
        </div>
      </div>
      <div class="fc-days">
        {% for day in weather.days %}
        <div class="fc-day"><span class="d">{{ day.d }}</span><span class="i">{{ day.icon }}</span><span class="hi">{{ day.hi }}°</span><span class="lo">{{ day.lo }}°</span></div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>

  <!-- TODAY'S DINNER (tap for recipe) + tomorrow chip -->
  {% set todayMeal = null %}{% set tomorrowMeal = null %}
  {% for m in mealweek %}
    {% if m.isToday %}{% set todayMeal = m %}{% endif %}
    {% if m.isTomorrow %}{% set tomorrowMeal = m %}{% endif %}
  {% endfor %}
  <div class="card today">
    <h3 class="card-h">🍽 Tonight</h3>
    {% if todayMeal %}
    <div class="dinner-hero{% if not todayMeal.recipe %} no-recipe{% endif %}"
         {% if todayMeal.recipe %}data-recipe="{{ todayMeal.recipe.slug }}"{% endif %}>
      <div class="dinner-name">{{ todayMeal.name }}</div>
      {% if todayMeal.recipe %}<div class="dinner-tap">tap for recipe</div>{% endif %}
    </div>
    {% endif %}
    {% if tomorrowMeal %}
