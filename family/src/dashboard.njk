---
layout: base.njk
title: Family Dashboard
permalink: "/dashboard/index.html"
---

<style>
  /* Wall-mounted Kindle Fire 10": no nav, no scroll */
  #site-nav { display: none !important; }
  html, body { overflow: hidden; height: 100%; }
  body { background: var(--warm-bg); }

  .dash {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 56px 320px 1fr;
    grid-template-areas:
      "top    top    top    top"
      "today  cal    cal    budget"
      "kid1   kid2   kid3   kid4";
    gap: 10px;
    padding: 10px;
    height: 100vh;
    box-sizing: border-box;
  }

  /* === TOP BAR === */
  .topbar {
    grid-area: top;
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 24px;
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 8px 22px;
  }
  .fc-days { gap: 18px; }
  .clock-block {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .clock {
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    color: var(--accent-orange);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .date-inline {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1;
  }
  .date-inline .dow {
    color: var(--text-mid);
    margin-right: 6px;
  }
  .countdown {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(63,185,80,0.16);
    border: 1px solid rgba(63,185,80,0.35);
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent-teal);
    white-space: nowrap;
  }
  .countdown .n { font-weight: 800; }
  .countdown .lbl { color: var(--text-dark); font-weight: 600; }

  .forecast {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-content: flex-end;
  }
  .fc-now {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-right: 18px;
    border-right: 1px solid #30363d;
  }
  .fc-now .icon { font-size: 1.7rem; }
  .fc-now .temp { font-size: 1.6rem; font-weight: 800; line-height: 1; }
  .fc-now .lo-hi { font-size: 0.78rem; color: var(--text-mid); font-weight: 600; line-height: 1; margin-top: 2px; }
  .fc-now .meta { display: flex; flex-direction: column; gap: 3px; }

  .fc-days { display: flex; gap: 14px; }
  .fc-day {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 44px;
  }
  .fc-day .d { font-size: 0.65rem; color: var(--text-mid); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; line-height: 1; }
  .fc-day .i { font-size: 1.05rem; line-height: 1; margin: 1px 0; }
  .fc-day .hi { font-size: 0.85rem; font-weight: 700; line-height: 1; }
  .fc-day .lo { font-size: 0.7rem; color: var(--text-mid); font-weight: 500; line-height: 1; }

  /* === SHARED CARD === */
  .card {
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 14px 16px 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .card-h {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    margin: 0 0 10px;
    font-weight: 700;
  }
  .card-h .h-action {
    background: rgba(255,255,255,0.06);
    color: var(--text-dark);
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    cursor: pointer;
    border: none;
    text-transform: uppercase;
  }
  .card-h .h-action:hover, .card-h .h-action:active {
    background: rgba(255,255,255,0.12);
  }

  /* === WEEK MEAL PLAN === */
  .today { grid-area: today; }
  .week-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;
  }
  .week-row {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 10px;
    align-items: center;
    padding: 6px 9px;
    border-radius: 7px;
    background: rgba(255,255,255,0.02);
    cursor: pointer;
    transition: background 0.15s;
    min-height: 0;
  }
  .week-row:hover, .week-row:active { background: rgba(255,255,255,0.06); }
  .week-row.today-row {
    background: rgba(232,131,74,0.14);
  }
  .week-row .dow {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .week-row.today-row .dow { color: var(--accent-orange); }
  .week-row .meal {
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text-dark);
  }
  .week-row.no-recipe { cursor: default; }
  .week-row.no-recipe:hover { background: rgba(255,255,255,0.02); }
  .week-row.no-recipe.today-row:hover { background: rgba(232,131,74,0.14); }

  /* === CALENDAR === */
  .cal { grid-area: cal; }
  .cal-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
  }
  .cal-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    align-items: center;
    padding: 6px 10px;
    border-radius: 7px;
    background: rgba(255,255,255,0.02);
  }
  .cal-row.today-row {
    background: rgba(232,131,74,0.12);
  }
  .cal-row .when { font-weight: 700; color: var(--text-mid); font-size: 0.92rem; }
  .cal-row.today-row .when { color: var(--accent-orange); }
  .cal-row .what {
    font-size: 1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cal-row .who {
    font-size: 0.62rem;
    background: rgba(255,255,255,0.08);
    padding: 3px 9px;
    border-radius: 999px;
    color: var(--text-mid);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .cal-row .who.family    { background: rgba(232,131,74,0.2); color: var(--accent-orange); }
  .cal-row .who.nancy     { background: rgba(188,140,255,0.18); color: var(--accent-purple); }
  .cal-row .who.william   { background: rgba(63,185,80,0.18); color: var(--accent-teal); }
  .cal-row .who.henry     { background: rgba(88,166,255,0.18); color: var(--accent-blue); }
  .cal-row .who.charlie   { background: rgba(248,81,73,0.18); color: var(--accent-rose); }
  .cal-row .who.thomas    { background: rgba(210,153,34,0.2); color: var(--accent-gold); }
  .cal-row .who.parents   { background: rgba(188,140,255,0.18); color: var(--accent-purple); }
  .cal-row .who.mike      { background: rgba(63,185,80,0.18); color: var(--accent-teal); }

  /* === KID COLUMNS === */
  .kid {
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
    min-height: 0;
  }
  .kid-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 6px;
    border-bottom: 1px solid #21262d;
  }
  .kid-name { font-size: 1.3rem; font-weight: 800; letter-spacing: -0.3px; color: var(--text-dark); }
  .kid-meta { font-size: 0.68rem; color: var(--text-mid); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }

  .kid .section { display: flex; flex-direction: column; gap: 4px; }
  .kid .section .lbl {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.9px;
    color: var(--text-mid);
    font-weight: 700;
  }

  .hw-item {
    font-size: 0.9rem;
    padding: 9px 11px;
    background: rgba(255,255,255,0.03);
    border-radius: 7px;
    line-height: 1.3;
  }
  .hw-item.none {
    color: var(--text-mid);
    font-style: italic;
    font-size: 0.82rem;
    padding: 7px 11px;
  }
  .hw-item .due {
    display: block;
    font-size: 0.7rem;
    color: var(--text-mid);
    margin-top: 4px;
    font-style: normal;
  }
  .hw-item .progress {
    margin-top: 8px;
    height: 4px;
    background: #21262d;
    border-radius: 2px;
    overflow: hidden;
  }
  .hw-item .progress .bar {
    height: 100%;
    background: var(--accent-orange);
    border-radius: 2px;
  }

  .stat-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .stat-num {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--accent-teal);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .stat-num.warn { color: var(--accent-gold); }
  .stat-num.danger { color: var(--accent-rose); }
  .stat-sub { font-size: 0.75rem; color: var(--text-mid); font-weight: 500; margin-left: auto; }

  /* === MODAL === */
  .modal-bg {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .modal-bg.open { display: flex; }
  .modal {
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 16px;
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 22px;
    border-bottom: 1px solid #21262d;
  }
  .modal-head h2 { font-size: 1.4rem; font-weight: 800; margin: 0; }
  .modal-close {
    background: rgba(255,255,255,0.08);
    border: none;
    color: var(--text-dark);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 1.2rem;
    cursor: pointer;
    font-weight: 700;
  }
  .modal-body {
    padding: 18px 22px 22px;
    overflow-y: auto;
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .modal-body h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-mid);
    margin: 14px 0 8px;
  }
  .modal-body h3:first-child { margin-top: 0; }
  .modal-body ul, .modal-body ol { padding-left: 22px; margin: 0; }
  .modal-body li { margin-bottom: 6px; }
  .modal-body .meta {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--text-mid);
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid #21262d;
  }
  .modal-body .meta b { color: var(--text-dark); font-weight: 700; }

  /* Calendar expanded modal */
  .cal-filter {
    width: 100%;
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 8px;
    color: var(--text-dark);
    padding: 10px 14px;
    font-size: 0.95rem;
    margin-bottom: 14px;
    box-sizing: border-box;
  }
  .cal-filter:focus { outline: none; border-color: var(--accent-orange); }
  .cal-full-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cal-full-list .cal-row { padding: 8px 12px; }
  .cal-full-list .cal-row .what { font-size: 0.9rem; }
  .cal-month-h {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-mid);
    font-weight: 700;
    margin: 14px 0 4px;
    padding-left: 4px;
  }
  .cal-month-h:first-child { margin-top: 0; }

  /* === BUDGET STRIP (vertical, shares row with dinner+calendar) === */
  .budget {
    grid-area: budget;
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
  }
  .budget-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex-shrink: 0;
  }
  .budget-h {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    font-weight: 700;
  }
  .budget-month {
    font-size: 0.65rem;
    color: var(--text-mid);
    font-weight: 600;
  }
  .budget-cats {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    justify-content: space-around;
  }
  .budget-cat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .budget-cat .name {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .budget-cat .name .budget-status {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--text-mid);
    text-transform: none;
    letter-spacing: 0;
  }
  .budget-cat .name .budget-status.over { color: var(--accent-rose); }
  .budget-bars {
    position: relative;
    height: 18px;
    background: rgba(255,255,255,0.04);
    border-radius: 5px;
    overflow: visible;
  }
  .budget-bars .actual {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    border-radius: 5px;
    transition: width 0.4s;
  }
  .budget-bars .actual.ok    { background: var(--accent-teal); }
  .budget-bars .actual.warn  { background: var(--accent-gold); }
  .budget-bars .actual.over  { background: var(--accent-rose); }
  .budget-bars .pace {
    position: absolute;
    top: -4px;
    height: calc(100% + 8px);
    width: 3px;
    background: #ffffff;
    border-radius: 1px;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.6);
    transform: translateX(-1.5px);
  }
  .budget-bars .pace::after { display: none; }

  /* Grid assignments */
  .kid1 { grid-area: kid1; }
  .kid2 { grid-area: kid2; }
  .kid3 { grid-area: kid3; }
  .kid4 { grid-area: kid4; }

  /* === MOBILE (phones, sub-768px) ===
     Tablet layout untouched. Phone: scroll, single column, stack everything.
  */
  @media (max-width: 767px) {
    html, body { overflow: auto; height: auto; }

    .dash {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      grid-template-areas:
        "top"
        "today"
        "cal"
        "budget"
        "kid1"
        "kid2"
        "kid3"
        "kid4";
      height: auto;
      min-height: 100vh;
      gap: 8px;
      padding: 8px;
    }

    /* Top bar: stack clock, weather, forecast vertically */
    .topbar {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 10px 14px;
    }
    .clock-block { justify-content: space-between; }
    .clock { font-size: 2rem; }
    .forecast {
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .fc-now { padding-right: 12px; }
    .fc-days { gap: 10px; flex-wrap: wrap; }
    .fc-day { min-width: 38px; }

    /* Cards: don't cap height, let content size */
    .card, .kid, .budget {
      overflow: visible;
      min-height: 0;
    }

    /* Calendar: tighten when columns shrink */
    .cal-row { grid-template-columns: 72px 1fr; gap: 8px; }
    .cal-row .what { white-space: normal; }

    /* Kid columns: ease up on font sizes */
    .kid-name { font-size: 1.15rem; }
    .stat-num { font-size: 1.5rem; }

    /* Dinner */
    .dinner-name { font-size: 1.2rem; }

    /* Modals: full-width on phone */
    .modal-bg { padding: 12px; }
    .modal { max-height: 95vh; }
    .modal-head { padding: 12px 16px; }
    .modal-body { padding: 14px 16px 18px; }
  }
</style>

<div class="dash">

  <!-- TOP BAR -->
  <div class="topbar">
    <span class="countdown" id="countdown" style="display:none">
      <span class="n" id="countdownN">0</span>
      <span class="lbl" id="countdownLbl">days</span>
    </span>
    <div></div>
    <div class="forecast">
      {% if weather %}
      <div class="fc-now">
        <span class="icon">{{ weather.now.icon }}</span>
        <div class="meta">
          <span class="temp">{{ weather.now.temp }}°</span>
          <span class="lo-hi">L {{ weather.now.lo }}° · H {{ weather.now.hi }}°</span>
        </div>
      </div>
      <div class="fc-days">
        {% for day in weather.days %}
        <div class="fc-day"><span class="d">{{ day.d }}</span><span class="i">{{ day.icon }}</span><span class="hi">{{ day.hi }}°</span><span class="lo">{{ day.lo }}°</span></div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>

  <!-- WEEK MEAL PLAN (tap a day for recipe) -->
  <div class="card today">
    <h3 class="card-h">🍽 This Week</h3>
    <div class="week-list">
      {% for m in mealweek %}
      <div class="week-row{% if m.isToday %} today-row{% endif %}{% if not m.recipe %} no-recipe{% endif %}"
           {% if m.recipe %}data-recipe="{{ m.recipe.slug }}"{% endif %}>
        <span class="dow">{{ m.dow_short }}</span>
        <span class="meal">{{ m.name }}</span>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- CALENDAR -->
  <div class="card cal">
    <h3 class="card-h">
      <span>📅 Upcoming</span>
      <button class="h-action" id="calExpand">See all</button>
    </h3>
    <div class="cal-list" id="calPreview"></div>
  </div>

  {# === KID CARDS (Charlie / Henry / William / Thomas) === #}
  {% for kid in kids %}
  <div class="kid {{ kid.key }} kid{{ loop.index }}">
    <div class="kid-head">
      <span class="kid-name">{{ kid.name }}</span>
      <span class="kid-meta">{{ kid.grade }}</span>
    </div>

    {% if kid.sugar.balance is not none %}
    <div class="section">
      <span class="lbl">🍭 Sugar checks</span>
      <div class="stat-row">
        {# Balance = remaining grams. Negative = overspent (red). Low = warn. Healthy = green. #}
        {% set neg = kid.sugar.balance < 0 %}
        {% set low = kid.sugar.balance >= 0 and kid.sugar.balance < kid.sugar.refill * 0.5 %}
        <span class="stat-num{% if neg %} danger{% elif low %} warn{% endif %}">{{ kid.sugar.balance }}g</span>
        <span class="stat-sub">left</span>
      </div>
    </div>
    {% endif %}

    {% if kid.allowance.balance_str %}
    <div class="section">
      <span class="lbl">💵 Allowance</span>
      <div class="stat-row">
        {% set negA = '-' in kid.allowance.balance_str %}
        <span class="stat-num{% if negA %} danger{% endif %}">{{ kid.allowance.balance_str }}</span>
      </div>
    </div>
    {% endif %}

    {% if kid.reading %}
    <div class="section">
      <span class="lbl">📚 Summer reading</span>
      <div class="hw-item">
        <span class="due">{{ kid.reading.pages }} / {{ kid.reading.target }} pgs</span>
        <div class="progress"><div class="bar" style="width: {{ kid.reading.pct }}%"></div></div>
      </div>
    </div>
    {% endif %}
  </div>
  {% endfor %}

  <!-- BUDGET STRIP -->
  <div class="budget" id="budgetStrip">
    <div class="budget-head">
      <span class="budget-h">💳 Budget</span>
      <span class="budget-month" id="budgetMonth">June</span>
    </div>
    <div class="budget-cats">
      <div class="budget-cat" data-cat="shopping" data-pct="42">
        <div class="name">
          <span>Shopping</span>
          <span class="budget-status" id="status-shopping"></span>
        </div>
        <div class="budget-bars">
          <div class="actual" id="bar-shopping"></div>
          <div class="pace" id="pace-shopping"></div>
        </div>
      </div>
      <div class="budget-cat" data-cat="food" data-pct="68">
        <div class="name">
          <span>Food</span>
          <span class="budget-status" id="status-food"></span>
        </div>
        <div class="budget-bars">
          <div class="actual" id="bar-food"></div>
          <div class="pace" id="pace-food"></div>
        </div>
      </div>
      <div class="budget-cat" data-cat="ent" data-pct="89">
        <div class="name">
          <span>Entertainment</span>
          <span class="budget-status" id="status-ent"></span>
        </div>
        <div class="budget-bars">
          <div class="actual" id="bar-ent"></div>
          <div class="pace" id="pace-ent"></div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- RECIPE MODAL (content swapped per tapped day) -->
{% if mealweek %}
<div class="modal-bg" id="recipeModal">
  <div class="modal">
    <div class="modal-head">
      <h2 id="recipeTitle">Recipe</h2>
      <button class="modal-close" onclick="closeModal('recipeModal')">✕</button>
    </div>
    <div class="modal-body" id="recipeBody"></div>
  </div>
</div>

<script>
  // Recipe lookup table built from mealweek
  const RECIPES = {
    {% for m in mealweek %}{% if m.recipe %}
    {{ m.recipe.slug | dump | safe }}: {
      name: {{ m.recipe.name | dump | safe }},
      servings: {{ (m.recipe.servings or 0) | dump | safe }},
      prep_min: {{ (m.recipe.prep_min or 0) | dump | safe }},
      cook_min: {{ (m.recipe.cook_min or 0) | dump | safe }},
      effort: {{ (m.recipe.effort or '') | dump | safe }},
      protein_g: {{ (m.recipe.protein_g or 0) | dump | safe }},
      cal: {{ (m.recipe.cal or 0) | dump | safe }},
      body_html: {{ (m.recipe.body_html or '') | dump | safe }}
    },
    {% endif %}{% endfor %}
  };

  function openRecipe(slug) {
    const r = RECIPES[slug];
    if (!r) return;
    document.getElementById('recipeTitle').textContent = r.name;
    let meta = '<div class="meta">';
    if (r.servings) meta += '<span><b>Serves:</b> ' + r.servings + '</span>';
    if (r.prep_min) meta += '<span><b>Prep:</b> ' + r.prep_min + ' min</span>';
    if (r.cook_min) meta += '<span><b>Cook:</b> ' + r.cook_min + ' min</span>';
    if (r.effort) meta += '<span><b>Effort:</b> ' + r.effort + '</span>';
    if (r.protein_g) meta += '<span><b>Protein:</b> ' + r.protein_g + 'g</span>';
    if (r.cal) meta += '<span><b>Cal:</b> ' + r.cal + '</span>';
    meta += '</div>';
    document.getElementById('recipeBody').innerHTML = meta + r.body_html;
    openModal('recipeModal');
  }

  document.querySelectorAll('.week-row[data-recipe]').forEach(row => {
    row.addEventListener('click', () => openRecipe(row.dataset.recipe));
  });
</script>
{% endif %}

<!-- CALENDAR FULL MODAL -->
<div class="modal-bg" id="calModal">
  <div class="modal">
    <div class="modal-head">
      <h2>📅 All upcoming events</h2>
      <button class="modal-close" onclick="closeModal('calModal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="text" class="cal-filter" id="calFilter" placeholder="Filter events..." autocomplete="off" />
      <div id="calFullList"></div>
    </div>
  </div>
</div>

<script>
  // === EVENTS DATA (built at build time from cal_today.py via _data/calendar.js) ===
  const events = {{ calendar | dump | safe }};

  const today = new Date();
  // Use LOCAL date components, not toISOString() (which is UTC and rolls to "tomorrow" after ~8pm ET).
  const todayStr = today.getFullYear() + '-' +
    String(today.getMonth() + 1).padStart(2, '0') + '-' +
    String(today.getDate()).padStart(2, '0');

  function fmtWhen(ev) {
    const d = new Date(ev.date + 'T00:00:00');
    const dow = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];
    const diffDays = Math.round((d - new Date(todayStr + 'T00:00:00')) / 86400000);
    if (ev.date === todayStr) return 'Today ' + ev.time;
    if (diffDays >= 1 && diffDays < 7) return dow + ' ' + ev.time;
    const mo = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()];
    return mo + ' ' + d.getDate() + ' ' + ev.time;
  }

  function rowHTML(ev) {
    const isToday = ev.date === todayStr;
    return '<div class="cal-row' + (isToday ? ' today-row' : '') + '">' +
      '<span class="when">' + fmtWhen(ev) + '</span>' +
      '<span class="what">' + ev.what + '</span>' +
      '</div>';
  }

  // Render preview (top ~8 upcoming)
  function renderPreview() {
    const upcoming = events.filter(e => e.date >= todayStr).slice(0, 14);
    document.getElementById('calPreview').innerHTML = upcoming.map(rowHTML).join('');
  }
  renderPreview();

  // Render full modal list, grouped by month
  function renderFullList(filter = '') {
    const f = filter.trim().toLowerCase();
    const filtered = events
      .filter(e => e.date >= todayStr)
      .filter(e => !f || e.what.toLowerCase().includes(f));
    if (filtered.length === 0) {
      document.getElementById('calFullList').innerHTML = '<div style="padding:20px;text-align:center;color:var(--text-mid)">No matching events.</div>';
      return;
    }
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    let html = '';
    let currentMonth = '';
    filtered.forEach(ev => {
      const d = new Date(ev.date + 'T00:00:00');
      const monthKey = months[d.getMonth()] + ' ' + d.getFullYear();
      if (monthKey !== currentMonth) {
        html += '<div class="cal-month-h">' + monthKey + '</div>';
        currentMonth = monthKey;
      }
      html += rowHTML(ev);
    });
    document.getElementById('calFullList').innerHTML = '<div class="cal-full-list">' + html + '</div>';
  }

  // === MODAL CONTROLS ===
  function openModal(id) {
    document.getElementById(id).classList.add('open');
    if (id === 'calModal') {
      renderFullList();
      setTimeout(() => document.getElementById('calFilter').focus(), 50);
    }
  }
  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }
  window.closeModal = closeModal;

  const dinnerCard = null;
  document.getElementById('calExpand').addEventListener('click', (e) => { e.stopPropagation(); openModal('calModal'); });
  document.getElementById('calFilter').addEventListener('input', (e) => renderFullList(e.target.value));

  // Click backdrop to close
  document.querySelectorAll('.modal-bg').forEach(bg => {
    bg.addEventListener('click', (e) => { if (e.target === bg) bg.classList.remove('open'); });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') document.querySelectorAll('.modal-bg.open').forEach(m => m.classList.remove('open'));
  });

  // === COUNTDOWNS ===
  // [{ label, date: 'YYYY-MM-DD' }] first non-past one wins
  const COUNTDOWNS = [
    { label: 'lake trip', date: '2026-07-06' },
  ];
  function renderCountdown() {
    const el = document.getElementById('countdown');
    const today = new Date();
    const todayMid = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    for (const c of COUNTDOWNS) {
      const [y, m, d] = c.date.split('-').map(Number);
      const target = new Date(y, m - 1, d);
      const days = Math.round((target - todayMid) / 86400000);
      if (days < 0) continue;
      document.getElementById('countdownN').textContent = days === 0 ? 'today!' : days;
      document.getElementById('countdownLbl').textContent = days === 0 ? c.label : 'days to ' + c.label;
      el.style.display = 'inline-flex';
      return;
    }
    el.style.display = 'none';
  }
  renderCountdown();

  // === AUTO-RELOAD (was paired with clock tick) ===
  setTimeout(() => location.reload(), 10 * 60 * 1000);

  // === BUDGET STRIP ===
  function renderBudget() {
    const now = new Date();
    const dayOfMonth = now.getDate();
    const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
    const monthPct = Math.round((dayOfMonth / daysInMonth) * 100);
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    document.getElementById('budgetMonth').textContent = months[now.getMonth()] + ' · day ' + dayOfMonth + '/' + daysInMonth;

    document.querySelectorAll('.budget-cat').forEach(cat => {
      const key = cat.dataset.cat;
      const pct = parseInt(cat.dataset.pct, 10);
      const bar = document.getElementById('bar-' + key);
      const pace = document.getElementById('pace-' + key);
      const status = document.getElementById('status-' + key);

      bar.style.width = Math.min(pct, 100) + '%';
      pace.style.left = Math.min(monthPct, 100) + '%';

      // Color: green if ahead of pace, yellow if slightly behind, red if blown past 100
      if (pct >= 100) {
        bar.className = 'actual over';
        status.textContent = 'over';
        status.className = 'budget-status over';
      } else if (pct > monthPct + 8) {
        bar.className = 'actual warn';
        status.textContent = 'pacing high';
        status.className = 'budget-status';
      } else {
        bar.className = 'actual ok';
        status.textContent = 'on pace';
        status.className = 'budget-status';
      }
    });
  }
  renderBudget();
</script>
