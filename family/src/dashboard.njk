<script>
  function pad(n) { return String(n).padStart(2, '0'); }
  function tick() {
    const now = new Date();
    const h = now.getHours(), m = now.getMinutes();
    const h12 = ((h + 11) % 12) + 1;
    const ampm = h >= 12 ? 'pm' : 'am';
    document.getElementById('clock').textContent = h12 + ':' + pad(m) + ampm;
    const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    document.getElementById('dow').textContent = days[now.getDay()];
    document.getElementById('date').textContent = months[now.getMonth()] + ' ' + now.getDate() + ', ' + now.getFullYear();
  }
  tick();
  setInterval(tick, 1000 * 30);
  // Periodic refresh so stale data clears
  setTimeout(() => location.reload(), 10 * 60 * 1000);
</script>
