<style>
  /* Wall-mounted Kindle Fire 10": no nav, no scroll */
  #site-nav { display: none !important; }
  html, body { overflow: hidden; height: 100%; }
  body { background: var(--warm-bg); }

  .dash {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: 60px minmax(200px, 30%) 1fr;
    grid-template-areas:
      "top    top    top    top    top"
      "today  cal    cal    cal    cal"
      "kid1   kid2   kid3   kid4   kid5";
    gap: 10px;
    padding: 10px;
    height: 100vh;
    box-sizing: border-box;
  }

  /* === TOP BAR === */
  .topbar {
    grid-area: top;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 28px;
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 12px 24px;
  }
  .clock {
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    color: var(--accent-orange);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .date-block { display: flex; flex-direction: column; line-height: 1.15; }
  .date-block .dow { font-size: 1rem; color: var(--text-mid); font-weight: 600; }
  .date-block .date { font-size: 1.25rem; font-weight: 700; }
  .weather {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 1.3rem;
  }
  .weather .icon { font-size: 1.8rem; }
  .weather .temp { font-weight: 800; font-size: 1.6rem; }
  .weather .lo-hi { color: var(--text-mid); font-size: 0.95rem; font-weight: 600; }

  /* === SHARED CARD === */
  .card {
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 12px 16px 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .card-h {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--text-mid);
    margin: 0 0 8px;
    font-weight: 700;
  }

  /* === DINNER (left of middle row) === */
  .today { grid-area: today; }
  .dinner-name {
    font-size: 1.3rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 6px;
  }
  .dinner-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.78rem;
    color: var(--text-mid);
  }
  .dinner-meta .row { display: flex; gap: 8px; align-items: baseline; }
  .dinner-meta .row .k { color: var(--text-light); font-weight: 600; min-width: 52px; text-transform: uppercase; font-size: 0.62rem; letter-spacing: 0.5px; }
  .dinner-meta .row .v { color: var(--text-dark); font-weight: 600; font-size: 0.82rem; }
  .dinner-tag {
    margin-top: auto;
    display: inline-block;
    align-self: flex-start;
    background: rgba(63,185,80,0.15);
    color: var(--accent-teal);
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* === CALENDAR (right of middle row) === */
  .cal { grid-area: cal; }
  .cal-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
  }
  .cal-row {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 7px 12px;
    border-radius: 8px;
    background: rgba(255,255,255,0.02);
  }
  .cal-row.today-row {
    background: rgba(232,131,74,0.12);
    border-left: 3px solid var(--accent-orange);
    padding-left: 9px;
  }
  .cal-row .when { font-weight: 700; color: var(--text-mid); font-size: 0.82rem; }
  .cal-row.today-row .when { color: var(--accent-orange); }
  .cal-row .what {
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cal-row .who {
    font-size: 0.65rem;
    background: rgba(255,255,255,0.08);
    padding: 3px 9px;
    border-radius: 999px;
    color: var(--text-mid);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .cal-row .who.family    { background: rgba(232,131,74,0.2); color: var(--accent-orange); }
  .cal-row .who.nancy     { background: rgba(188,140,255,0.18); color: var(--accent-purple); }
  .cal-row .who.william   { background: rgba(63,185,80,0.18); color: var(--accent-teal); }
  .cal-row .who.henry     { background: rgba(88,166,255,0.18); color: var(--accent-blue); }
  .cal-row .who.charlie   { background: rgba(248,81,73,0.18); color: var(--accent-rose); }
  .cal-row .who.thomas    { background: rgba(210,153,34,0.2); color: var(--accent-gold); }
  .cal-row .who.parents   { background: rgba(188,140,255,0.18); color: var(--accent-purple); }

  /* === KID COLUMNS === */
  .kid {
    background: var(--card-bg);
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 11px 12px 13px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
    min-height: 0;
    border-top-width: 4px;
    border-top-style: solid;
  }
  .kid.charlie { border-top-color: var(--accent-rose); }
  .kid.henry   { border-top-color: var(--accent-blue); }
  .kid.william { border-top-color: var(--accent-teal); }
  .kid.thomas  { border-top-color: var(--accent-gold); }
  .kid.nancy   { border-top-color: var(--accent-purple); }

  .kid-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 3px;
    border-bottom: 1px solid #21262d;
  }
  .kid-name { font-size: 1.15rem; font-weight: 800; letter-spacing: -0.3px; }
  .kid-meta { font-size: 0.65rem; color: var(--text-mid); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }

  .kid .section { display: flex; flex-direction: column; gap: 4px; }
  .kid .section .lbl {
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.9px;
    color: var(--text-mid);
    font-weight: 700;
  }

  .hw-item {
    font-size: 0.8rem;
    padding: 6px 9px;
    background: rgba(255,255,255,0.03);
    border-radius: 6px;
    border-left: 2px solid var(--accent-orange);
    line-height: 1.3;
  }
  .hw-item.none {
    color: var(--text-mid);
    border-left-color: #30363d;
    font-style: italic;
    font-size: 0.75rem;
    padding: 5px 9px;
    background: transparent;
  }
  .hw-item .due {
    display: block;
    font-size: 0.65rem;
    color: var(--text-mid);
    margin-top: 2px;
    font-style: normal;
  }
  .hw-item .progress {
    margin-top: 5px;
    height: 3px;
    background: #21262d;
    border-radius: 2px;
    overflow: hidden;
  }
  .hw-item .progress .bar {
    height: 100%;
    background: var(--accent-orange);
    border-radius: 2px;
  }

  .sugar-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .sugar-num {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--accent-teal);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .sugar-num.warn { color: var(--accent-gold); }
  .sugar-num.danger { color: var(--accent-rose); }
  .sugar-total {
    font-size: 0.78rem;
    color: var(--text-mid);
    font-weight: 600;
  }
  .sugar-label { font-size: 0.68rem; color: var(--text-mid); margin-left: auto; font-weight: 500; }

  .money {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--accent-teal);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .activity {
    font-size: 0.78rem;
    padding: 5px 9px;
    background: rgba(88,166,255,0.12);
    border-radius: 6px;
    color: var(--accent-blue);
    font-weight: 600;
    line-height: 1.3;
  }
  .activity.none {
    background: transparent;
    color: var(--text-light);
    padding: 0;
    font-style: italic;
    font-weight: 400;
    font-size: 0.75rem;
  }
  .activity.warn {
    background: rgba(248,81,73,0.12);
    color: var(--accent-rose);
  }

  /* Kid grid assignments */
  .kid1 { grid-area: kid1; }
  .kid2 { grid-area: kid2; }
  .kid3 { grid-area: kid3; }
  .kid4 { grid-area: kid4; }
  .kid5 { grid-area: kid5; }
</style>

